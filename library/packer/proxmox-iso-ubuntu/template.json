{
  "version": "1",
  "slug": "proxmox-iso-ubuntu",
  "kind": "packer",
  "metadata": {
    "name": "Proxmox Ubuntu Server Template (ISO)",
    "description": "Packer template to create an Ubuntu Server VM template on Proxmox using ISO installation. This template creates a cloud-init enabled Ubuntu VM that can be used as a template for cloning.\n\nFeatures: - Automated Ubuntu installation via autoinstall - Cloud-init integration - QEMU guest agent - Configurable CPU, memory, and disk settings - SSH authentication (password or key-based)\n\nProject: https://www.packer.io/\nDocumentation: https://developer.hashicorp.com/packer/integrations/hashicorp/proxmox\n",
    "author": "Christian Lempa",
    "template_version": "1.11.2",
    "icon": {
      "provider": "simple-icons",
      "id": "proxmox"
    },
    "date": "2024-11-11"
  },
  "entrypoint": {
    "path": "proxmox-iso-ubuntu.pkr.hcl",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "playbook_name",
          "type": "str",
          "title": "Name of the playbook",
          "required": false,
          "description": "Name of the playbook"
        },
        {
          "name": "image_name",
          "type": "str",
          "title": "Image Name",
          "required": false,
          "default": "ubuntu-server-noble"
        },
        {
          "name": "vm_id",
          "type": "int",
          "title": "Proxmox VM ID for the template",
          "required": false,
          "default": 100,
          "description": "Proxmox VM ID for the template"
        },
        {
          "name": "vm_description",
          "type": "str",
          "title": "VM template description",
          "required": false,
          "default": "Ubuntu Server Noble (24.04) Image",
          "description": "VM template description"
        },
        {
          "name": "proxmox_node",
          "type": "str",
          "title": "Proxmox node name where the VM will be created",
          "required": false,
          "default": "pve",
          "description": "Proxmox node name where the VM will be created"
        }
      ]
    },
    {
      "key": "proxmox",
      "title": "Proxmox Connection",
      "variables": [
        {
          "name": "proxmox_api_url",
          "type": "str",
          "title": "Proxmox API URL (e.g., https://proxmox.example.com:8006/api2/json)",
          "required": false,
          "default": "https://proxmox.local:8006/api2/json",
          "description": "Proxmox API URL (e.g., https://proxmox.example.com:8006/api2/json)"
        },
        {
          "name": "proxmox_api_token_id",
          "type": "str",
          "title": "Proxmox API token ID (e.g., root@pam!packer)",
          "required": false,
          "default": "root@pam!packer",
          "description": "Proxmox API token ID (e.g., root@pam!packer)"
        },
        {
          "name": "proxmox_api_token_secret",
          "type": "str",
          "title": "Proxmox API token secret",
          "required": false,
          "default": "",
          "description": "Proxmox API token secret",
          "sensitive": true
        },
        {
          "name": "skip_tls_verify",
          "type": "bool",
          "title": "Skip TLS certificate verification",
          "required": false,
          "default": false,
          "description": "Skip TLS certificate verification"
        }
      ]
    },
    {
      "key": "iso",
      "title": "ISO Configuration",
      "variables": [
        {
          "name": "iso_source",
          "type": "str",
          "title": "ISO source type",
          "required": false,
          "default": "local",
          "description": "ISO source type",
          "options": [
            "local",
            "download"
          ]
        },
        {
          "name": "iso_file",
          "type": "str",
          "title": "Local ISO file path (for local source)",
          "required": false,
          "default": "local:iso/ubuntu-24.04-live-server-amd64.iso",
          "description": "Local ISO file path (for local source)"
        },
        {
          "name": "iso_url",
          "type": "str",
          "title": "ISO download URL (for download source)",
          "required": false,
          "default": "https://releases.ubuntu.com/24.04/ubuntu-24.04-live-server-amd64.iso",
          "description": "ISO download URL (for download source)"
        },
        {
          "name": "iso_storage",
          "type": "str",
          "title": "Proxmox storage for downloaded ISO",
          "required": false,
          "default": "local",
          "description": "Proxmox storage for downloaded ISO"
        },
        {
          "name": "iso_checksum",
          "type": "str",
          "title": "ISO checksum (SHA256 or checksum file URL)",
          "required": false,
          "default": "e240e4b801f7bb68c20d1356b60968ad0c33a41d00d828e74ceb3364a0317be9",
          "description": "ISO checksum (SHA256 or checksum file URL)"
        }
      ]
    },
    {
      "key": "hardware",
      "title": "Hardware Configuration",
      "variables": [
        {
          "name": "cpu_cores",
          "type": "int",
          "title": "Number of CPU cores",
          "required": false,
          "default": 1,
          "description": "Number of CPU cores"
        },
        {
          "name": "memory_mb",
          "type": "int",
          "title": "Memory in MB",
          "required": false,
          "default": 2048,
          "description": "Memory in MB"
        },
        {
          "name": "disk_size",
          "type": "str",
          "title": "Disk size (e.g., 25G, 50G)",
          "required": false,
          "default": "25G",
          "description": "Disk size (e.g., 25G, 50G)"
        },
        {
          "name": "disk_storage",
          "type": "str",
          "title": "Proxmox storage pool for disk",
          "required": false,
          "default": "local-lvm",
          "description": "Proxmox storage pool for disk"
        },
        {
          "name": "network_bridge",
          "type": "str",
          "title": "Network bridge",
          "required": false,
          "default": "vmbr0",
          "description": "Network bridge"
        }
      ]
    },
    {
      "key": "cloudinit",
      "title": "Cloud-Init Configuration",
      "variables": [
        {
          "name": "cloudinit_storage",
          "type": "str",
          "title": "Proxmox storage pool for cloud-init disk",
          "required": false,
          "default": "local-lvm",
          "description": "Proxmox storage pool for cloud-init disk"
        },
        {
          "name": "locale",
          "type": "str",
          "title": "System locale",
          "required": false,
          "default": "en_US",
          "description": "System locale"
        },
        {
          "name": "keyboard_layout",
          "type": "str",
          "title": "Keyboard layout",
          "required": false,
          "default": "us",
          "description": "Keyboard layout"
        },
        {
          "name": "timezone",
          "type": "str",
          "title": "System timezone",
          "required": false,
          "default": "UTC",
          "description": "System timezone"
        }
      ]
    },
    {
      "key": "ssh",
      "title": "SSH Configuration",
      "variables": [
        {
          "name": "ssh_username",
          "type": "str",
          "title": "SSH username for provisioning",
          "required": false,
          "default": "ubuntu",
          "description": "SSH username for provisioning"
        },
        {
          "name": "ssh_auth_method",
          "type": "str",
          "title": "SSH authentication method",
          "required": false,
          "default": "password",
          "description": "SSH authentication method",
          "options": [
            "password",
            "key"
          ]
        },
        {
          "name": "ssh_password",
          "type": "str",
          "title": "SSH password (for password auth)",
          "required": false,
          "default": "",
          "description": "SSH password (for password auth)",
          "sensitive": true
        },
        {
          "name": "ssh_private_key_file",
          "type": "str",
          "title": "SSH private key file path (for key auth)",
          "required": false,
          "default": "~/.ssh/id_rsa",
          "description": "SSH private key file path (for key auth)"
        },
        {
          "name": "ssh_public_key",
          "type": "str",
          "title": "SSH public key (for key auth in cloud-init)",
          "required": false,
          "default": "",
          "description": "SSH public key (for key auth in cloud-init)"
        },
        {
          "name": "ssh_timeout",
          "type": "str",
          "title": "SSH connection timeout",
          "required": false,
          "default": "30m",
          "description": "SSH connection timeout"
        }
      ]
    },
    {
      "key": "boot",
      "title": "Boot Configuration",
      "variables": [
        {
          "name": "boot_wait",
          "type": "str",
          "title": "Time to wait before typing boot command",
          "required": false,
          "default": "10s",
          "description": "Time to wait before typing boot command"
        },
        {
          "name": "http_bind_address",
          "type": "str",
          "title": "HTTP server bind address for autoinstall",
          "required": false,
          "default": "0.0.0.0",
          "description": "HTTP server bind address for autoinstall"
        },
        {
          "name": "http_port_min",
          "type": "int",
          "title": "HTTP server minimum port",
          "required": false,
          "default": 8802,
          "description": "HTTP server minimum port"
        },
        {
          "name": "http_port_max",
          "type": "int",
          "title": "HTTP server maximum port",
          "required": false,
          "default": 8802,
          "description": "HTTP server maximum port"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
