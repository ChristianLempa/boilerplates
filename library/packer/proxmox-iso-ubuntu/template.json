{
  "version": "1",
  "slug": "proxmox-iso-ubuntu",
  "kind": "packer",
  "metadata": {
    "name": "Proxmox Ubuntu Server Template (ISO)",
    "description": "Packer template to create an Ubuntu Server VM template on Proxmox using ISO installation. This template creates a cloud-init enabled Ubuntu VM that can be used as a template for cloning.\n\nFeatures: - Automated Ubuntu installation via autoinstall - Cloud-init integration - QEMU guest agent - Configurable CPU, memory, and disk settings - SSH authentication (password or key-based)\n\nProject: https://www.packer.io/\nDocumentation: https://developer.hashicorp.com/packer/integrations/hashicorp/proxmox\n",
    "author": "Christian Lempa",
    "template_version": "1.11.2",
    "icon": {
      "provider": "selfh",
      "id": "proxmox"
    },
    "date": "2024-11-11"
  },
  "entrypoint": {
    "path": "proxmox-iso-ubuntu.pkr.hcl",
    "type": "file"
  },
  "variables": [
    {
      "key": "playbook_name",
      "type": "string",
      "label": "Name of the playbook",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "description": "Name of the playbook"
    },
    {
      "key": "image_name",
      "type": "string",
      "label": "Image Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "ubuntu-server-noble"
    },
    {
      "key": "vm_id",
      "type": "number",
      "label": "Proxmox VM ID for the template",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "int",
      "default": 100,
      "description": "Proxmox VM ID for the template"
    },
    {
      "key": "vm_description",
      "type": "string",
      "label": "VM template description",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "Ubuntu Server Noble (24.04) Image",
      "description": "VM template description"
    },
    {
      "key": "proxmox_node",
      "type": "string",
      "label": "Proxmox node name where the VM will be created",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "pve",
      "description": "Proxmox node name where the VM will be created"
    },
    {
      "key": "proxmox_api_url",
      "type": "string",
      "label": "Proxmox API URL (e.g., https://proxmox.example.com:8006/api2/json)",
      "required": false,
      "section": {
        "key": "proxmox",
        "title": "Proxmox Connection",
        "required": true
      },
      "source_type": "url",
      "default": "https://proxmox.local:8006/api2/json",
      "description": "Proxmox API URL (e.g., https://proxmox.example.com:8006/api2/json)"
    },
    {
      "key": "proxmox_api_token_id",
      "type": "string",
      "label": "Proxmox API token ID (e.g., root@pam!packer)",
      "required": false,
      "section": {
        "key": "proxmox",
        "title": "Proxmox Connection",
        "required": true
      },
      "source_type": "str",
      "default": "root@pam!packer",
      "description": "Proxmox API token ID (e.g., root@pam!packer)"
    },
    {
      "key": "proxmox_api_token_secret",
      "type": "string",
      "label": "Proxmox API token secret",
      "required": false,
      "section": {
        "key": "proxmox",
        "title": "Proxmox Connection",
        "required": true
      },
      "source_type": "str",
      "default": "",
      "description": "Proxmox API token secret",
      "sensitive": true
    },
    {
      "key": "skip_tls_verify",
      "type": "boolean",
      "label": "Skip TLS certificate verification",
      "required": false,
      "section": {
        "key": "proxmox",
        "title": "Proxmox Connection",
        "required": true
      },
      "source_type": "bool",
      "default": false,
      "description": "Skip TLS certificate verification"
    },
    {
      "key": "iso_source",
      "type": "string",
      "label": "ISO source type",
      "required": false,
      "section": {
        "key": "iso",
        "title": "ISO Configuration",
        "required": true
      },
      "source_type": "enum",
      "default": "local",
      "description": "ISO source type",
      "options": [
        "local",
        "download"
      ]
    },
    {
      "key": "iso_file",
      "type": "string",
      "label": "Local ISO file path (for local source)",
      "required": false,
      "section": {
        "key": "iso",
        "title": "ISO Configuration",
        "required": true
      },
      "source_type": "str",
      "default": "local:iso/ubuntu-24.04-live-server-amd64.iso",
      "description": "Local ISO file path (for local source)"
    },
    {
      "key": "iso_url",
      "type": "string",
      "label": "ISO download URL (for download source)",
      "required": false,
      "section": {
        "key": "iso",
        "title": "ISO Configuration",
        "required": true
      },
      "source_type": "url",
      "default": "https://releases.ubuntu.com/24.04/ubuntu-24.04-live-server-amd64.iso",
      "description": "ISO download URL (for download source)"
    },
    {
      "key": "iso_storage",
      "type": "string",
      "label": "Proxmox storage for downloaded ISO",
      "required": false,
      "section": {
        "key": "iso",
        "title": "ISO Configuration",
        "required": true
      },
      "source_type": "str",
      "default": "local",
      "description": "Proxmox storage for downloaded ISO"
    },
    {
      "key": "iso_checksum",
      "type": "string",
      "label": "ISO checksum (SHA256 or checksum file URL)",
      "required": false,
      "section": {
        "key": "iso",
        "title": "ISO Configuration",
        "required": true
      },
      "source_type": "str",
      "default": "e240e4b801f7bb68c20d1356b60968ad0c33a41d00d828e74ceb3364a0317be9",
      "description": "ISO checksum (SHA256 or checksum file URL)"
    },
    {
      "key": "cpu_cores",
      "type": "number",
      "label": "Number of CPU cores",
      "required": false,
      "section": {
        "key": "hardware",
        "title": "Hardware Configuration"
      },
      "source_type": "int",
      "default": 1,
      "description": "Number of CPU cores"
    },
    {
      "key": "memory_mb",
      "type": "number",
      "label": "Memory in MB",
      "required": false,
      "section": {
        "key": "hardware",
        "title": "Hardware Configuration"
      },
      "source_type": "int",
      "default": 2048,
      "description": "Memory in MB"
    },
    {
      "key": "disk_size",
      "type": "string",
      "label": "Disk size (e.g., 25G, 50G)",
      "required": false,
      "section": {
        "key": "hardware",
        "title": "Hardware Configuration"
      },
      "source_type": "str",
      "default": "25G",
      "description": "Disk size (e.g., 25G, 50G)"
    },
    {
      "key": "disk_storage",
      "type": "string",
      "label": "Proxmox storage pool for disk",
      "required": false,
      "section": {
        "key": "hardware",
        "title": "Hardware Configuration"
      },
      "source_type": "str",
      "default": "local-lvm",
      "description": "Proxmox storage pool for disk"
    },
    {
      "key": "network_bridge",
      "type": "string",
      "label": "Network bridge",
      "required": false,
      "section": {
        "key": "hardware",
        "title": "Hardware Configuration"
      },
      "source_type": "str",
      "default": "vmbr0",
      "description": "Network bridge"
    },
    {
      "key": "cloudinit_storage",
      "type": "string",
      "label": "Proxmox storage pool for cloud-init disk",
      "required": false,
      "section": {
        "key": "cloudinit",
        "title": "Cloud-Init Configuration"
      },
      "source_type": "str",
      "default": "local-lvm",
      "description": "Proxmox storage pool for cloud-init disk"
    },
    {
      "key": "locale",
      "type": "string",
      "label": "System locale",
      "required": false,
      "section": {
        "key": "cloudinit",
        "title": "Cloud-Init Configuration"
      },
      "source_type": "str",
      "default": "en_US",
      "description": "System locale"
    },
    {
      "key": "keyboard_layout",
      "type": "string",
      "label": "Keyboard layout",
      "required": false,
      "section": {
        "key": "cloudinit",
        "title": "Cloud-Init Configuration"
      },
      "source_type": "str",
      "default": "us",
      "description": "Keyboard layout"
    },
    {
      "key": "timezone",
      "type": "string",
      "label": "System timezone",
      "required": false,
      "section": {
        "key": "cloudinit",
        "title": "Cloud-Init Configuration"
      },
      "source_type": "str",
      "default": "UTC",
      "description": "System timezone"
    },
    {
      "key": "ssh_username",
      "type": "string",
      "label": "SSH username for provisioning",
      "required": false,
      "section": {
        "key": "ssh",
        "title": "SSH Configuration",
        "required": true
      },
      "source_type": "str",
      "default": "ubuntu",
      "description": "SSH username for provisioning"
    },
    {
      "key": "ssh_auth_method",
      "type": "string",
      "label": "SSH authentication method",
      "required": false,
      "section": {
        "key": "ssh",
        "title": "SSH Configuration",
        "required": true
      },
      "source_type": "enum",
      "default": "password",
      "description": "SSH authentication method",
      "options": [
        "password",
        "key"
      ]
    },
    {
      "key": "ssh_password",
      "type": "string",
      "label": "SSH password (for password auth)",
      "required": false,
      "section": {
        "key": "ssh",
        "title": "SSH Configuration",
        "required": true
      },
      "source_type": "str",
      "default": "",
      "description": "SSH password (for password auth)",
      "sensitive": true
    },
    {
      "key": "ssh_private_key_file",
      "type": "string",
      "label": "SSH private key file path (for key auth)",
      "required": false,
      "section": {
        "key": "ssh",
        "title": "SSH Configuration",
        "required": true
      },
      "source_type": "str",
      "default": "~/.ssh/id_rsa",
      "description": "SSH private key file path (for key auth)"
    },
    {
      "key": "ssh_public_key",
      "type": "string",
      "label": "SSH public key (for key auth in cloud-init)",
      "required": false,
      "section": {
        "key": "ssh",
        "title": "SSH Configuration",
        "required": true
      },
      "source_type": "str",
      "default": "",
      "description": "SSH public key (for key auth in cloud-init)"
    },
    {
      "key": "ssh_timeout",
      "type": "string",
      "label": "SSH connection timeout",
      "required": false,
      "section": {
        "key": "ssh",
        "title": "SSH Configuration",
        "required": true
      },
      "source_type": "str",
      "default": "30m",
      "description": "SSH connection timeout"
    },
    {
      "key": "boot_wait",
      "type": "string",
      "label": "Time to wait before typing boot command",
      "required": false,
      "section": {
        "key": "boot",
        "title": "Boot Configuration"
      },
      "source_type": "str",
      "default": "10s",
      "description": "Time to wait before typing boot command"
    },
    {
      "key": "http_bind_address",
      "type": "string",
      "label": "HTTP server bind address for autoinstall",
      "required": false,
      "section": {
        "key": "boot",
        "title": "Boot Configuration"
      },
      "source_type": "str",
      "default": "0.0.0.0",
      "description": "HTTP server bind address for autoinstall"
    },
    {
      "key": "http_port_min",
      "type": "number",
      "label": "HTTP server minimum port",
      "required": false,
      "section": {
        "key": "boot",
        "title": "Boot Configuration"
      },
      "source_type": "int",
      "default": 8802,
      "description": "HTTP server minimum port"
    },
    {
      "key": "http_port_max",
      "type": "number",
      "label": "HTTP server maximum port",
      "required": false,
      "section": {
        "key": "boot",
        "title": "Boot Configuration"
      },
      "source_type": "int",
      "default": 8802,
      "description": "HTTP server maximum port"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
