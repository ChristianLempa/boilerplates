{
  "version": "1",
  "slug": "cloudflare-dns-record",
  "kind": "terraform",
  "metadata": {
    "name": "Cloudflare DNS Record",
    "description": "Create Cloudflare DNS records (A, AAAA, CNAME, TXT, MX) with configurable settings.\n\nSupports all common DNS record types with proxy status and TTL configuration.\n\nProject: https://www.cloudflare.com/\nDocumentation: https://registry.terraform.io/providers/cloudflare/cloudflare/latest/docs/resources/dns_record",
    "tags": [],
    "author": "Christian Lempa",
    "template_version": "5.12.0",
    "date": "2025-11-11",
    "icon": {
      "provider": "simple-icons",
      "id": "cloudflare"
    },
    "draft": false,
    "next_steps": ""
  },
  "entrypoint": {
    "path": "cloudflare_dns_record.tf",
    "type": "file"
  },
  "variables": [
    {
      "key": "comment",
      "title": "Comment",
      "variables": [
        {
          "name": "comment_enabled",
          "type": "bool",
          "title": "Add comment to DNS record",
          "required": false,
          "default": false,
          "description": "Add comment to DNS record"
        },
        {
          "name": "comment_text",
          "type": "str",
          "title": "Comment for the DNS record",
          "required": false,
          "default": "Managed by Terraform",
          "description": "Comment for the DNS record"
        }
      ]
    },
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "resource_name",
          "type": "str",
          "title": "Terraform resource name (alphanumeric and underscores only)",
          "required": false,
          "default": "dns_record",
          "description": "Terraform resource name (alphanumeric and underscores only)"
        },
        {
          "name": "zone_id_value",
          "type": "str",
          "title": "Cloudflare Zone ID",
          "required": false,
          "description": "Cloudflare Zone ID"
        }
      ]
    },
    {
      "key": "mx",
      "title": "MX Record Settings",
      "variables": [
        {
          "name": "mx_enabled",
          "type": "bool",
          "title": "Configure MX record priority",
          "required": false,
          "default": false,
          "description": "Configure MX record priority"
        },
        {
          "name": "priority",
          "type": "int",
          "title": "MX record priority (lower = higher priority)",
          "required": false,
          "default": 10,
          "description": "MX record priority (lower = higher priority)"
        }
      ]
    },
    {
      "key": "record",
      "title": "DNS Record",
      "variables": [
        {
          "name": "content",
          "type": "str",
          "title": "DNS record content (IP, hostname, or text)",
          "required": false,
          "default": "192.0.2.1",
          "description": "DNS record content (IP, hostname, or text)"
        },
        {
          "name": "name",
          "type": "str",
          "title": "DNS record name (use @ for root domain)",
          "required": false,
          "default": "www",
          "description": "DNS record name (use @ for root domain)"
        },
        {
          "name": "proxied",
          "type": "bool",
          "title": "Enable Cloudflare proxy (orange cloud)",
          "required": false,
          "default": true,
          "description": "Enable Cloudflare proxy (orange cloud)"
        },
        {
          "name": "record_type",
          "type": "str",
          "title": "DNS record type",
          "required": false,
          "default": "A",
          "description": "DNS record type",
          "options": [
            "A",
            "AAAA",
            "CNAME",
            "TXT",
            "MX"
          ]
        },
        {
          "name": "ttl",
          "type": "int",
          "title": "Time to live (1 = automatic, or 60-86400 seconds)",
          "required": false,
          "default": 1,
          "description": "Time to live (1 = automatic, or 60-86400 seconds)"
        }
      ]
    },
    {
      "key": "depends-on",
      "title": "Dependencies",
      "variables": [
        {
          "name": "depends_on_enabled",
          "type": "bool",
          "title": "Enable resource dependencies",
          "required": false,
          "default": false,
          "description": "Enable resource dependencies"
        },
        {
          "name": "dependencies",
          "type": "str",
          "title": "Comma-separated list of resource dependencies",
          "required": false,
          "default": "",
          "description": "Comma-separated list of resource dependencies"
        }
      ]
    },
    {
      "key": "lifecycle",
      "title": "Lifecycle",
      "variables": [
        {
          "name": "lifecycle_enabled",
          "type": "bool",
          "title": "Enable lifecycle rules",
          "required": false,
          "default": false,
          "description": "Enable lifecycle rules"
        },
        {
          "name": "prevent_destroy",
          "type": "bool",
          "title": "Prevent resource destruction",
          "required": false,
          "default": false,
          "description": "Prevent resource destruction"
        },
        {
          "name": "create_before_destroy",
          "type": "bool",
          "title": "Create replacement before destroying",
          "required": false,
          "default": false,
          "description": "Create replacement before destroying"
        },
        {
          "name": "ignore_changes",
          "type": "str",
          "title": "Comma-separated list of attributes to ignore changes for",
          "required": false,
          "default": "",
          "description": "Comma-separated list of attributes to ignore changes for"
        }
      ]
    },
    {
      "key": "tags",
      "title": "Tags",
      "variables": [
        {
          "name": "tags_enabled",
          "type": "bool",
          "title": "Enable tags",
          "required": false,
          "default": false,
          "description": "Enable tags"
        },
        {
          "name": "tags_json",
          "type": "str",
          "title": "Tags in JSON format",
          "required": false,
          "default": "{}",
          "description": "Tags in JSON format"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
