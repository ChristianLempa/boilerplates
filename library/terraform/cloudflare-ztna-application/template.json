{
  "version": "1",
  "slug": "cloudflare-ztna-application",
  "kind": "terraform",
  "metadata": {
    "name": "Cloudflare Zero Trust Access Application",
    "description": "Create Cloudflare Zero Trust Access application with policies.\n\nSupports service token authentication and IP-based access policies.\n\nProject: https://www.cloudflare.com/zero-trust/\nDocumentation: https://registry.terraform.io/providers/cloudflare/cloudflare/latest/docs/resources/zero_trust_access_application",
    "tags": [],
    "author": "Christian Lempa",
    "template_version": "5.12.0",
    "date": "2025-11-11",
    "icon": {
      "provider": "simple-icons",
      "id": "cloudflare"
    },
    "draft": false,
    "next_steps": ""
  },
  "entrypoint": {
    "path": "cloudflare_account_zone.tf",
    "type": "file"
  },
  "variables": [
    {
      "key": "application",
      "title": "Application",
      "variables": [
        {
          "name": "app_name",
          "type": "str",
          "title": "Application name",
          "required": false,
          "default": "my_application",
          "description": "Application name"
        },
        {
          "name": "domain",
          "type": "str",
          "title": "Application domain",
          "required": false,
          "default": "app.example.com",
          "description": "Application domain"
        },
        {
          "name": "session_duration",
          "type": "str",
          "title": "Session duration (e.g., 15m, 1h, 24h)",
          "required": false,
          "default": "15m",
          "description": "Session duration (e.g., 15m, 1h, 24h)"
        }
      ]
    },
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "account_id_value",
          "type": "str",
          "title": "Cloudflare Account ID",
          "required": false,
          "description": "Cloudflare Account ID"
        },
        {
          "name": "resource_name",
          "type": "str",
          "title": "Terraform resource name (alphanumeric and underscores only)",
          "required": false,
          "default": "ztna_app",
          "description": "Terraform resource name (alphanumeric and underscores only)"
        },
        {
          "name": "zone_id_value",
          "type": "str",
          "title": "Cloudflare Zone ID",
          "required": false,
          "description": "Cloudflare Zone ID"
        },
        {
          "name": "ip_range",
          "type": "str",
          "title": "Ip Range",
          "required": false,
          "default": ""
        }
      ]
    },
    {
      "key": "ip-policy",
      "title": "IP-Based Policy",
      "variables": [
        {
          "name": "ip_policy_enabled",
          "type": "bool",
          "title": "Enable IP-based policy",
          "required": false,
          "default": false,
          "description": "Enable IP-based policy"
        },
        {
          "name": "ip_policy_name",
          "type": "str",
          "title": "Policy name for IP-based access",
          "required": false,
          "default": "ip_policy",
          "description": "Policy name for IP-based access"
        },
        {
          "name": "ip_ranges",
          "type": "str",
          "title": "Comma-separated list of IP ranges (CIDR notation)",
          "required": false,
          "default": "192.0.2.0/24",
          "description": "Comma-separated list of IP ranges (CIDR notation)"
        }
      ]
    },
    {
      "key": "service-token-policy",
      "title": "Service Token Policy",
      "variables": [
        {
          "name": "service_token_enabled",
          "type": "bool",
          "title": "Enable service token policy",
          "required": false,
          "default": false,
          "description": "Enable service token policy"
        },
        {
          "name": "service_token_id",
          "type": "str",
          "title": "Cloudflare service token ID",
          "required": false,
          "description": "Cloudflare service token ID"
        },
        {
          "name": "service_token_policy_name",
          "type": "str",
          "title": "Policy name for service token",
          "required": false,
          "default": "service_token_policy",
          "description": "Policy name for service token"
        }
      ]
    },
    {
      "key": "depends-on",
      "title": "Dependencies",
      "variables": [
        {
          "name": "depends_on_enabled",
          "type": "bool",
          "title": "Enable resource dependencies",
          "required": false,
          "default": false,
          "description": "Enable resource dependencies"
        },
        {
          "name": "dependencies",
          "type": "str",
          "title": "Comma-separated list of resource dependencies",
          "required": false,
          "default": "",
          "description": "Comma-separated list of resource dependencies"
        }
      ]
    },
    {
      "key": "lifecycle",
      "title": "Lifecycle",
      "variables": [
        {
          "name": "lifecycle_enabled",
          "type": "bool",
          "title": "Enable lifecycle rules",
          "required": false,
          "default": false,
          "description": "Enable lifecycle rules"
        },
        {
          "name": "prevent_destroy",
          "type": "bool",
          "title": "Prevent resource destruction",
          "required": false,
          "default": false,
          "description": "Prevent resource destruction"
        },
        {
          "name": "create_before_destroy",
          "type": "bool",
          "title": "Create replacement before destroying",
          "required": false,
          "default": false,
          "description": "Create replacement before destroying"
        },
        {
          "name": "ignore_changes",
          "type": "str",
          "title": "Comma-separated list of attributes to ignore changes for",
          "required": false,
          "default": "",
          "description": "Comma-separated list of attributes to ignore changes for"
        }
      ]
    },
    {
      "key": "tags",
      "title": "Tags",
      "variables": [
        {
          "name": "tags_enabled",
          "type": "bool",
          "title": "Enable tags",
          "required": false,
          "default": false,
          "description": "Enable tags"
        },
        {
          "name": "tags_json",
          "type": "str",
          "title": "Tags in JSON format",
          "required": false,
          "default": "{}",
          "description": "Tags in JSON format"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
