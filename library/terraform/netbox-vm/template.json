{
  "version": "1",
  "slug": "netbox-vm",
  "kind": "terraform",
  "metadata": {
    "name": "NetBox Virtual Machine",
    "description": "Register a virtual machine in NetBox with cluster and site association.\n\nDefines VM metadata including name, cluster, site, host device, and resource allocation.\n\nProject: https://netboxlabs.com/\nDocumentation: https://registry.terraform.io/providers/e-breuninger/netbox/latest/docs/resources/virtual_machine\n",
    "author": "Christian Lempa",
    "template_version": "5.0.0",
    "icon": {
      "provider": "simple-icons",
      "id": "netbox"
    },
    "date": "2025-12-02"
  },
  "entrypoint": {
    "path": "netbox_virtual_machine.tf",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "resource_name",
          "type": "str",
          "title": "Resource Name",
          "required": false,
          "default": "vm"
        }
      ]
    },
    {
      "key": "vm",
      "title": "Virtual Machine Configuration",
      "variables": [
        {
          "name": "vm_name",
          "type": "str",
          "title": "Virtual machine name",
          "required": true,
          "default": "srv-prod-1",
          "description": "Virtual machine name"
        },
        {
          "name": "cluster_ref",
          "type": "str",
          "title": "Cluster resource name",
          "required": true,
          "default": "pve_prod_1",
          "description": "Cluster resource name"
        },
        {
          "name": "status",
          "type": "str",
          "title": "VM status",
          "required": false,
          "default": "active",
          "description": "VM status",
          "options": [
            "active",
            "planned",
            "staged",
            "offline",
            "decommissioning"
          ]
        }
      ]
    },
    {
      "key": "site",
      "title": "Site Assignment",
      "variables": [
        {
          "name": "site_ref",
          "type": "str",
          "title": "Site data source name (leave empty to skip)",
          "required": false,
          "description": "Site data source name (leave empty to skip)"
        }
      ]
    },
    {
      "key": "device",
      "title": "Host Device",
      "variables": [
        {
          "name": "device_ref",
          "type": "str",
          "title": "Device resource name for host assignment (leave empty to skip)",
          "required": false,
          "description": "Device resource name for host assignment (leave empty to skip)"
        }
      ]
    },
    {
      "key": "ipam",
      "title": "IP Address Management",
      "variables": [
        {
          "name": "ipam_enabled",
          "type": "bool",
          "title": "Enable IP address assignment",
          "required": false,
          "default": false,
          "description": "Enable IP address assignment"
        },
        {
          "name": "interface_name",
          "type": "str",
          "title": "Network interface name",
          "required": true,
          "default": "eth0",
          "description": "Network interface name"
        },
        {
          "name": "primary_ip4",
          "type": "str",
          "title": "Primary IPv4 address resource name",
          "required": true,
          "description": "Primary IPv4 address resource name"
        },
        {
          "name": "dns_name",
          "type": "str",
          "title": "DNS name for the IP address (leave empty to skip)",
          "required": false,
          "description": "DNS name for the IP address (leave empty to skip)"
        }
      ]
    },
    {
      "key": "resources",
      "title": "Resource Allocation",
      "variables": [
        {
          "name": "resources_enabled",
          "type": "bool",
          "title": "Specify resource allocation",
          "required": false,
          "default": false,
          "description": "Specify resource allocation"
        },
        {
          "name": "vcpus",
          "type": "int",
          "title": "Number of virtual CPUs",
          "required": false,
          "default": 2,
          "description": "Number of virtual CPUs"
        },
        {
          "name": "memory_mb",
          "type": "int",
          "title": "Memory allocation in MB",
          "required": false,
          "default": 4096,
          "description": "Memory allocation in MB"
        },
        {
          "name": "disk_gb",
          "type": "int",
          "title": "Disk size in GB",
          "required": false,
          "default": 50,
          "description": "Disk size in GB"
        }
      ]
    },
    {
      "key": "description",
      "title": "Description",
      "variables": [
        {
          "name": "description_enabled",
          "type": "bool",
          "title": "Add VM description",
          "required": false,
          "default": false,
          "description": "Add VM description"
        },
        {
          "name": "description_text",
          "type": "str",
          "title": "VM description",
          "required": false,
          "default": "Managed by Terraform",
          "description": "VM description"
        }
      ]
    },
    {
      "key": "depends-on",
      "title": "Dependencies",
      "variables": [
        {
          "name": "depends_on_enabled",
          "type": "bool",
          "title": "Enable resource dependencies",
          "required": false,
          "default": false,
          "description": "Enable resource dependencies"
        },
        {
          "name": "dependencies",
          "type": "str",
          "title": "Comma-separated list of resource dependencies",
          "required": false,
          "default": "",
          "description": "Comma-separated list of resource dependencies"
        }
      ]
    },
    {
      "key": "lifecycle",
      "title": "Lifecycle",
      "variables": [
        {
          "name": "lifecycle_enabled",
          "type": "bool",
          "title": "Enable lifecycle rules",
          "required": false,
          "default": false,
          "description": "Enable lifecycle rules"
        },
        {
          "name": "prevent_destroy",
          "type": "bool",
          "title": "Prevent resource destruction",
          "required": false,
          "default": false,
          "description": "Prevent resource destruction"
        },
        {
          "name": "create_before_destroy",
          "type": "bool",
          "title": "Create replacement before destroying",
          "required": false,
          "default": false,
          "description": "Create replacement before destroying"
        },
        {
          "name": "ignore_changes",
          "type": "str",
          "title": "Comma-separated list of attributes to ignore changes for",
          "required": false,
          "default": "",
          "description": "Comma-separated list of attributes to ignore changes for"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
