{
  "version": "1",
  "slug": "dns-a-record",
  "kind": "terraform",
  "metadata": {
    "name": "DNS A Record",
    "description": "Create DNS A record for hostname to IP address mapping.\n\nSupports single or multiple IP addresses with configurable TTL.\n\nProject: https://www.terraform.io/\nDocumentation: https://registry.terraform.io/providers/hashicorp/dns/latest/docs/resources/a_record_set",
    "tags": [],
    "author": "Christian Lempa",
    "template_version": "3.4.3",
    "date": "2025-12-02",
    "icon": {
      "provider": "simple-icons",
      "id": "iscbind"
    },
    "draft": false,
    "next_steps": ""
  },
  "entrypoint": {
    "path": "dns_a_record_set.tf",
    "type": "file"
  },
  "variables": [
    {
      "key": "addresses",
      "title": "IP Addresses",
      "variables": [
        {
          "name": "additional_ips",
          "type": "str",
          "title": "Additional IP addresses (comma-separated, e.g., 10.20.0.11,10.20.0.12)",
          "required": false,
          "default": "",
          "description": "Additional IP addresses (comma-separated, e.g., 10.20.0.11,10.20.0.12)",
          "needs": [
            "multiple_addresses=true"
          ]
        },
        {
          "name": "ip_address",
          "type": "str",
          "title": "Primary IP address",
          "required": false,
          "default": "10.20.0.10",
          "description": "Primary IP address"
        },
        {
          "name": "multiple_addresses",
          "type": "bool",
          "title": "Enable multiple IP addresses",
          "required": false,
          "default": false,
          "description": "Enable multiple IP addresses"
        }
      ]
    },
    {
      "key": "dns",
      "title": "DNS Configuration",
      "variables": [
        {
          "name": "record_name",
          "type": "str",
          "title": "Record name (hostname without domain)",
          "required": false,
          "default": "server",
          "description": "Record name (hostname without domain)"
        },
        {
          "name": "ttl",
          "type": "int",
          "title": "Time to live in seconds",
          "required": false,
          "default": 3600,
          "description": "Time to live in seconds"
        },
        {
          "name": "zone",
          "type": "str",
          "title": "DNS zone (must end with a dot)",
          "required": false,
          "default": "home.example.com.",
          "description": "DNS zone (must end with a dot)"
        }
      ]
    },
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "resource_name",
          "type": "str",
          "title": "Resource Name",
          "required": false,
          "default": "record"
        },
        {
          "name": "ip",
          "type": "str",
          "title": "Ip",
          "required": false,
          "default": ""
        }
      ]
    },
    {
      "key": "depends-on",
      "title": "Dependencies",
      "variables": [
        {
          "name": "depends_on_enabled",
          "type": "bool",
          "title": "Enable resource dependencies",
          "required": false,
          "default": false,
          "description": "Enable resource dependencies"
        },
        {
          "name": "dependencies",
          "type": "str",
          "title": "Comma-separated list of resource dependencies",
          "required": false,
          "default": "",
          "description": "Comma-separated list of resource dependencies"
        }
      ]
    },
    {
      "key": "lifecycle",
      "title": "Lifecycle",
      "variables": [
        {
          "name": "lifecycle_enabled",
          "type": "bool",
          "title": "Enable lifecycle rules",
          "required": false,
          "default": false,
          "description": "Enable lifecycle rules"
        },
        {
          "name": "prevent_destroy",
          "type": "bool",
          "title": "Prevent resource destruction",
          "required": false,
          "default": false,
          "description": "Prevent resource destruction"
        },
        {
          "name": "create_before_destroy",
          "type": "bool",
          "title": "Create replacement before destroying",
          "required": false,
          "default": false,
          "description": "Create replacement before destroying"
        },
        {
          "name": "ignore_changes",
          "type": "str",
          "title": "Comma-separated list of attributes to ignore changes for",
          "required": false,
          "default": "",
          "description": "Comma-separated list of attributes to ignore changes for"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
