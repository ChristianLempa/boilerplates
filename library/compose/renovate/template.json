{
  "version": "1",
  "slug": "renovate",
  "kind": "compose",
  "metadata": {
    "name": "Renovate",
    "description": "**Renovate** is an automated dependency update tool that creates pull requests for newer versions of dependencies.\nSupports GitHub, GitLab, Bitbucket, Gitea, and more platforms with flexible configuration options.\n\n## Use Cases\n- Automated dependency updates for all your repositories\n- Security vulnerability patching\n- Multi-platform support (GitLab, GitHub, Bitbucket, etc.)\n- Customizable update schedules and rules\n- Self-hosted or cloud-based deployment\n\n## Resources\n- **Project**: https://www.mend.io/renovate/\n- **Documentation**: https://docs.renovatebot.com/\n- **GitHub**: https://github.com/renovatebot/renovate",
    "tags": [
      "traefik",
      "swarm"
    ],
    "author": "Christian Lempa",
    "template_version": "13.6.0-full",
    "icon": {
      "provider": "simple-icons",
      "id": "renovate"
    },
    "date": "2026-02-13",
    "draft": true
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "renovate"
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": false,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        },
        {
          "name": "container_name",
          "type": "str",
          "title": "Container Name",
          "required": false,
          "default": "renovate"
        },
        {
          "name": "container_hostname",
          "type": "str",
          "title": "Container Hostname",
          "required": false,
          "default": "renovate"
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false,
          "default": "UTC"
        },
        {
          "name": "container_loglevel",
          "type": "str",
          "title": "Container Loglevel",
          "required": false,
          "options": [
            "debug",
            "info",
            "warn",
            "error"
          ]
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik Tls Certresolver",
          "required": false,
          "default": ""
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "Traefik Tls Entrypoint",
          "required": false,
          "default": ""
        }
      ]
    },
    {
      "key": "renovate-settings",
      "title": "Renovate Settings",
      "variables": [
        {
          "name": "renovate_platform",
          "type": "str",
          "title": "Git Platform Type",
          "required": false,
          "default": "gitlab",
          "description": "Git Platform Type",
          "options": [
            "gitlab",
            "github",
            "gitea"
          ]
        },
        {
          "name": "renovate_endpoint",
          "type": "str",
          "title": "Git Platform Endpoint URL",
          "required": false,
          "default": "https://gitlab.com",
          "description": "Git Platform Endpoint URL"
        },
        {
          "name": "renovate_autodiscover",
          "type": "bool",
          "title": "Auto-discover repositories",
          "required": false,
          "default": false,
          "description": "Auto-discover repositories"
        }
      ]
    },
    {
      "key": "authentication",
      "title": "Authentication",
      "variables": [
        {
          "name": "git_token",
          "type": "str",
          "title": "Git platform Personal Access Token",
          "required": false,
          "description": "Git platform Personal Access Token",
          "sensitive": true
        },
        {
          "name": "license_key",
          "type": "str",
          "title": "Mend Renovate CE License Key",
          "required": false,
          "description": "Mend Renovate CE License Key",
          "sensitive": true
        },
        {
          "name": "webhook_secret",
          "type": "str",
          "title": "Webhook secret for platform integration",
          "required": false,
          "default": "renovate",
          "description": "Webhook secret for platform integration",
          "sensitive": true
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_http",
          "type": "int",
          "title": "External HTTP port for web interface",
          "required": false,
          "default": 8080,
          "description": "External HTTP port for web interface"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Traefik Enabled",
          "required": false,
          "default": false
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik Network",
          "required": false,
          "default": "traefik"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "renovate"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik Domain",
          "required": false,
          "default": "home.arpa"
        },
        {
          "name": "traefik_entrypoint",
          "type": "bool",
          "title": "Traefik Entrypoint",
          "required": false,
          "default": "web"
        }
      ]
    },
    {
      "key": "network",
      "title": "Network",
      "variables": [
        {
          "name": "network_mode",
          "type": "str",
          "title": "Network Mode",
          "required": false,
          "default": "bridge",
          "options": [
            "bridge",
            "host",
            "macvlan"
          ]
        },
        {
          "name": "network_name",
          "type": "str",
          "title": "Network Name",
          "required": false,
          "default": "bridge"
        }
      ]
    },
    {
      "key": "swarm",
      "title": "Swarm",
      "variables": [
        {
          "name": "swarm_enabled",
          "type": "bool",
          "title": "Swarm Enabled",
          "required": false,
          "default": false
        },
        {
          "name": "swarm_placement_mode",
          "type": "str",
          "title": "Swarm Placement Mode",
          "required": false,
          "default": "replicated",
          "options": [
            "replicated",
            "global"
          ]
        },
        {
          "name": "swarm_replicas",
          "type": "int",
          "title": "Swarm Replicas",
          "required": false,
          "default": 1,
          "needs": [
            "swarm_placement_mode=replicated"
          ]
        },
        {
          "name": "swarm_placement_host",
          "type": "str",
          "title": "Swarm Placement Host",
          "required": false,
          "default": "",
          "needs": [
            "swarm_placement_mode=replicated"
          ]
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
