{
  "version": "1",
  "slug": "pihole",
  "kind": "compose",
  "metadata": {
    "name": "Pihole",
    "description": "Network-wide advertisement and internet tracker blocking application that functions as a DNS blackhole.\nProvides DNS-level content filtering for all network devices, improving browsing performance, privacy, and security.\nSupports custom blocklists, whitelists, and seamless integration with existing network infrastructure.\n## Prerequisites\n- :warning: Pi-hole uses local storage and configuration files and does NOT support running multiple replicas.\nThis template enforces a single replica with node placement constraints to ensure stable DNS resolution.\n## References\n- **Project:** https://pi-hole.net/\n- **Documentation:** https://docs.pi-hole.net/\n- **GitHub:** https://github.com/pi-hole/pi-hole\n",
    "tags": [
      "traefik",
      "swarm",
      "network",
      "volume"
    ],
    "author": "Christian Lempa",
    "template_version": "2025.11.1",
    "icon": {
      "provider": "simple-icons",
      "id": "pihole"
    },
    "date": "2025-12-11",
    "next_steps": "Log in with your initial admin user:\n```bash\nUsername: admin\nPassword: {{ webpassword }}\n```"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "pihole"
        },
        {
          "name": "container_name",
          "type": "str",
          "title": "Container Name",
          "required": false,
          "default": "pihole"
        },
        {
          "name": "container_hostname",
          "type": "str",
          "title": "Container Hostname",
          "required": false
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false
        },
        {
          "name": "user_uid",
          "type": "int",
          "title": "User Uid",
          "required": false,
          "default": 1000
        },
        {
          "name": "user_gid",
          "type": "int",
          "title": "User Gid",
          "required": false,
          "default": 1000
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        }
      ]
    },
    {
      "key": "admin-settings",
      "title": "Admin Settings",
      "variables": [
        {
          "name": "webpassword",
          "type": "str",
          "title": "Web interface admin password",
          "required": false,
          "description": "Web interface admin password",
          "sensitive": true,
          "autogenerated": true
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_dns",
          "type": "int",
          "title": "DNS port for Pi-hole",
          "required": true,
          "default": 53,
          "description": "DNS port for Pi-hole"
        },
        {
          "name": "ports_http",
          "type": "int",
          "title": "HTTP port for Pi-hole",
          "required": false,
          "default": 80,
          "description": "HTTP port for Pi-hole"
        },
        {
          "name": "ports_https",
          "type": "int",
          "title": "HTTPS port for Pi-hole",
          "required": false,
          "default": 443,
          "description": "HTTPS port for Pi-hole"
        },
        {
          "name": "ports_ntp",
          "type": "int",
          "title": "External NTP port",
          "required": true,
          "default": 123,
          "description": "External NTP port"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "pihole"
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik Network",
          "required": true,
          "default": "traefik"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik Domain",
          "required": true,
          "default": "home.arpa"
        },
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        }
      ]
    },
    {
      "key": "traefik-tls",
      "title": "Traefik TLS",
      "variables": [
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik Tls Certresolver",
          "required": true,
          "default": "cloudflare"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable Traefik TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        }
      ]
    },
    {
      "key": "network",
      "title": "Network",
      "variables": [
        {
          "name": "network_mode",
          "type": "str",
          "title": "Network Mode",
          "required": false
        },
        {
          "name": "network_name",
          "type": "str",
          "title": "Network Name",
          "required": false,
          "default": "pihole_network"
        },
        {
          "name": "network_macvlan_ipv4_address",
          "type": "str",
          "title": "Network Macvlan Ipv4 Address",
          "required": true,
          "default": "192.168.1.253",
          "needs": [
            "network_mode=macvlan"
          ]
        },
        {
          "name": "network_macvlan_parent_interface",
          "type": "str",
          "title": "Network Macvlan Parent Interface",
          "required": true,
          "default": "eth0",
          "needs": [
            "network_mode=macvlan"
          ]
        },
        {
          "name": "network_macvlan_subnet",
          "type": "str",
          "title": "Network Macvlan Subnet",
          "required": true,
          "default": "192.168.1.0/24",
          "needs": [
            "network_mode=macvlan"
          ]
        },
        {
          "name": "network_macvlan_gateway",
          "type": "str",
          "title": "Network Macvlan Gateway",
          "required": true,
          "default": "192.168.1.1",
          "needs": [
            "network_mode=macvlan"
          ]
        },
        {
          "name": "network_external",
          "type": "bool",
          "title": "Whether the network is external",
          "required": false,
          "default": false,
          "description": "Whether the network is external"
        }
      ]
    },
    {
      "key": "swarm",
      "title": "Docker Swarm",
      "variables": [
        {
          "name": "swarm_placement_host",
          "type": "str",
          "title": "Swarm Placement Host",
          "required": true,
          "needs": null
        },
        {
          "name": "swarm_replicas",
          "type": "int",
          "title": "Number of replicas for Swarm mode",
          "required": false,
          "default": 1,
          "description": "Number of replicas for Swarm mode"
        },
        {
          "name": "swarm_enabled",
          "type": "bool",
          "title": "Enable Docker Swarm mode",
          "required": false,
          "default": false,
          "description": "Enable Docker Swarm mode"
        },
        {
          "name": "swarm_placement_mode",
          "type": "str",
          "title": "The placement mode",
          "required": false,
          "default": "replicated",
          "description": "The placement mode"
        }
      ]
    },
    {
      "key": "volume",
      "title": "Volume",
      "variables": [
        {
          "name": "volume_mode",
          "type": "str",
          "title": "Volume Mode",
          "required": true,
          "default": "local",
          "options": [
            "local",
            "mount",
            "nfs"
          ]
        },
        {
          "name": "volume_mount_path",
          "type": "str",
          "title": "Volume Mount Path",
          "required": true,
          "default": "/mnt/storage",
          "needs": [
            "volume_mode=mount"
          ]
        },
        {
          "name": "volume_nfs_server",
          "type": "str",
          "title": "Volume Nfs Server",
          "required": true,
          "default": "192.168.1.1",
          "needs": [
            "volume_mode=nfs"
          ]
        },
        {
          "name": "volume_nfs_path",
          "type": "str",
          "title": "Volume Nfs Path",
          "required": true,
          "default": "/export",
          "needs": [
            "volume_mode=nfs"
          ]
        },
        {
          "name": "volume_nfs_options",
          "type": "str",
          "title": "Volume Nfs Options",
          "required": true,
          "default": "rw,nolock,soft",
          "needs": [
            "volume_mode=nfs"
          ]
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
