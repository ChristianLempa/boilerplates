{
  "version": "1",
  "slug": "pihole",
  "kind": "compose",
  "metadata": {
    "name": "Pihole",
    "description": "Network-wide advertisement and internet tracker blocking application that functions as a DNS blackhole.\nProvides DNS-level content filtering for all network devices, improving browsing performance, privacy, and security.\nSupports custom blocklists, whitelists, and seamless integration with existing network infrastructure.\n## Prerequisites\n- :warning: Pi-hole uses local storage and configuration files and does NOT support running multiple replicas.\nThis template enforces a single replica with node placement constraints to ensure stable DNS resolution.\n## References\n- **Project:** https://pi-hole.net/\n- **Documentation:** https://docs.pi-hole.net/\n- **GitHub:** https://github.com/pi-hole/pi-hole\n",
    "tags": [
      "traefik",
      "swarm",
      "network",
      "volume"
    ],
    "author": "Christian Lempa",
    "template_version": "2025.11.1",
    "icon": {
      "provider": "selfh",
      "id": "pi-hole"
    },
    "date": "2025-12-11",
    "next_steps": "Log in with your initial admin user:\n```bash\nUsername: admin\nPassword: {{ webpassword }}\n```"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "service_name",
      "type": "string",
      "label": "Service Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "pihole"
    },
    {
      "key": "container_name",
      "type": "string",
      "label": "Container Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "pihole"
    },
    {
      "key": "container_hostname",
      "type": "string",
      "label": "Container Hostname",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str"
    },
    {
      "key": "container_timezone",
      "type": "string",
      "label": "Container Timezone",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str"
    },
    {
      "key": "user_uid",
      "type": "number",
      "label": "User Uid",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "int",
      "default": 1000
    },
    {
      "key": "user_gid",
      "type": "number",
      "label": "User Gid",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "int",
      "default": 1000
    },
    {
      "key": "restart_policy",
      "type": "string",
      "label": "Restart Policy",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "enum",
      "default": "unless-stopped",
      "options": [
        "unless-stopped",
        "always",
        "on-failure",
        "no"
      ]
    },
    {
      "key": "webpassword",
      "type": "string",
      "label": "Web interface admin password",
      "required": false,
      "section": {
        "key": "admin_settings",
        "required": true,
        "description": "Admin Pi-hole Settings"
      },
      "source_type": "str",
      "description": "Web interface admin password",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "ports_dns",
      "type": "number",
      "label": "DNS port for Pi-hole",
      "required": true,
      "section": {
        "key": "ports"
      },
      "source_type": "int",
      "default": 53,
      "description": "DNS port for Pi-hole"
    },
    {
      "key": "ports_http",
      "type": "number",
      "label": "HTTP port for Pi-hole",
      "required": false,
      "section": {
        "key": "ports"
      },
      "source_type": "int",
      "default": 80,
      "description": "HTTP port for Pi-hole"
    },
    {
      "key": "ports_https",
      "type": "number",
      "label": "HTTPS port for Pi-hole",
      "required": false,
      "section": {
        "key": "ports"
      },
      "source_type": "int",
      "default": 443,
      "description": "HTTPS port for Pi-hole"
    },
    {
      "key": "ports_ntp",
      "type": "number",
      "label": "External NTP port",
      "required": true,
      "section": {
        "key": "ports"
      },
      "source_type": "int",
      "default": 123,
      "description": "External NTP port"
    },
    {
      "key": "traefik_host",
      "type": "string",
      "label": "Traefik Host",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "pihole"
    },
    {
      "key": "traefik_network",
      "type": "string",
      "label": "Traefik Network",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "traefik"
    },
    {
      "key": "traefik_domain",
      "type": "string",
      "label": "Traefik Domain",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "home.arpa"
    },
    {
      "key": "traefik_enabled",
      "type": "boolean",
      "label": "Enable Traefik integration",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik integration"
    },
    {
      "key": "traefik_tls_certresolver",
      "type": "string",
      "label": "Traefik Tls Certresolver",
      "required": true,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "str",
      "default": "cloudflare"
    },
    {
      "key": "traefik_tls_enabled",
      "type": "boolean",
      "label": "Enable Traefik TLS",
      "required": false,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik TLS"
    },
    {
      "key": "network_mode",
      "type": "string",
      "label": "Network Mode",
      "required": false,
      "section": {
        "key": "network"
      },
      "source_type": "str",
      "extra": "If you need DHCP functionality, use 'host' or 'macvlan' mode. NOTE: Swarm only supports 'bridge' mode!\"\n"
    },
    {
      "key": "network_name",
      "type": "string",
      "label": "Network Name",
      "required": false,
      "section": {
        "key": "network"
      },
      "source_type": "str",
      "default": "pihole_network"
    },
    {
      "key": "network_macvlan_ipv4_address",
      "type": "string",
      "label": "Network Macvlan Ipv4 Address",
      "required": true,
      "section": {
        "key": "network"
      },
      "source_type": "str",
      "default": "192.168.1.253",
      "needs": [
        "network_mode=macvlan"
      ]
    },
    {
      "key": "network_macvlan_parent_interface",
      "type": "string",
      "label": "Network Macvlan Parent Interface",
      "required": true,
      "section": {
        "key": "network"
      },
      "source_type": "str",
      "default": "eth0",
      "needs": [
        "network_mode=macvlan"
      ]
    },
    {
      "key": "network_macvlan_subnet",
      "type": "string",
      "label": "Network Macvlan Subnet",
      "required": true,
      "section": {
        "key": "network"
      },
      "source_type": "str",
      "default": "192.168.1.0/24",
      "needs": [
        "network_mode=macvlan"
      ]
    },
    {
      "key": "network_macvlan_gateway",
      "type": "string",
      "label": "Network Macvlan Gateway",
      "required": true,
      "section": {
        "key": "network"
      },
      "source_type": "str",
      "default": "192.168.1.1",
      "needs": [
        "network_mode=macvlan"
      ]
    },
    {
      "key": "network_external",
      "type": "boolean",
      "label": "Whether the network is external",
      "required": false,
      "section": {
        "key": "network"
      },
      "source_type": "bool",
      "default": false,
      "description": "Whether the network is external"
    },
    {
      "key": "swarm_placement_host",
      "type": "string",
      "label": "Swarm Placement Host",
      "required": true,
      "section": {
        "key": "swarm",
        "title": "Docker Swarm",
        "toggle": "swarm_enabled",
        "description": "Configure Docker Swarm mode deployment"
      },
      "source_type": "str",
      "needs": null
    },
    {
      "key": "swarm_replicas",
      "type": "number",
      "label": "Number of replicas for Swarm mode",
      "required": false,
      "section": {
        "key": "swarm",
        "title": "Docker Swarm",
        "toggle": "swarm_enabled",
        "description": "Configure Docker Swarm mode deployment"
      },
      "source_type": "int",
      "default": 1,
      "description": "Number of replicas for Swarm mode"
    },
    {
      "key": "swarm_enabled",
      "type": "boolean",
      "label": "Enable Docker Swarm mode",
      "required": false,
      "section": {
        "key": "swarm",
        "title": "Docker Swarm",
        "toggle": "swarm_enabled",
        "description": "Configure Docker Swarm mode deployment"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Docker Swarm mode"
    },
    {
      "key": "swarm_placement_mode",
      "type": "string",
      "label": "The placement mode",
      "required": false,
      "section": {
        "key": "swarm",
        "title": "Docker Swarm",
        "toggle": "swarm_enabled",
        "description": "Configure Docker Swarm mode deployment"
      },
      "source_type": "str",
      "default": "replicated",
      "description": "The placement mode"
    },
    {
      "key": "volume_mode",
      "type": "string",
      "label": "Volume Mode",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "enum",
      "default": "local",
      "options": [
        "local",
        "mount",
        "nfs"
      ]
    },
    {
      "key": "volume_mount_path",
      "type": "string",
      "label": "Volume Mount Path",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "str",
      "default": "/mnt/storage",
      "needs": [
        "volume_mode=mount"
      ]
    },
    {
      "key": "volume_nfs_server",
      "type": "string",
      "label": "Volume Nfs Server",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "str",
      "default": "192.168.1.1",
      "needs": [
        "volume_mode=nfs"
      ]
    },
    {
      "key": "volume_nfs_path",
      "type": "string",
      "label": "Volume Nfs Path",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "str",
      "default": "/export",
      "needs": [
        "volume_mode=nfs"
      ]
    },
    {
      "key": "volume_nfs_options",
      "type": "string",
      "label": "Volume Nfs Options",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "str",
      "default": "rw,nolock,soft",
      "needs": [
        "volume_mode=nfs"
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
