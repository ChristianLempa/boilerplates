{
  "version": "1",
  "slug": "traefik",
  "kind": "compose",
  "metadata": {
    "name": "Traefik",
    "description": "Traefik is a modern HTTP reverse proxy and load balancer that makes deploying microservices easy.",
    "tags": [
      "traefik",
      "reverse-proxy",
      "load-balancer",
      "http",
      "https",
      "acme",
      "letsencrypt"
    ],
    "author": "Christian Lempa",
    "template_version": "v3.6.8",
    "date": "2026-02-11",
    "icon": {
      "provider": "simple-icons",
      "id": "traefikproxy",
      "color": "blue"
    },
    "next_steps": "Start the `{{ service_name }}` project\n1. Copy the project directory for `{{ service_name }}` to the host.\n2. Start Traefik with Docker Compose from the project directory:\n  `docker compose up -d`"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": true,
          "default": "UTC"
        },
        {
          "name": "container_loglevel",
          "type": "enum",
          "title": "Container Loglevel",
          "required": false,
          "options": [
            "debug",
            "info",
            "warn",
            "error"
          ]
        },
        {
          "name": "restart_policy",
          "type": "enum",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_dashboard",
          "type": "int",
          "title": "Dashboard port (external)",
          "required": true,
          "default": 8080,
          "description": "Dashboard port (external)",
          "needs": [
            "dashboard_enabled=true"
          ]
        },
        {
          "name": "ports_http",
          "type": "str",
          "title": "Ports Http",
          "required": false,
          "default": 80
        },
        {
          "name": "ports_https",
          "type": "str",
          "title": "Ports Https",
          "required": false,
          "default": 443
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Settings",
      "variables": [
        {
          "name": "accesslog_enabled",
          "type": "bool",
          "title": "Enable Traefik access log",
          "required": false,
          "default": false,
          "description": "Enable Traefik access log"
        },
        {
          "name": "dashboard_enabled",
          "type": "bool",
          "title": "Enable Traefik dashboard",
          "required": false,
          "default": false,
          "description": "Enable Traefik dashboard"
        },
        {
          "name": "prometheus_enabled",
          "type": "bool",
          "title": "Enable Prometheus metrics",
          "required": false,
          "default": false,
          "description": "Enable Prometheus metrics"
        },
        {
          "name": "security_enabled",
          "type": "bool",
          "title": "Create production-ready security headers middleware",
          "required": false,
          "default": true,
          "description": "Create production-ready security headers middleware"
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik Network",
          "required": false
        },
        {
          "name": "traefik_network_external",
          "type": "bool",
          "title": "Use existing Docker network (external)",
          "required": false,
          "default": false,
          "description": "Use existing Docker network (external)"
        }
      ]
    },
    {
      "key": "traefik-tls",
      "title": "TLS Settings",
      "variables": [
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable HTTPS/TLS with ACME",
          "required": false,
          "default": false,
          "description": "Enable HTTPS/TLS with ACME"
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "enum",
          "title": "ACME DNS challenge provider",
          "required": true,
          "default": "cloudflare",
          "description": "ACME DNS challenge provider",
          "options": [
            "cloudflare",
            "porkbun",
            "godaddy",
            "digitalocean",
            "route53",
            "azure",
            "namecheap",
            "ovh"
          ],
          "needs": [
            "traefik_tls_enabled=true"
          ]
        },
        {
          "name": "traefik_tls_acme_email",
          "type": "str",
          "title": "Email address for ACME",
          "required": true,
          "description": "Email address for ACME",
          "needs": [
            "traefik_tls_enabled=true"
          ]
        },
        {
          "name": "traefik_tls_acme_endpoint",
          "type": "str",
          "title": "OVH API endpoint",
          "required": false,
          "default": "ovh-eu",
          "description": "OVH API endpoint",
          "needs": [
            "traefik_tls_enabled=true",
            "traefik_tls_certresolver=ovh"
          ]
        },
        {
          "name": "traefik_tls_acme_region",
          "type": "str",
          "title": "AWS Region",
          "required": true,
          "default": "us-east-1",
          "description": "AWS Region",
          "needs": [
            "traefik_tls_enabled=true",
            "traefik_tls_certresolver=route53"
          ]
        },
        {
          "name": "traefik_tls_acme_resource_group",
          "type": "str",
          "title": "Azure Resource Group",
          "required": true,
          "description": "Azure Resource Group",
          "needs": [
            "traefik_tls_enabled=true",
            "traefik_tls_certresolver=azure"
          ]
        },
        {
          "name": "traefik_tls_acme_secret_key",
          "type": "secret",
          "title": "DNS provider secret key",
          "required": true,
          "description": "DNS provider secret key",
          "needs": [
            "traefik_tls_enabled=true",
            "traefik_tls_certresolver=azure,godaddy,ovh,porkbun,route53"
          ]
        },
        {
          "name": "traefik_tls_acme_subscription_id",
          "type": "str",
          "title": "Azure Subscription ID",
          "required": true,
          "description": "Azure Subscription ID",
          "needs": [
            "traefik_tls_enabled=true",
            "traefik_tls_certresolver=azure"
          ]
        },
        {
          "name": "traefik_tls_acme_tenant_id",
          "type": "str",
          "title": "Azure Tenant ID",
          "required": true,
          "description": "Azure Tenant ID",
          "needs": [
            "traefik_tls_enabled=true",
            "traefik_tls_certresolver=azure"
          ]
        },
        {
          "name": "traefik_tls_acme_token",
          "type": "secret",
          "title": "DNS provider API token",
          "required": true,
          "description": "DNS provider API token",
          "needs": [
            "traefik_tls_enabled=true",
            "traefik_tls_certresolver=cloudflare,digitalocean,godaddy,namecheap,ovh,porkbun"
          ]
        },
        {
          "name": "traefik_tls_acme_username",
          "type": "str",
          "title": "Namecheap API username",
          "required": true,
          "description": "Namecheap API username",
          "needs": [
            "traefik_tls_enabled=true",
            "traefik_tls_certresolver=namecheap"
          ]
        },
        {
          "name": "traefik_tls_acme_consumer_key",
          "type": "secret",
          "title": "OVH Consumer Key",
          "required": true,
          "description": "OVH Consumer Key",
          "needs": [
            "traefik_tls_enabled=true",
            "traefik_tls_certresolver=ovh"
          ]
        },
        {
          "name": "traefik_tls_redirect",
          "type": "bool",
          "title": "Redirect all HTTP traffic to HTTPS",
          "required": false,
          "default": true,
          "description": "Redirect all HTTP traffic to HTTPS",
          "needs": [
            "traefik_tls_enabled=true"
          ]
        },
        {
          "name": "traefik_tls_secure_ciphers",
          "type": "bool",
          "title": "Enable strict cipher suites (recommended)",
          "required": false,
          "default": false,
          "description": "Enable strict cipher suites (recommended)",
          "needs": [
            "traefik_tls_enabled=true"
          ]
        },
        {
          "name": "traefik_tls_skipverify",
          "type": "bool",
          "title": "Skip TLS verification for backend servers",
          "required": false,
          "default": false,
          "description": "Skip TLS verification for backend servers",
          "needs": [
            "traefik_tls_enabled=true"
          ]
        }
      ]
    },
    {
      "key": "volume",
      "title": "Volume",
      "variables": [
        {
          "name": "volume_mode",
          "type": "enum",
          "title": "Volume Mode",
          "required": true,
          "default": "local",
          "options": [
            "local",
            "mount",
            "nfs"
          ]
        },
        {
          "name": "volume_mount_path",
          "type": "str",
          "title": "Volume Mount Path",
          "required": true,
          "default": "/mnt/storage",
          "needs": [
            "volume_mode=mount"
          ]
        },
        {
          "name": "volume_nfs_server",
          "type": "str",
          "title": "Volume Nfs Server",
          "required": true,
          "default": "192.168.1.1",
          "needs": [
            "volume_mode=nfs"
          ]
        },
        {
          "name": "volume_nfs_path",
          "type": "str",
          "title": "Volume Nfs Path",
          "required": true,
          "default": "/export",
          "needs": [
            "volume_mode=nfs"
          ]
        },
        {
          "name": "volume_nfs_options",
          "type": "str",
          "title": "Volume Nfs Options",
          "required": true,
          "default": "rw,nolock,soft",
          "needs": [
            "volume_mode=nfs"
          ]
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
