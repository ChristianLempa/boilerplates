{
  "version": "1",
  "slug": "homer",
  "kind": "compose",
  "metadata": {
    "name": "Homer",
    "description": "A very simple static homepage for your server to keep your services on hand, from a simple yaml configuration file.\n\nProject: https://github.com/bastienwirtz/homer\nDocumentation: https://github.com/bastienwirtz/homer/blob/main/docs/configuration.md\n",
    "tags": [
      "traefik",
      "swarm",
      "authentik"
    ],
    "author": "Christian Lempa",
    "template_version": "v25.11.1",
    "icon": {
      "provider": "mdi",
      "id": "view-dashboard-outline"
    },
    "date": "2025-12-11",
    "draft": true,
    "next_steps": "1. Start the Homer dashboard:\n   docker compose up -d\n\n2. Customize your dashboard:\n   - Edit assets/config.yml to add your services\n   - Organize services into groups (Applications, Monitoring, etc.)\n   - Add links to the navbar for quick access\n\n3. Optional: Add a logo:\n   - Place your logo.png file in the assets/ directory\n   - Or update the logo path in assets/config.yml\n   - Supported formats: PNG, SVG, JPG\n\n4. Optional: Customize the theme:\n   - Uncomment and modify the colors section in config.yml\n   - Available themes: default, sui\n   - See documentation for advanced theming options\n\n5. Access your dashboard:\n   {% if traefik_enabled -%}\n   - Via Traefik: https://{{ traefik_host }}\n   {% if not traefik_enabled and network_mode == 'bridge' %}- Direct access: http://localhost:{{ ports_http }}{% endif %}\n   {%- else -%}\n   - Open http://localhost:{{ ports_http }} in your browser\n   {%- endif %}\n\nFor more information, visit: https://github.com/bastienwirtz/homer/blob/main/docs/configuration.md\n"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "homer"
        },
        {
          "name": "container_name",
          "type": "str",
          "title": "Container Name",
          "required": false,
          "default": "homer"
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        },
        {
          "name": "homer_title",
          "type": "str",
          "title": "Dashboard title",
          "required": false,
          "default": "My Dashboard",
          "description": "Dashboard title"
        },
        {
          "name": "homer_subtitle",
          "type": "str",
          "title": "Dashboard subtitle",
          "required": false,
          "default": "Homer",
          "description": "Dashboard subtitle"
        },
        {
          "name": "homer_logo",
          "type": "str",
          "title": "Logo file path (relative to assets/)",
          "required": false,
          "default": "logo.png",
          "description": "Logo file path (relative to assets/)"
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_http",
          "type": "int",
          "title": "Host port for HTTP (8080)",
          "required": false,
          "default": 8080,
          "description": "Host port for HTTP (8080)"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_entrypoint",
          "type": "str",
          "title": "The Traefik entrypoint",
          "required": true,
          "default": "web",
          "description": "The Traefik entrypoint"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "homepage"
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik Network",
          "required": true,
          "default": "traefik"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik Domain",
          "required": true,
          "default": "home.arpa"
        }
      ]
    },
    {
      "key": "traefik-tls",
      "title": "Traefik Tls",
      "variables": [
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable Traefik TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "The Traefik TLS entrypoint",
          "required": true,
          "default": "websecure",
          "description": "The Traefik TLS entrypoint"
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik Tls Certresolver",
          "required": true,
          "default": "cloudflare"
        }
      ]
    },
    {
      "key": "swarm",
      "title": "Docker Swarm",
      "variables": [
        {
          "name": "swarm_placement_mode",
          "type": "str",
          "title": "Swarm Placement Mode",
          "required": true,
          "default": "replicated",
          "options": [
            "replicated",
            "global"
          ]
        },
        {
          "name": "swarm_replicas",
          "type": "int",
          "title": "Swarm Replicas",
          "required": true,
          "default": 1,
          "needs": [
            "swarm_placement_mode=replicated"
          ]
        },
        {
          "name": "swarm_placement_host",
          "type": "str",
          "title": "Swarm Placement Host",
          "required": false,
          "default": "",
          "needs": [
            "swarm_placement_mode=replicated"
          ]
        },
        {
          "name": "swarm_enabled",
          "type": "bool",
          "title": "Enable Docker Swarm mode",
          "required": false,
          "default": false,
          "description": "Enable Docker Swarm mode"
        }
      ]
    },
    {
      "key": "authentik",
      "title": "Authentik SSO",
      "variables": [
        {
          "name": "authentik_traefik_middleware",
          "type": "str",
          "title": "Authentik Traefik Middleware",
          "required": true,
          "default": "authentik-middleware@file",
          "needs": [
            "traefik_enabled=true"
          ]
        },
        {
          "name": "authentik_client_id",
          "type": "str",
          "title": "The Authentik client ID",
          "required": false,
          "default": "",
          "description": "The Authentik client ID"
        },
        {
          "name": "authentik_client_secret",
          "type": "str",
          "title": "The Authentik client secret",
          "required": false,
          "default": "",
          "description": "The Authentik client secret"
        },
        {
          "name": "authentik_enabled",
          "type": "bool",
          "title": "Enable Authentik SSO integration",
          "required": false,
          "default": false,
          "description": "Enable Authentik SSO integration"
        },
        {
          "name": "authentik_slug",
          "type": "str",
          "title": "The Authentik application slug",
          "required": false,
          "default": "",
          "description": "The Authentik application slug"
        },
        {
          "name": "authentik_url",
          "type": "str",
          "title": "The Authentik URL",
          "required": false,
          "default": "",
          "description": "The Authentik URL"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
