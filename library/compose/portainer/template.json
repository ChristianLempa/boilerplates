{
  "version": "1",
  "slug": "portainer",
  "kind": "compose",
  "metadata": {
    "name": "Portainer",
    "description": "Portainer is a powerful and user-friendly management tool for Docker and Kubernetes environments.\nIt provides a simple web-based interface to manage containers, images, networks, and volumes,\nmaking it easier to deploy and monitor applications.\n## References\n- **Project:** https://www.portainer.io/\n- **Documentation:** https://docs.portainer.io/\n- **GitHub:** https://github.com/portainer/portainer",
    "tags": [
      "traefik",
      "swarm",
      "volumes"
    ],
    "author": "Christian Lempa",
    "template_version": "2.38.1-alpine",
    "icon": {
      "provider": "selfh",
      "id": "portainer"
    },
    "date": "2026-02-12"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "service_name",
      "type": "string",
      "label": "Service Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "portainer"
    },
    {
      "key": "container_timezone",
      "type": "string",
      "label": "Container Timezone",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str"
    },
    {
      "key": "restart_policy",
      "type": "string",
      "label": "Restart Policy",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "enum",
      "default": "unless-stopped",
      "options": [
        "unless-stopped",
        "always",
        "on-failure",
        "no"
      ]
    },
    {
      "key": "ports_http",
      "type": "string",
      "label": "Ports Http",
      "required": false,
      "section": {
        "key": "ports"
      },
      "source_type": "str",
      "default": 9000
    },
    {
      "key": "ports_https",
      "type": "string",
      "label": "Ports Https",
      "required": false,
      "section": {
        "key": "ports"
      },
      "source_type": "str",
      "default": 9443
    },
    {
      "key": "ports_edge",
      "type": "number",
      "label": "Host port for Edge agent (8000)",
      "required": true,
      "section": {
        "key": "ports"
      },
      "source_type": "int",
      "default": 8000,
      "description": "Host port for Edge agent (8000)"
    },
    {
      "key": "traefik_host",
      "type": "string",
      "label": "Traefik Host",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "portainer"
    },
    {
      "key": "traefik_network",
      "type": "string",
      "label": "Traefik Network",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "traefik"
    },
    {
      "key": "traefik_domain",
      "type": "string",
      "label": "Traefik Domain",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "home.arpa"
    },
    {
      "key": "traefik_enabled",
      "type": "boolean",
      "label": "Enable Traefik integration",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik integration"
    },
    {
      "key": "traefik_tls_certresolver",
      "type": "string",
      "label": "Traefik Tls Certresolver",
      "required": true,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "str",
      "default": "cloudflare"
    },
    {
      "key": "traefik_tls_enabled",
      "type": "boolean",
      "label": "Enable Traefik TLS",
      "required": false,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik TLS"
    },
    {
      "key": "volume_mode",
      "type": "string",
      "label": "Volume Mode",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "enum",
      "default": "local",
      "options": [
        "local",
        "mount",
        "nfs"
      ]
    },
    {
      "key": "volume_mount_path",
      "type": "string",
      "label": "Volume Mount Path",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "str",
      "default": "/mnt/storage",
      "needs": [
        "volume_mode=mount"
      ]
    },
    {
      "key": "volume_nfs_server",
      "type": "string",
      "label": "Volume Nfs Server",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "str",
      "default": "192.168.1.1",
      "needs": [
        "volume_mode=nfs"
      ]
    },
    {
      "key": "volume_nfs_path",
      "type": "string",
      "label": "Volume Nfs Path",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "str",
      "default": "/export",
      "needs": [
        "volume_mode=nfs"
      ]
    },
    {
      "key": "volume_nfs_options",
      "type": "string",
      "label": "Volume Nfs Options",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "str",
      "default": "rw,nolock,soft",
      "needs": [
        "volume_mode=nfs"
      ]
    },
    {
      "key": "swarm_placement_host",
      "type": "string",
      "label": "Target hostname for placement constraint",
      "required": false,
      "section": {
        "key": "swarm",
        "title": "Docker Swarm",
        "toggle": "swarm_enabled",
        "description": "Configure Docker Swarm mode deployment"
      },
      "source_type": "str",
      "default": "",
      "description": "Target hostname for placement constraint",
      "extra": "Constrains service to run on specific node by hostname"
    },
    {
      "key": "swarm_enabled",
      "type": "boolean",
      "label": "Enable Docker Swarm mode",
      "required": false,
      "section": {
        "key": "swarm",
        "title": "Docker Swarm",
        "toggle": "swarm_enabled",
        "description": "Configure Docker Swarm mode deployment"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Docker Swarm mode"
    },
    {
      "key": "swarm_placement_mode",
      "type": "string",
      "label": "The placement mode",
      "required": false,
      "section": {
        "key": "swarm",
        "title": "Docker Swarm",
        "toggle": "swarm_enabled",
        "description": "Configure Docker Swarm mode deployment"
      },
      "source_type": "str",
      "default": "replicated",
      "description": "The placement mode"
    },
    {
      "key": "swarm_replicas",
      "type": "number",
      "label": "The number of replicas",
      "required": false,
      "section": {
        "key": "swarm",
        "title": "Docker Swarm",
        "toggle": "swarm_enabled",
        "description": "Configure Docker Swarm mode deployment"
      },
      "source_type": "int",
      "default": 1,
      "description": "The number of replicas"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
