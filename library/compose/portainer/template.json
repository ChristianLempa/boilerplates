{
  "version": "1",
  "slug": "portainer",
  "kind": "compose",
  "metadata": {
    "name": "Portainer",
    "description": "Portainer is a powerful and user-friendly management tool for Docker and Kubernetes environments.\nIt provides a simple web-based interface to manage containers, images, networks, and volumes,\nmaking it easier to deploy and monitor applications.\n## References\n- **Project:** https://www.portainer.io/\n- **Documentation:** https://docs.portainer.io/\n- **GitHub:** https://github.com/portainer/portainer",
    "tags": [
      "traefik",
      "swarm",
      "volumes"
    ],
    "author": "Christian Lempa",
    "template_version": "2.38.1-alpine",
    "icon": {
      "provider": "simple-icons",
      "id": "portainer"
    },
    "date": "2026-02-12"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "portainer"
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_http",
          "type": "str",
          "title": "Ports Http",
          "required": false,
          "default": 9000
        },
        {
          "name": "ports_https",
          "type": "str",
          "title": "Ports Https",
          "required": false,
          "default": 9443
        },
        {
          "name": "ports_edge",
          "type": "int",
          "title": "Host port for Edge agent (8000)",
          "required": true,
          "default": 8000,
          "description": "Host port for Edge agent (8000)"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "portainer"
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik Network",
          "required": true,
          "default": "traefik"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik Domain",
          "required": true,
          "default": "home.arpa"
        },
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        }
      ]
    },
    {
      "key": "traefik-tls",
      "title": "Traefik TLS",
      "variables": [
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik Tls Certresolver",
          "required": true,
          "default": "cloudflare"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable Traefik TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        }
      ]
    },
    {
      "key": "volume",
      "title": "Volume",
      "variables": [
        {
          "name": "volume_mode",
          "type": "str",
          "title": "Volume Mode",
          "required": true,
          "default": "local",
          "options": [
            "local",
            "mount",
            "nfs"
          ]
        },
        {
          "name": "volume_mount_path",
          "type": "str",
          "title": "Volume Mount Path",
          "required": true,
          "default": "/mnt/storage",
          "needs": [
            "volume_mode=mount"
          ]
        },
        {
          "name": "volume_nfs_server",
          "type": "str",
          "title": "Volume Nfs Server",
          "required": true,
          "default": "192.168.1.1",
          "needs": [
            "volume_mode=nfs"
          ]
        },
        {
          "name": "volume_nfs_path",
          "type": "str",
          "title": "Volume Nfs Path",
          "required": true,
          "default": "/export",
          "needs": [
            "volume_mode=nfs"
          ]
        },
        {
          "name": "volume_nfs_options",
          "type": "str",
          "title": "Volume Nfs Options",
          "required": true,
          "default": "rw,nolock,soft",
          "needs": [
            "volume_mode=nfs"
          ]
        }
      ]
    },
    {
      "key": "swarm",
      "title": "Docker Swarm",
      "variables": [
        {
          "name": "swarm_placement_host",
          "type": "str",
          "title": "Target hostname for placement constraint",
          "required": false,
          "default": "",
          "description": "Target hostname for placement constraint"
        },
        {
          "name": "swarm_enabled",
          "type": "bool",
          "title": "Enable Docker Swarm mode",
          "required": false,
          "default": false,
          "description": "Enable Docker Swarm mode"
        },
        {
          "name": "swarm_placement_mode",
          "type": "str",
          "title": "The placement mode",
          "required": false,
          "default": "replicated",
          "description": "The placement mode"
        },
        {
          "name": "swarm_replicas",
          "type": "int",
          "title": "The number of replicas",
          "required": false,
          "default": 1,
          "description": "The number of replicas"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
