{
  "version": "1",
  "slug": "mariadb",
  "kind": "compose",
  "metadata": {
    "name": "MariaDB",
    "description": "MariaDB is a community-developed, commercially supported fork of the MySQL relational database management system.\nIt's designed to remain free and open-source software under the GNU General Public License.\n## References\n* **Project:** https://mariadb.org/\n* **Documentation:** https://mariadb.com/kb/en/documentation/\n* **GitHub:** https://github.com/MariaDB/server",
    "tags": [],
    "author": "Christian Lempa",
    "template_version": "12.2.2",
    "icon": {
      "provider": "selfh",
      "id": "mariadb"
    },
    "next_steps": "Log in with your initial admin user:\n```bash\nUsername: `root` or `{{ database_user }}`\nPassword: {{ database_password }}\n```",
    "date": "2026-02-16",
    "draft": true
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "service_name",
      "type": "string",
      "label": "Service Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "mariadb"
    },
    {
      "key": "restart_policy",
      "type": "string",
      "label": "Restart Policy",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "enum",
      "default": "unless-stopped",
      "options": [
        "unless-stopped",
        "always",
        "on-failure",
        "no"
      ]
    },
    {
      "key": "ports_mariadb",
      "type": "number",
      "label": "Host port for MariaDB",
      "required": true,
      "section": {
        "key": "ports"
      },
      "source_type": "int",
      "default": 3306,
      "description": "Host port for MariaDB"
    },
    {
      "key": "database_name",
      "type": "string",
      "label": "Database Name",
      "required": true,
      "section": {
        "key": "database"
      },
      "source_type": "str"
    },
    {
      "key": "database_user",
      "type": "string",
      "label": "Database User",
      "required": true,
      "section": {
        "key": "database"
      },
      "source_type": "str"
    },
    {
      "key": "database_password",
      "type": "string",
      "label": "Database Password",
      "required": true,
      "section": {
        "key": "database"
      },
      "source_type": "str",
      "sensitive": true
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
