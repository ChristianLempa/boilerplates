{
  "version": "1",
  "slug": "mariadb",
  "kind": "compose",
  "metadata": {
    "name": "MariaDB",
    "description": "MariaDB is a community-developed, commercially supported fork of the MySQL relational database management system.\nIt's designed to remain free and open-source software under the GNU General Public License.\n## References\n* **Project:** https://mariadb.org/\n* **Documentation:** https://mariadb.com/kb/en/documentation/\n* **GitHub:** https://github.com/MariaDB/server",
    "tags": [],
    "author": "Christian Lempa",
    "template_version": "12.2.2",
    "icon": {
      "provider": "simple-icons",
      "id": "mariadb"
    },
    "next_steps": "Log in with your initial admin user:\n```bash\nUsername: `root` or `{{ database_user }}`\nPassword: {{ database_password }}\n```",
    "date": "2026-02-16",
    "draft": true
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "mariadb"
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_mariadb",
          "type": "int",
          "title": "Host port for MariaDB",
          "required": true,
          "default": 3306,
          "description": "Host port for MariaDB"
        }
      ]
    },
    {
      "key": "database",
      "title": "Database",
      "variables": [
        {
          "name": "database_name",
          "type": "str",
          "title": "Database Name",
          "required": true
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database User",
          "required": true
        },
        {
          "name": "database_password",
          "type": "str",
          "title": "Database Password",
          "required": true,
          "sensitive": true
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
