{
  "version": "1",
  "slug": "nginx",
  "kind": "compose",
  "metadata": {
    "name": "Nginx",
    "description": "Nginx is a high-performance web server, reverse proxy, and load balancer known for its stability, rich feature set, simple configuration, and low resource\nconsumption. It is widely used to serve static content, handle HTTP requests, and distribute traffic across multiple servers.\n\n## Prerequisites\n* **Project:** https://nginx.org/\n* **Documentation:** https://nginx.org/en/docs/\n* **GitHub:** https://github.com/nginx/nginx",
    "tags": [
      "traefik",
      "swarm"
    ],
    "author": "Christian Lempa",
    "template_version": "1.28.2-alpine",
    "icon": {
      "provider": "simple-icons",
      "id": "nginx"
    },
    "date": "2026-02-05",
    "draft": true
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "nginx"
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": false,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        },
        {
          "name": "container_name",
          "type": "str",
          "title": "Container Name",
          "required": false,
          "default": "nginx"
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false,
          "default": "UTC"
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "Traefik Tls Entrypoint",
          "required": false,
          "default": ""
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik Tls Certresolver",
          "required": false,
          "default": ""
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_http",
          "type": "int",
          "title": "HTTP port for nginx service",
          "required": false,
          "default": 8080,
          "description": "HTTP port for nginx service"
        },
        {
          "name": "ports_https",
          "type": "int",
          "title": "HTTPS port for nginx service",
          "required": false,
          "default": 8443,
          "description": "HTTPS port for nginx service"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Traefik Enabled",
          "required": false,
          "default": false
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik Network",
          "required": false,
          "default": "traefik"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "nginx"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik Domain",
          "required": false,
          "default": "home.arpa"
        },
        {
          "name": "traefik_entrypoint",
          "type": "bool",
          "title": "Traefik Entrypoint",
          "required": false,
          "default": "web"
        }
      ]
    },
    {
      "key": "network",
      "title": "Network",
      "variables": [
        {
          "name": "network_mode",
          "type": "str",
          "title": "Network Mode",
          "required": false,
          "default": "bridge",
          "options": [
            "bridge",
            "host",
            "macvlan"
          ]
        },
        {
          "name": "network_name",
          "type": "str",
          "title": "Network Name",
          "required": false,
          "default": "bridge"
        }
      ]
    },
    {
      "key": "swarm",
      "title": "Swarm",
      "variables": [
        {
          "name": "swarm_enabled",
          "type": "bool",
          "title": "Swarm Enabled",
          "required": false,
          "default": false
        },
        {
          "name": "swarm_replicas",
          "type": "int",
          "title": "Number of replicas for Swarm mode",
          "required": false,
          "default": 1,
          "description": "Number of replicas for Swarm mode"
        },
        {
          "name": "swarm_placement_host",
          "type": "str",
          "title": "The placement host",
          "required": false,
          "default": "",
          "description": "The placement host"
        },
        {
          "name": "swarm_placement_mode",
          "type": "str",
          "title": "The placement mode",
          "required": false,
          "default": "replicated",
          "description": "The placement mode"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
