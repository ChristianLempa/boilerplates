{
  "version": "1",
  "slug": "nginx",
  "kind": "compose",
  "metadata": {
    "name": "Nginx",
    "description": "Nginx is a high-performance web server, reverse proxy, and load balancer known for its stability, rich feature set, simple configuration, and low resource\nconsumption. It is widely used to serve static content, handle HTTP requests, and distribute traffic across multiple servers.\n\n## Prerequisites\n* **Project:** https://nginx.org/\n* **Documentation:** https://nginx.org/en/docs/\n* **GitHub:** https://github.com/nginx/nginx",
    "tags": [
      "traefik",
      "swarm"
    ],
    "author": "Christian Lempa",
    "template_version": "1.28.2-alpine",
    "icon": {
      "provider": "selfh",
      "id": "nginx"
    },
    "date": "2026-02-05",
    "draft": true
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "service_name",
      "type": "string",
      "label": "Service Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "nginx"
    },
    {
      "key": "restart_policy",
      "type": "string",
      "label": "Restart Policy",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "enum",
      "default": "unless-stopped",
      "options": [
        "unless-stopped",
        "always",
        "on-failure",
        "no"
      ]
    },
    {
      "key": "container_name",
      "type": "string",
      "label": "Container Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "nginx"
    },
    {
      "key": "container_timezone",
      "type": "string",
      "label": "Container Timezone",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "UTC"
    },
    {
      "key": "ports_http",
      "type": "number",
      "label": "HTTP port for nginx service",
      "required": false,
      "section": {
        "key": "ports"
      },
      "source_type": "int",
      "default": 8080,
      "description": "HTTP port for nginx service"
    },
    {
      "key": "ports_https",
      "type": "number",
      "label": "HTTPS port for nginx service",
      "required": false,
      "section": {
        "key": "ports"
      },
      "source_type": "int",
      "default": 8443,
      "description": "HTTPS port for nginx service"
    },
    {
      "key": "traefik_enabled",
      "type": "boolean",
      "label": "Traefik Enabled",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "bool",
      "default": false
    },
    {
      "key": "traefik_network",
      "type": "string",
      "label": "Traefik Network",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "traefik"
    },
    {
      "key": "traefik_host",
      "type": "string",
      "label": "Traefik Host",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "nginx"
    },
    {
      "key": "traefik_domain",
      "type": "string",
      "label": "Traefik Domain",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "home.arpa"
    },
    {
      "key": "traefik_entrypoint",
      "type": "boolean",
      "label": "Traefik Entrypoint",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "bool",
      "default": "web"
    },
    {
      "key": "network_mode",
      "type": "string",
      "label": "Network Mode",
      "required": false,
      "section": {
        "key": "network"
      },
      "source_type": "enum",
      "default": "bridge",
      "options": [
        "bridge",
        "host",
        "macvlan"
      ]
    },
    {
      "key": "network_name",
      "type": "string",
      "label": "Network Name",
      "required": false,
      "section": {
        "key": "network"
      },
      "source_type": "str",
      "default": "bridge"
    },
    {
      "key": "swarm_enabled",
      "type": "boolean",
      "label": "Swarm Enabled",
      "required": false,
      "section": {
        "key": "swarm",
        "toggle": "swarm_enabled"
      },
      "source_type": "bool",
      "default": false
    },
    {
      "key": "swarm_replicas",
      "type": "number",
      "label": "Number of replicas for Swarm mode",
      "required": false,
      "section": {
        "key": "swarm",
        "toggle": "swarm_enabled"
      },
      "source_type": "int",
      "default": 1,
      "description": "Number of replicas for Swarm mode"
    },
    {
      "key": "swarm_placement_host",
      "type": "string",
      "label": "The placement host",
      "required": false,
      "section": {
        "key": "swarm",
        "toggle": "swarm_enabled"
      },
      "source_type": "str",
      "default": "",
      "description": "The placement host"
    },
    {
      "key": "swarm_placement_mode",
      "type": "string",
      "label": "The placement mode",
      "required": false,
      "section": {
        "key": "swarm",
        "toggle": "swarm_enabled"
      },
      "source_type": "str",
      "default": "replicated",
      "description": "The placement mode"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
