{
  "version": "1",
  "slug": "postgres",
  "kind": "compose",
  "metadata": {
    "name": "PostgreSQL",
    "description": "PostgreSQL is a powerful, open source object-relational database system with over 30 years of active development that has earned it a strong reputation for reliability, feature robustness, and performance.\n\nProject: https://www.postgresql.org/\nDocumentation: https://www.postgresql.org/docs/\nGitHub: https://github.com/postgres/postgres\n",
    "tags": [
      "swarm"
    ],
    "author": "Christian Lempa",
    "template_version": "18.2",
    "icon": {
      "provider": "simple-icons",
      "id": "postgresql"
    },
    "date": "2026-02-13",
    "draft": true
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "postgres"
        },
        {
          "name": "container_name",
          "type": "str",
          "title": "Container Name",
          "required": false,
          "default": "postgres"
        },
        {
          "name": "container_hostname",
          "type": "str",
          "title": "Container Hostname",
          "required": false
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        },
        {
          "name": "postgres_initdb_args",
          "type": "str",
          "title": "Postgres Initdb Args",
          "required": false,
          "default": ""
        },
        {
          "name": "postgres_host_auth_method",
          "type": "str",
          "title": "Postgres Host Auth Method",
          "required": false,
          "default": ""
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_postgres",
          "type": "int",
          "title": "PostgreSQL port",
          "required": false,
          "default": 5432,
          "description": "PostgreSQL port"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "postgres"
        }
      ]
    },
    {
      "key": "network",
      "title": "Network",
      "variables": [
        {
          "name": "network_mode",
          "type": "str",
          "title": "Network Mode",
          "required": false
        },
        {
          "name": "network_name",
          "type": "str",
          "title": "Network Name",
          "required": false,
          "default": "postgres_network"
        },
        {
          "name": "network_external",
          "type": "bool",
          "title": "Whether the network is external",
          "required": false,
          "default": false,
          "description": "Whether the network is external"
        }
      ]
    },
    {
      "key": "swarm",
      "title": "Docker Swarm",
      "variables": [
        {
          "name": "swarm_replicas",
          "type": "int",
          "title": "Number of replicas for Swarm mode",
          "required": false,
          "default": 1,
          "description": "Number of replicas for Swarm mode"
        },
        {
          "name": "swarm_enabled",
          "type": "bool",
          "title": "Enable Docker Swarm mode",
          "required": false,
          "default": false,
          "description": "Enable Docker Swarm mode"
        },
        {
          "name": "swarm_placement_host",
          "type": "str",
          "title": "The placement host",
          "required": false,
          "default": "",
          "description": "The placement host"
        },
        {
          "name": "swarm_placement_mode",
          "type": "str",
          "title": "The placement mode",
          "required": false,
          "default": "replicated",
          "description": "The placement mode"
        }
      ]
    },
    {
      "key": "volume",
      "title": "Volume",
      "variables": [
        {
          "name": "volume_mode",
          "type": "str",
          "title": "Volume mounting mode (local, mount, nfs)",
          "required": false,
          "default": "local",
          "description": "Volume mounting mode (local, mount, nfs)",
          "options": [
            "local",
            "mount",
            "nfs"
          ]
        },
        {
          "name": "volume_mount_path",
          "type": "str",
          "title": "Path for bind mounts when volume_mode is 'mount'",
          "required": false,
          "default": "/var/lib/postgresql/data",
          "description": "Path for bind mounts when volume_mode is 'mount'"
        },
        {
          "name": "volume_nfs_server",
          "type": "str",
          "title": "NFS server address when volume_mode is 'nfs'",
          "required": false,
          "default": "",
          "description": "NFS server address when volume_mode is 'nfs'"
        },
        {
          "name": "volume_nfs_path",
          "type": "str",
          "title": "NFS path when volume_mode is 'nfs'",
          "required": false,
          "default": "",
          "description": "NFS path when volume_mode is 'nfs'"
        },
        {
          "name": "volume_nfs_options",
          "type": "str",
          "title": "NFS mount options when volume_mode is 'nfs'",
          "required": false,
          "default": "rw",
          "description": "NFS mount options when volume_mode is 'nfs'"
        }
      ]
    },
    {
      "key": "database",
      "title": "Database",
      "variables": [
        {
          "name": "database_port",
          "type": "int",
          "title": "Database Port",
          "required": true,
          "default": 5432
        },
        {
          "name": "database_name",
          "type": "str",
          "title": "Database Name",
          "required": true
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database User",
          "required": true
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
