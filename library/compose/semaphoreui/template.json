{
  "version": "1",
  "slug": "semaphoreui",
  "kind": "compose",
  "metadata": {
    "name": "Semaphore UI",
    "description": "Modern UI for Ansible automation with task scheduling and web-based management.\nSemaphore provides a beautiful web interface to run Ansible playbooks, manage\ninventories, and schedule automated tasks. Perfect for teams who want a\nuser-friendly way to execute and monitor Ansible automation.\n## Prerequisites\n- :info: SemaphoreUI supports multiple database backends. You can choose between SQLite (default),\nPostgreSQL, or MySQL. SQLite is suitable for small deployments, while PostgreSQL and MySQL\nare recommended for larger installations.\n## References\n- **Project:** https://www.semaphoreui.com/\n- **Documentation:** https://docs.semaphoreui.com/\n- **GitHub:** https://github.com/semaphoreui/semaphore",
    "tags": [
      "traefik",
      "database"
    ],
    "author": "Christian Lempa",
    "template_version": "v2.17.2",
    "icon": {
      "provider": "selfh",
      "id": "semaphore-ui"
    },
    "date": "2026-02-15",
    "next_steps": "Log in with your initial admin user:\n```bash\nUsername: {{ admin_user }}\nPassword: {{ admin_pass }}\n```"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "service_name",
      "type": "string",
      "label": "Service Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "semaphoreui"
    },
    {
      "key": "container_name",
      "type": "string",
      "label": "Container Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "semaphoreui"
    },
    {
      "key": "restart_policy",
      "type": "string",
      "label": "Restart Policy",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "enum",
      "default": "unless-stopped",
      "options": [
        "unless-stopped",
        "always",
        "on-failure",
        "no"
      ]
    },
    {
      "key": "secret_key",
      "type": "string",
      "label": "Secret key for encrypting access keys",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "description": "Secret key for encrypting access keys",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "admin_user",
      "type": "string",
      "label": "Administrator username",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "admin",
      "description": "Administrator username"
    },
    {
      "key": "admin_name",
      "type": "string",
      "label": "Administrator full name",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "Administrator",
      "description": "Administrator full name"
    },
    {
      "key": "admin_email",
      "type": "string",
      "label": "Administrator email address",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "admin@home.arpa",
      "description": "Administrator email address"
    },
    {
      "key": "admin_pass",
      "type": "string",
      "label": "Administrator password",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "description": "Administrator password",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "ansible_host_key_checking",
      "type": "boolean",
      "label": "Enable Ansible SSH host key checking",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "bool",
      "description": "Enable Ansible SSH host key checking"
    },
    {
      "key": "ports_http",
      "type": "string",
      "label": "Ports Http",
      "required": false,
      "section": {
        "key": "ports"
      },
      "source_type": "str",
      "default": 3000
    },
    {
      "key": "traefik_host",
      "type": "string",
      "label": "Traefik Host",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "semaphoreui"
    },
    {
      "key": "traefik_network",
      "type": "string",
      "label": "Traefik Network",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "traefik"
    },
    {
      "key": "traefik_domain",
      "type": "string",
      "label": "Traefik Domain",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "home.arpa"
    },
    {
      "key": "traefik_enabled",
      "type": "boolean",
      "label": "Enable Traefik integration",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik integration"
    },
    {
      "key": "traefik_tls_certresolver",
      "type": "string",
      "label": "Traefik Tls Certresolver",
      "required": true,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "str",
      "default": "cloudflare"
    },
    {
      "key": "traefik_tls_enabled",
      "type": "boolean",
      "label": "Enable Traefik TLS",
      "required": false,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik TLS"
    },
    {
      "key": "database_type",
      "type": "string",
      "label": "Database Type",
      "required": false,
      "section": {
        "key": "database"
      },
      "source_type": "str",
      "default": "mysql",
      "options": [
        "postgres",
        "mysql"
      ]
    },
    {
      "key": "database_name",
      "type": "string",
      "label": "Database Name",
      "required": false,
      "section": {
        "key": "database"
      },
      "source_type": "str",
      "default": "semaphore"
    },
    {
      "key": "database_user",
      "type": "string",
      "label": "Database User",
      "required": false,
      "section": {
        "key": "database"
      },
      "source_type": "str",
      "default": "semaphore"
    },
    {
      "key": "database_host",
      "type": "string",
      "label": "Database Host",
      "required": true,
      "section": {
        "key": "database"
      },
      "source_type": "str",
      "default": "postgres",
      "needs": [
        "database_external=true"
      ]
    },
    {
      "key": "database_password",
      "type": "string",
      "label": "Database Password",
      "required": true,
      "section": {
        "key": "database"
      },
      "source_type": "str",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "database_external",
      "type": "boolean",
      "label": "Use external database",
      "required": false,
      "section": {
        "key": "database"
      },
      "source_type": "bool",
      "default": false,
      "description": "Use external database"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
