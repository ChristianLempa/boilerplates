{
  "version": "1",
  "slug": "semaphoreui",
  "kind": "compose",
  "metadata": {
    "name": "Semaphore UI",
    "description": "Modern UI for Ansible automation with task scheduling and web-based management.\nSemaphore provides a beautiful web interface to run Ansible playbooks, manage\ninventories, and schedule automated tasks. Perfect for teams who want a\nuser-friendly way to execute and monitor Ansible automation.\n## Prerequisites\n- :info: SemaphoreUI supports multiple database backends. You can choose between SQLite (default),\nPostgreSQL, or MySQL. SQLite is suitable for small deployments, while PostgreSQL and MySQL\nare recommended for larger installations.\n## References\n- **Project:** https://www.semaphoreui.com/\n- **Documentation:** https://docs.semaphoreui.com/\n- **GitHub:** https://github.com/semaphoreui/semaphore",
    "tags": [
      "traefik",
      "database"
    ],
    "author": "Christian Lempa",
    "template_version": "v2.17.2",
    "icon": {
      "provider": "mdi",
      "id": "traffic-light-outline"
    },
    "date": "2026-02-15",
    "next_steps": "Log in with your initial admin user:\n```bash\nUsername: {{ admin_user }}\nPassword: {{ admin_pass }}\n```"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "semaphoreui"
        },
        {
          "name": "container_name",
          "type": "str",
          "title": "Container Name",
          "required": false,
          "default": "semaphoreui"
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        },
        {
          "name": "secret_key",
          "type": "str",
          "title": "Secret key for encrypting access keys",
          "required": true,
          "description": "Secret key for encrypting access keys",
          "sensitive": true,
          "autogenerated": true
        },
        {
          "name": "admin_user",
          "type": "str",
          "title": "Administrator username",
          "required": true,
          "default": "admin",
          "description": "Administrator username"
        },
        {
          "name": "admin_name",
          "type": "str",
          "title": "Administrator full name",
          "required": true,
          "default": "Administrator",
          "description": "Administrator full name"
        },
        {
          "name": "admin_email",
          "type": "str",
          "title": "Administrator email address",
          "required": true,
          "default": "admin@home.arpa",
          "description": "Administrator email address"
        },
        {
          "name": "admin_pass",
          "type": "str",
          "title": "Administrator password",
          "required": true,
          "description": "Administrator password",
          "sensitive": true,
          "autogenerated": true
        },
        {
          "name": "ansible_host_key_checking",
          "type": "bool",
          "title": "Enable Ansible SSH host key checking",
          "required": false,
          "description": "Enable Ansible SSH host key checking"
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_http",
          "type": "str",
          "title": "Ports Http",
          "required": false,
          "default": 3000
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "semaphoreui"
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik Network",
          "required": true,
          "default": "traefik"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik Domain",
          "required": true,
          "default": "home.arpa"
        },
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        }
      ]
    },
    {
      "key": "traefik-tls",
      "title": "Traefik TLS",
      "variables": [
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik Tls Certresolver",
          "required": true,
          "default": "cloudflare"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable Traefik TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        }
      ]
    },
    {
      "key": "database",
      "title": "Database",
      "variables": [
        {
          "name": "database_type",
          "type": "str",
          "title": "Database Type",
          "required": false,
          "default": "mysql",
          "options": [
            "postgres",
            "mysql"
          ]
        },
        {
          "name": "database_name",
          "type": "str",
          "title": "Database Name",
          "required": false,
          "default": "semaphore"
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database User",
          "required": false,
          "default": "semaphore"
        },
        {
          "name": "database_host",
          "type": "str",
          "title": "Database Host",
          "required": true,
          "default": "postgres",
          "needs": [
            "database_external=true"
          ]
        },
        {
          "name": "database_password",
          "type": "str",
          "title": "Database Password",
          "required": true,
          "sensitive": true,
          "autogenerated": true
        },
        {
          "name": "database_external",
          "type": "bool",
          "title": "Use external database",
          "required": false,
          "default": false,
          "description": "Use external database"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
