{
  "version": "1",
  "slug": "dockge",
  "kind": "compose",
  "metadata": {
    "name": "Dockge",
    "description": "Dockge is a powerful Docker management platform that simplifies container orchestration and monitoring.\nIt provides an intuitive web interface to manage Docker containers, images, networks, and volumes with ease.\n## Prerequisites\n* **Project:** https://dockge.com/\n* **Documentation:** https://docs.dockge.com/\n* **GitHub:** https://github.com/dockge/dockge",
    "tags": [
      "traefik"
    ],
    "author": "Christian Lempa",
    "template_version": "1.5.0",
    "icon": {
      "provider": "mdi",
      "id": "docker"
    },
    "date": "2025-09-28"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "dockge"
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        },
        {
          "name": "stacks_path",
          "type": "str",
          "title": "Docker Compose Path",
          "required": true,
          "default": "/opt/stacks",
          "description": "Docker Compose Path"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "dockge"
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik Network",
          "required": true,
          "default": "traefik"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik Domain",
          "required": true,
          "default": "home.arpa"
        },
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        }
      ]
    },
    {
      "key": "traefik-tls",
      "title": "Traefik TLS",
      "variables": [
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik Tls Certresolver",
          "required": true,
          "default": "cloudflare"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable Traefik TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_http",
          "type": "str",
          "title": "Ports Http",
          "required": false,
          "default": 5001
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
