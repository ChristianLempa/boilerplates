{
  "version": "1",
  "slug": "openwebui",
  "kind": "compose",
  "metadata": {
    "name": "Openwebui",
    "description": "OpenWebUI is an open-source web-based user interface for managing and interacting with AI models. It provides a user-friendly platform to deploy, monitor, and utilize various AI models for tasks such as image generation, text generation, and more. OpenWebUI supports integration with popular AI frameworks and offers features like model management, user authentication, and real-time interaction.\n\nProject: https://openwebui.io/\nDocumentation: https://docs.openwebui.io/\nGitHub: https://github.com/openwebui/openwebui\n",
    "tags": [
      "traefik",
      "authentik"
    ],
    "author": "Christian Lempa",
    "template_version": "0.7.2",
    "icon": {
      "provider": "mdi",
      "id": "robot-outline"
    },
    "date": "2026-01-10",
    "draft": true
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "openwebui"
        },
        {
          "name": "container_name",
          "type": "str",
          "title": "Container Name",
          "required": false,
          "default": "openwebui"
        },
        {
          "name": "container_hostname",
          "type": "str",
          "title": "Container Hostname",
          "required": false
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        },
        {
          "name": "ollama_base_url",
          "type": "str",
          "title": "Ollama API base URL",
          "required": false,
          "default": "http://ollama:11434",
          "description": "Ollama API base URL"
        },
        {
          "name": "traefik_entrypoint",
          "type": "str",
          "title": "Traefik Entrypoint",
          "required": false,
          "default": ""
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "Traefik Tls Entrypoint",
          "required": false,
          "default": ""
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "openwebui.home.arpa"
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik Network",
          "required": true,
          "default": "traefik"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik Domain",
          "required": true,
          "default": "home.arpa"
        },
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        }
      ]
    },
    {
      "key": "traefik-tls",
      "title": "Traefik TLS",
      "variables": [
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik Tls Certresolver",
          "required": true,
          "default": "cloudflare"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable Traefik TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_http",
          "type": "int",
          "title": "Web UI port",
          "required": false,
          "default": 8080,
          "description": "Web UI port"
        }
      ]
    },
    {
      "key": "authentik",
      "title": "Authentik",
      "variables": [
        {
          "name": "authentik_enabled",
          "type": "str",
          "title": "Authentik Enabled",
          "required": false,
          "default": false
        },
        {
          "name": "openid_provider_url",
          "type": "str",
          "title": "OpenID provider configuration URL",
          "required": false,
          "default": "https://authentik.example.com/application/o/openwebui/.well-known/openid-configuration",
          "description": "OpenID provider configuration URL"
        },
        {
          "name": "openid_redirect_uri",
          "type": "str",
          "title": "OAuth redirect URI",
          "required": false,
          "default": "https://openwebui.example.com/oauth/oidc/callback",
          "description": "OAuth redirect URI"
        },
        {
          "name": "oauth_scopes",
          "type": "str",
          "title": "OAuth scopes (space-separated)",
          "required": false,
          "default": "openid email profile",
          "description": "OAuth scopes (space-separated)"
        },
        {
          "name": "oauth_merge_accounts",
          "type": "bool",
          "title": "Merge OAuth accounts by email",
          "required": false,
          "default": false,
          "description": "Merge OAuth accounts by email"
        },
        {
          "name": "authentik_client_id",
          "type": "str",
          "title": "Authentik Client Id",
          "required": true,
          "sensitive": true
        },
        {
          "name": "authentik_client_secret",
          "type": "str",
          "title": "Authentik Client Secret",
          "required": true,
          "sensitive": true
        },
        {
          "name": "authentik_slug",
          "type": "str",
          "title": "The Authentik application slug",
          "required": false,
          "default": "",
          "description": "The Authentik application slug"
        },
        {
          "name": "authentik_url",
          "type": "str",
          "title": "The Authentik URL",
          "required": false,
          "default": "",
          "description": "The Authentik URL"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
