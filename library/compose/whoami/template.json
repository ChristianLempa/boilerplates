{
  "version": "1",
  "slug": "whoami",
  "kind": "compose",
  "metadata": {
    "name": "Whoami",
    "description": "A **simple web application** that displays information about the HTTP request it receives.\n## Use Cases\n- Testing reverse proxy configurations\n- Debugging web server setups\n- Verifying load balancer functionality\n- Quick HTTP endpoint testing\n## Resources\n- **Project**: https://github.com/traefik/whoami\n- **Documentation**: https://traefik.io/docs/\n- **GitHub**: https://github.com/traefik/whoami\n",
    "tags": [
      "traefik",
      "testing",
      "http"
    ],
    "author": "Christian Lempa",
    "template_version": "1.11.0",
    "icon": {
      "provider": "simple-icons",
      "id": "traefikproxy",
      "color": "rose"
    },
    "date": "2025-10-30"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Container restart policy",
          "required": true,
          "default": "unless-stopped",
          "description": "Container restart policy",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "whoami"
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik network name",
          "required": true,
          "default": "traefik",
          "description": "Traefik network name"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Base domain (e.g., example.com)",
          "required": true,
          "default": "home.arpa",
          "description": "Base domain (e.g., example.com)"
        }
      ]
    },
    {
      "key": "traefik-tls",
      "title": "Traefik Tls",
      "variables": [
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable HTTPS/TLS",
          "required": false,
          "default": true,
          "description": "Enable HTTPS/TLS"
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik certificate resolver name",
          "required": true,
          "default": "cloudflare",
          "description": "Traefik certificate resolver name"
        }
      ]
    }
  ]
}
