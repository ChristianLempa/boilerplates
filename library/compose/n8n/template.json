{
  "version": "1",
  "slug": "n8n",
  "kind": "compose",
  "metadata": {
    "name": "N8N",
    "description": "N8n is a free and source-available workflow automation tool. It enables you to connect\nvarious apps and services to automate repetitive tasks without coding.\nWith its user-friendly interface, you can create complex workflows by simply dragging\nand dropping nodes that represent different actions and triggers.\n## Prerequisites\n- :info: By default, n8n uses SQLite as its database, which is suitable for small-scale or\npersonal use. For production environments, it is recommended to use an external\ndatabase like PostgreSQL or MySQL for better performance and reliability. This is also\nrequired when using Queue Mode.\n- :info: Queue mode allows n8n to handle a large number of workflows and tasks efficiently, by using\nmultiple Workers, and Redis as the queue backend. This is essential for high-availability\nsetups where multiple n8n instances work together. It also supports Queue Monitoring\n(when Prometheus metrics are enabled).\n## Resources\n- **Project**: https://n8n.io/\n- **Documentation**: https://docs.n8n.io/\n- **GitHub**: https://github.com/n8n-io/n8n\n",
    "tags": [
      "traefik",
      "database"
    ],
    "author": "Christian Lempa",
    "template_version": "8-alpine",
    "icon": {
      "provider": "selfh",
      "id": "n8n"
    },
    "date": "2025-12-17",
    "draft": true
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "service_name",
      "type": "string",
      "label": "Service Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "n8n"
    },
    {
      "key": "container_name",
      "type": "string",
      "label": "Container Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "n8n-server"
    },
    {
      "key": "container_hostname",
      "type": "string",
      "label": "Container Hostname",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "n8n-server"
    },
    {
      "key": "container_timezone",
      "type": "string",
      "label": "Container Timezone",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str"
    },
    {
      "key": "container_loglevel",
      "type": "string",
      "label": "Container Loglevel",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "enum",
      "options": [
        "debug",
        "info",
        "warn",
        "error"
      ]
    },
    {
      "key": "restart_policy",
      "type": "string",
      "label": "Restart Policy",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "enum",
      "default": "unless-stopped",
      "options": [
        "unless-stopped",
        "always",
        "on-failure",
        "no"
      ]
    },
    {
      "key": "queue_enabled",
      "type": "boolean",
      "label": "Enable queue mode (requires Redis)",
      "required": false,
      "section": {
        "key": "queue",
        "title": "Queue Mode",
        "toggle": "queue_enabled",
        "needs": "database_enabled=true",
        "description": "Enable queue mode with Redis for scaled deployments"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable queue mode (requires Redis)",
      "extra": "Required for multiple workers and scaled deployments"
    },
    {
      "key": "queue_redis_external",
      "type": "boolean",
      "label": "Use external Redis instance",
      "required": false,
      "section": {
        "key": "queue",
        "title": "Queue Mode",
        "toggle": "queue_enabled",
        "needs": "database_enabled=true",
        "description": "Enable queue mode with Redis for scaled deployments"
      },
      "source_type": "bool",
      "default": false,
      "description": "Use external Redis instance",
      "needs": "queue_enabled"
    },
    {
      "key": "queue_redis_host",
      "type": "string",
      "label": "Redis host",
      "required": false,
      "section": {
        "key": "queue",
        "title": "Queue Mode",
        "toggle": "queue_enabled",
        "needs": "database_enabled=true",
        "description": "Enable queue mode with Redis for scaled deployments"
      },
      "source_type": "str",
      "default": "redis",
      "description": "Redis host",
      "needs": "queue_enabled"
    },
    {
      "key": "queue_redis_port",
      "type": "number",
      "label": "Redis port",
      "required": false,
      "section": {
        "key": "queue",
        "title": "Queue Mode",
        "toggle": "queue_enabled",
        "needs": "database_enabled=true",
        "description": "Enable queue mode with Redis for scaled deployments"
      },
      "source_type": "int",
      "default": 6379,
      "description": "Redis port",
      "needs": "queue_enabled"
    },
    {
      "key": "queue_embedded_worker",
      "type": "boolean",
      "label": "Include embedded worker in this deployment",
      "required": false,
      "section": {
        "key": "queue",
        "title": "Queue Mode",
        "toggle": "queue_enabled",
        "needs": "database_enabled=true",
        "description": "Enable queue mode with Redis for scaled deployments"
      },
      "source_type": "bool",
      "default": false,
      "description": "Include embedded worker in this deployment",
      "needs": "queue_enabled",
      "extra": "Add a worker service to this compose file. For production, use separate n8n-worker template."
    },
    {
      "key": "database_enabled",
      "type": "boolean",
      "label": "Use external database",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database",
        "toggle": "database_enabled",
        "description": "External database configuration"
      },
      "source_type": "bool",
      "default": false,
      "description": "Use external database"
    },
    {
      "key": "database_type",
      "type": "string",
      "label": "Database type",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database",
        "toggle": "database_enabled",
        "description": "External database configuration"
      },
      "source_type": "enum",
      "default": "postgres",
      "description": "Database type",
      "needs": "database_enabled",
      "options": [
        "postgres",
        "mysql"
      ]
    },
    {
      "key": "database_host",
      "type": "string",
      "label": "Database host",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database",
        "toggle": "database_enabled",
        "description": "External database configuration"
      },
      "source_type": "str",
      "default": "postgres",
      "description": "Database host",
      "needs": "database_enabled"
    },
    {
      "key": "database_port",
      "type": "number",
      "label": "Database port",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database",
        "toggle": "database_enabled",
        "description": "External database configuration"
      },
      "source_type": "int",
      "default": 5432,
      "description": "Database port",
      "needs": "database_enabled"
    },
    {
      "key": "database_name",
      "type": "string",
      "label": "Database name",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database",
        "toggle": "database_enabled",
        "description": "External database configuration"
      },
      "source_type": "str",
      "default": "n8n",
      "description": "Database name",
      "needs": "database_enabled"
    },
    {
      "key": "database_user",
      "type": "string",
      "label": "Database username",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database",
        "toggle": "database_enabled",
        "description": "External database configuration"
      },
      "source_type": "str",
      "default": "n8n",
      "description": "Database username",
      "needs": "database_enabled"
    },
    {
      "key": "database_password",
      "type": "string",
      "label": "Database password",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database",
        "toggle": "database_enabled",
        "description": "External database configuration"
      },
      "source_type": "str",
      "description": "Database password",
      "needs": "database_enabled",
      "sensitive": true
    },
    {
      "key": "database_external",
      "type": "boolean",
      "label": "Use external database",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database",
        "toggle": "database_enabled",
        "description": "External database configuration"
      },
      "source_type": "bool",
      "default": false,
      "description": "Use external database"
    },
    {
      "key": "encryption_key",
      "type": "string",
      "label": "N8N encryption key for credentials",
      "required": false,
      "section": {
        "key": "security",
        "title": "Security"
      },
      "source_type": "str",
      "description": "N8N encryption key for credentials",
      "extra": "Keep this secure! Used to encrypt stored credentials.",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "proxy_hops",
      "type": "number",
      "label": "Number of proxy hops (X-Forwarded-For)",
      "required": false,
      "section": {
        "key": "security",
        "title": "Security"
      },
      "source_type": "int",
      "default": 1,
      "description": "Number of proxy hops (X-Forwarded-For)",
      "extra": "Set to 2 if behind multiple proxies (e.g., Cloudflare + Traefik)"
    },
    {
      "key": "webhook_url",
      "type": "string",
      "label": "Webhook base URL",
      "required": false,
      "section": {
        "key": "webhooks",
        "title": "Webhooks",
        "description": "Webhook configuration for external triggers"
      },
      "source_type": "url",
      "default": "",
      "description": "Webhook base URL",
      "extra": "Optional separate webhook URL (e.g., https://webhooks.example.com/)"
    },
    {
      "key": "metrics_enabled",
      "type": "boolean",
      "label": "Enable Prometheus metrics",
      "required": false,
      "section": {
        "key": "metrics",
        "title": "Metrics",
        "toggle": "metrics_enabled",
        "description": "Prometheus metrics configuration"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Prometheus metrics"
    },
    {
      "key": "metrics_detailed",
      "type": "boolean",
      "label": "Include detailed metrics (workflows, nodes, API endpoints)",
      "required": false,
      "section": {
        "key": "metrics",
        "title": "Metrics",
        "toggle": "metrics_enabled",
        "description": "Prometheus metrics configuration"
      },
      "source_type": "bool",
      "default": false,
      "description": "Include detailed metrics (workflows, nodes, API endpoints)",
      "needs": "metrics_enabled"
    },
    {
      "key": "execution_save_on_error",
      "type": "string",
      "label": "Save execution data on error",
      "required": false,
      "section": {
        "key": "execution",
        "title": "Execution Settings"
      },
      "source_type": "enum",
      "default": "all",
      "description": "Save execution data on error",
      "options": [
        "all",
        "none"
      ]
    },
    {
      "key": "execution_save_on_success",
      "type": "string",
      "label": "Save execution data on success",
      "required": false,
      "section": {
        "key": "execution",
        "title": "Execution Settings"
      },
      "source_type": "enum",
      "default": "none",
      "description": "Save execution data on success",
      "extra": "Set to 'none' to reduce database size",
      "options": [
        "all",
        "none"
      ]
    },
    {
      "key": "network_mode",
      "type": "string",
      "label": "Network Mode",
      "required": false,
      "section": {
        "key": "network"
      },
      "source_type": "str",
      "extra": "For queue mode with workers, use 'bridge' with shared networks. Swarm only supports 'bridge'."
    },
    {
      "key": "network_name",
      "type": "string",
      "label": "Network Name",
      "required": false,
      "section": {
        "key": "network"
      },
      "source_type": "str",
      "default": "n8n_network"
    },
    {
      "key": "network_external",
      "type": "boolean",
      "label": "Whether the network is external",
      "required": false,
      "section": {
        "key": "network"
      },
      "source_type": "bool",
      "default": false,
      "description": "Whether the network is external"
    },
    {
      "key": "traefik_enabled",
      "type": "string",
      "label": "Traefik Enabled",
      "required": false,
      "section": {
        "key": "traefik",
        "toggle": "traefik_enabled"
      },
      "source_type": "str",
      "needs": "network_mode=bridge"
    },
    {
      "key": "traefik_host",
      "type": "string",
      "label": "Traefik Host",
      "required": false,
      "section": {
        "key": "traefik",
        "toggle": "traefik_enabled"
      },
      "source_type": "str",
      "default": "n8n.home.arpa"
    },
    {
      "key": "traefik_webhook_host",
      "type": "string",
      "label": "Separate hostname for webhooks (optional)",
      "required": false,
      "section": {
        "key": "traefik",
        "toggle": "traefik_enabled"
      },
      "source_type": "hostname",
      "default": "",
      "description": "Separate hostname for webhooks (optional)",
      "needs": "traefik_enabled",
      "extra": "Leave empty to use same host for webhooks"
    },
    {
      "key": "traefik_network",
      "type": "string",
      "label": "Traefik network name",
      "required": false,
      "section": {
        "key": "traefik",
        "toggle": "traefik_enabled"
      },
      "source_type": "str",
      "default": "traefik",
      "description": "Traefik network name",
      "needs": "traefik_enabled"
    },
    {
      "key": "traefik_network_external",
      "type": "boolean",
      "label": "Use external Traefik network",
      "required": false,
      "section": {
        "key": "traefik",
        "toggle": "traefik_enabled"
      },
      "source_type": "bool",
      "default": true,
      "description": "Use external Traefik network",
      "needs": "traefik_enabled"
    },
    {
      "key": "traefik_domain",
      "type": "string",
      "label": "Traefik Domain",
      "required": true,
      "section": {
        "key": "traefik",
        "toggle": "traefik_enabled"
      },
      "source_type": "str",
      "default": "home.arpa"
    },
    {
      "key": "ports_http",
      "type": "number",
      "label": "External HTTP port",
      "required": false,
      "section": {
        "key": "ports"
      },
      "source_type": "int",
      "default": 5678,
      "description": "External HTTP port",
      "needs": [
        "traefik_enabled=false",
        "network_mode=bridge"
      ]
    },
    {
      "key": "swarm_enabled",
      "type": "string",
      "label": "Swarm Enabled",
      "required": false,
      "section": {
        "key": "swarm",
        "toggle": "swarm_enabled"
      },
      "source_type": "str",
      "needs": "network_mode=bridge"
    },
    {
      "key": "swarm_replicas",
      "type": "number",
      "label": "Number of server replicas",
      "required": false,
      "section": {
        "key": "swarm",
        "toggle": "swarm_enabled"
      },
      "source_type": "int",
      "default": 1,
      "description": "Number of server replicas",
      "needs": "swarm_enabled",
      "extra": "For HA, set > 1 (requires queue mode)"
    },
    {
      "key": "swarm_placement_host",
      "type": "string",
      "label": "Target hostname for placement constraint",
      "required": false,
      "section": {
        "key": "swarm",
        "toggle": "swarm_enabled"
      },
      "source_type": "str",
      "default": "",
      "description": "Target hostname for placement constraint",
      "extra": "Constrains service to run on specific node by hostname"
    },
    {
      "key": "swarm_placement_mode",
      "type": "string",
      "label": "The placement mode",
      "required": false,
      "section": {
        "key": "swarm",
        "toggle": "swarm_enabled"
      },
      "source_type": "str",
      "default": "replicated",
      "description": "The placement mode"
    },
    {
      "key": "traefik_tls_certresolver",
      "type": "string",
      "label": "Traefik Tls Certresolver",
      "required": true,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "str",
      "default": "cloudflare"
    },
    {
      "key": "traefik_tls_enabled",
      "type": "boolean",
      "label": "Enable Traefik TLS",
      "required": false,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik TLS"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
