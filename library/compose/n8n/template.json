{
  "version": "1",
  "slug": "n8n",
  "kind": "compose",
  "metadata": {
    "name": "N8N",
    "description": "N8n is a free and source-available workflow automation tool. It enables you to connect\nvarious apps and services to automate repetitive tasks without coding.\nWith its user-friendly interface, you can create complex workflows by simply dragging\nand dropping nodes that represent different actions and triggers.\n## Prerequisites\n- :info: By default, n8n uses SQLite as its database, which is suitable for small-scale or\npersonal use. For production environments, it is recommended to use an external\ndatabase like PostgreSQL or MySQL for better performance and reliability. This is also\nrequired when using Queue Mode.\n- :info: Queue mode allows n8n to handle a large number of workflows and tasks efficiently, by using\nmultiple Workers, and Redis as the queue backend. This is essential for high-availability\nsetups where multiple n8n instances work together. It also supports Queue Monitoring\n(when Prometheus metrics are enabled).\n## Resources\n- **Project**: https://n8n.io/\n- **Documentation**: https://docs.n8n.io/\n- **GitHub**: https://github.com/n8n-io/n8n\n",
    "tags": [
      "traefik",
      "database"
    ],
    "author": "Christian Lempa",
    "template_version": "8-alpine",
    "icon": {
      "provider": "simple-icons",
      "id": "n8n"
    },
    "date": "2025-12-17",
    "draft": true
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "n8n"
        },
        {
          "name": "container_name",
          "type": "str",
          "title": "Container Name",
          "required": false,
          "default": "n8n-server"
        },
        {
          "name": "container_hostname",
          "type": "str",
          "title": "Container Hostname",
          "required": false,
          "default": "n8n-server"
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false
        },
        {
          "name": "container_loglevel",
          "type": "str",
          "title": "Container Loglevel",
          "required": false,
          "options": [
            "debug",
            "info",
            "warn",
            "error"
          ]
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "Traefik Tls Entrypoint",
          "required": false,
          "default": ""
        },
        {
          "name": "database_password_secret_name",
          "type": "str",
          "title": "Database Password Secret Name",
          "required": false,
          "default": ""
        },
        {
          "name": "encryption_key_secret_name",
          "type": "str",
          "title": "Encryption Key Secret Name",
          "required": false,
          "default": ""
        },
        {
          "name": "traefik_entrypoint",
          "type": "str",
          "title": "Traefik Entrypoint",
          "required": false,
          "default": ""
        }
      ]
    },
    {
      "key": "queue",
      "title": "Queue Mode",
      "variables": [
        {
          "name": "queue_enabled",
          "type": "bool",
          "title": "Enable queue mode (requires Redis)",
          "required": false,
          "default": false,
          "description": "Enable queue mode (requires Redis)"
        },
        {
          "name": "queue_redis_external",
          "type": "bool",
          "title": "Use external Redis instance",
          "required": false,
          "default": false,
          "description": "Use external Redis instance",
          "needs": [
            "queue_enabled"
          ]
        },
        {
          "name": "queue_redis_host",
          "type": "str",
          "title": "Redis host",
          "required": false,
          "default": "redis",
          "description": "Redis host",
          "needs": [
            "queue_enabled"
          ]
        },
        {
          "name": "queue_redis_port",
          "type": "int",
          "title": "Redis port",
          "required": false,
          "default": 6379,
          "description": "Redis port",
          "needs": [
            "queue_enabled"
          ]
        },
        {
          "name": "queue_embedded_worker",
          "type": "bool",
          "title": "Include embedded worker in this deployment",
          "required": false,
          "default": false,
          "description": "Include embedded worker in this deployment",
          "needs": [
            "queue_enabled"
          ]
        }
      ]
    },
    {
      "key": "database",
      "title": "Database",
      "variables": [
        {
          "name": "database_enabled",
          "type": "bool",
          "title": "Use external database",
          "required": false,
          "default": false,
          "description": "Use external database"
        },
        {
          "name": "database_type",
          "type": "str",
          "title": "Database type",
          "required": false,
          "default": "postgres",
          "description": "Database type",
          "options": [
            "postgres",
            "mysql"
          ],
          "needs": [
            "database_enabled"
          ]
        },
        {
          "name": "database_host",
          "type": "str",
          "title": "Database host",
          "required": false,
          "default": "postgres",
          "description": "Database host",
          "needs": [
            "database_enabled"
          ]
        },
        {
          "name": "database_port",
          "type": "int",
          "title": "Database port",
          "required": false,
          "default": 5432,
          "description": "Database port",
          "needs": [
            "database_enabled"
          ]
        },
        {
          "name": "database_name",
          "type": "str",
          "title": "Database name",
          "required": false,
          "default": "n8n",
          "description": "Database name",
          "needs": [
            "database_enabled"
          ]
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database username",
          "required": false,
          "default": "n8n",
          "description": "Database username",
          "needs": [
            "database_enabled"
          ]
        },
        {
          "name": "database_password",
          "type": "str",
          "title": "Database password",
          "required": false,
          "description": "Database password",
          "sensitive": true,
          "needs": [
            "database_enabled"
          ]
        },
        {
          "name": "database_external",
          "type": "bool",
          "title": "Use external database",
          "required": false,
          "default": false,
          "description": "Use external database"
        }
      ]
    },
    {
      "key": "security",
      "title": "Security",
      "variables": [
        {
          "name": "encryption_key",
          "type": "str",
          "title": "N8N encryption key for credentials",
          "required": false,
          "description": "N8N encryption key for credentials",
          "sensitive": true,
          "autogenerated": true
        },
        {
          "name": "proxy_hops",
          "type": "int",
          "title": "Number of proxy hops (X-Forwarded-For)",
          "required": false,
          "default": 1,
          "description": "Number of proxy hops (X-Forwarded-For)"
        }
      ]
    },
    {
      "key": "webhooks",
      "title": "Webhooks",
      "variables": [
        {
          "name": "webhook_url",
          "type": "str",
          "title": "Webhook base URL",
          "required": false,
          "default": "",
          "description": "Webhook base URL"
        }
      ]
    },
    {
      "key": "metrics",
      "title": "Metrics",
      "variables": [
        {
          "name": "metrics_enabled",
          "type": "bool",
          "title": "Enable Prometheus metrics",
          "required": false,
          "default": false,
          "description": "Enable Prometheus metrics"
        },
        {
          "name": "metrics_detailed",
          "type": "bool",
          "title": "Include detailed metrics (workflows, nodes, API endpoints)",
          "required": false,
          "default": false,
          "description": "Include detailed metrics (workflows, nodes, API endpoints)",
          "needs": [
            "metrics_enabled"
          ]
        }
      ]
    },
    {
      "key": "execution",
      "title": "Execution Settings",
      "variables": [
        {
          "name": "execution_save_on_error",
          "type": "str",
          "title": "Save execution data on error",
          "required": false,
          "default": "all",
          "description": "Save execution data on error",
          "options": [
            "all",
            "none"
          ]
        },
        {
          "name": "execution_save_on_success",
          "type": "str",
          "title": "Save execution data on success",
          "required": false,
          "default": "none",
          "description": "Save execution data on success",
          "options": [
            "all",
            "none"
          ]
        }
      ]
    },
    {
      "key": "network",
      "title": "Network",
      "variables": [
        {
          "name": "network_mode",
          "type": "str",
          "title": "Network Mode",
          "required": false
        },
        {
          "name": "network_name",
          "type": "str",
          "title": "Network Name",
          "required": false,
          "default": "n8n_network"
        },
        {
          "name": "network_external",
          "type": "bool",
          "title": "Whether the network is external",
          "required": false,
          "default": false,
          "description": "Whether the network is external"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_enabled",
          "type": "str",
          "title": "Traefik Enabled",
          "required": false,
          "needs": [
            "network_mode=bridge"
          ]
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "n8n.home.arpa"
        },
        {
          "name": "traefik_webhook_host",
          "type": "str",
          "title": "Separate hostname for webhooks (optional)",
          "required": false,
          "default": "",
          "description": "Separate hostname for webhooks (optional)",
          "needs": [
            "traefik_enabled"
          ]
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik network name",
          "required": false,
          "default": "traefik",
          "description": "Traefik network name",
          "needs": [
            "traefik_enabled"
          ]
        },
        {
          "name": "traefik_network_external",
          "type": "bool",
          "title": "Use external Traefik network",
          "required": false,
          "default": true,
          "description": "Use external Traefik network",
          "needs": [
            "traefik_enabled"
          ]
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik Domain",
          "required": true,
          "default": "home.arpa"
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_http",
          "type": "int",
          "title": "External HTTP port",
          "required": false,
          "default": 5678,
          "description": "External HTTP port",
          "needs": [
            "traefik_enabled=false",
            "network_mode=bridge"
          ]
        }
      ]
    },
    {
      "key": "swarm",
      "title": "Swarm",
      "variables": [
        {
          "name": "swarm_enabled",
          "type": "str",
          "title": "Swarm Enabled",
          "required": false,
          "needs": [
            "network_mode=bridge"
          ]
        },
        {
          "name": "swarm_replicas",
          "type": "int",
          "title": "Number of server replicas",
          "required": false,
          "default": 1,
          "description": "Number of server replicas",
          "needs": [
            "swarm_enabled"
          ]
        },
        {
          "name": "swarm_placement_host",
          "type": "str",
          "title": "Target hostname for placement constraint",
          "required": false,
          "default": "",
          "description": "Target hostname for placement constraint"
        },
        {
          "name": "swarm_placement_mode",
          "type": "str",
          "title": "The placement mode",
          "required": false,
          "default": "replicated",
          "description": "The placement mode"
        }
      ]
    },
    {
      "key": "traefik-tls",
      "title": "Traefik TLS",
      "variables": [
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik Tls Certresolver",
          "required": true,
          "default": "cloudflare"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable Traefik TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
