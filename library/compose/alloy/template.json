{
  "version": "1",
  "slug": "alloy",
  "kind": "compose",
  "metadata": {
    "name": "Grafana Alloy",
    "description": "Grafana Alloy is an open telemetry collector that collects, processes, and exports metrics to various backends.\n## Prerequisites\n- :warning: When alloy runs in a container, you should set the `container_hostname` to a unique value to identify\nthe instance in your monitoring backend. Otherwise it defaults to the container ID.\n## Resources\n- **Project**: https://grafana.com/oss/alloy/\n- **Documentation**: https://grafana.com/docs/alloy/latest/\n- **GitHub**: https://github.com/grafana/alloy",
    "tags": [
      "traefik"
    ],
    "author": "Christian Lempa",
    "template_version": "v1.13.1",
    "date": "2026-02-16",
    "icon": {
      "provider": "simple-icons",
      "id": "grafana"
    },
    "next_steps": null
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "alloy"
        },
        {
          "name": "container_hostname",
          "type": "str",
          "title": "Container internal hostname",
          "required": false,
          "description": "Container internal hostname"
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Container restart policy",
          "required": true,
          "default": "unless-stopped",
          "description": "Container restart policy",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        }
      ]
    },
    {
      "key": "logs",
      "title": "Log Collection",
      "variables": [
        {
          "name": "logs_docker",
          "type": "bool",
          "title": "Enable Docker container log collection",
          "required": false,
          "default": true,
          "description": "Enable Docker container log collection"
        },
        {
          "name": "logs_enabled",
          "type": "bool",
          "title": "Enable log collection",
          "required": false,
          "default": false,
          "description": "Enable log collection"
        },
        {
          "name": "logs_loki_url",
          "type": "str",
          "title": "Loki endpoint URL for sending logs",
          "required": true,
          "default": "http://loki:3100/loki/api/v1/push",
          "description": "Loki endpoint URL for sending logs"
        },
        {
          "name": "logs_system",
          "type": "bool",
          "title": "Enable system and journalctl log collection",
          "required": false,
          "default": true,
          "description": "Enable system and journalctl log collection"
        }
      ]
    },
    {
      "key": "metrics",
      "title": "Metrics Collection",
      "variables": [
        {
          "name": "metrics_docker",
          "type": "bool",
          "title": "Enable Docker container metrics collection (cAdvisor)",
          "required": false,
          "default": true,
          "description": "Enable Docker container metrics collection (cAdvisor)"
        },
        {
          "name": "metrics_enabled",
          "type": "bool",
          "title": "Enable metrics collection",
          "required": false,
          "default": false,
          "description": "Enable metrics collection"
        },
        {
          "name": "metrics_prometheus_url",
          "type": "str",
          "title": "Prometheus remote write endpoint",
          "required": true,
          "default": "http://prometheus:9090/api/v1/write",
          "description": "Prometheus remote write endpoint"
        },
        {
          "name": "metrics_system",
          "type": "bool",
          "title": "Enable system (node) metrics collection",
          "required": false,
          "default": true,
          "description": "Enable system (node) metrics collection"
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_webui",
          "type": "int",
          "title": "Port for Alloy web UI",
          "required": false,
          "default": 12345,
          "description": "Port for Alloy web UI"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik reverse proxy integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik reverse proxy integration"
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik network name",
          "required": true,
          "default": "traefik",
          "description": "Traefik network name"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "alloy"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Base domain (e.g., example.com)",
          "required": true,
          "default": "home.arpa",
          "description": "Base domain (e.g., example.com)"
        }
      ]
    },
    {
      "key": "traefik-tls",
      "title": "Traefik TLS/SSL",
      "variables": [
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable HTTPS/TLS",
          "required": false,
          "default": true,
          "description": "Enable HTTPS/TLS"
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik certificate resolver name",
          "required": true,
          "default": "cloudflare",
          "description": "Traefik certificate resolver name"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
