{
  "version": "1",
  "slug": "alloy",
  "kind": "compose",
  "metadata": {
    "name": "Grafana Alloy",
    "description": "Grafana Alloy is an open telemetry collector that collects, processes, and exports metrics to various backends.\n## Prerequisites\n- :warning: When alloy runs in a container, you should set the `container_hostname` to a unique value to identify\nthe instance in your monitoring backend. Otherwise it defaults to the container ID.\n## Resources\n- **Project**: https://grafana.com/oss/alloy/\n- **Documentation**: https://grafana.com/docs/alloy/latest/\n- **GitHub**: https://github.com/grafana/alloy",
    "tags": [
      "traefik"
    ],
    "author": "Christian Lempa",
    "template_version": "v1.13.1",
    "date": "2026-02-16",
    "icon": {
      "provider": "selfh",
      "id": "grafana"
    },
    "next_steps": null
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "service_name",
      "type": "string",
      "label": "Service Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "alloy"
    },
    {
      "key": "container_hostname",
      "type": "string",
      "label": "Container internal hostname",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "description": "Container internal hostname"
    },
    {
      "key": "restart_policy",
      "type": "string",
      "label": "Container restart policy",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "enum",
      "default": "unless-stopped",
      "description": "Container restart policy",
      "options": [
        "unless-stopped",
        "always",
        "on-failure",
        "no"
      ]
    },
    {
      "key": "logs_docker",
      "type": "boolean",
      "label": "Enable Docker container log collection",
      "required": false,
      "section": {
        "key": "logs",
        "title": "Log Collection",
        "toggle": "logs_enabled"
      },
      "source_type": "bool",
      "default": true,
      "description": "Enable Docker container log collection"
    },
    {
      "key": "logs_enabled",
      "type": "boolean",
      "label": "Enable log collection",
      "required": false,
      "section": {
        "key": "logs",
        "title": "Log Collection",
        "toggle": "logs_enabled"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable log collection"
    },
    {
      "key": "logs_loki_url",
      "type": "string",
      "label": "Loki endpoint URL for sending logs",
      "required": true,
      "section": {
        "key": "logs",
        "title": "Log Collection",
        "toggle": "logs_enabled"
      },
      "source_type": "url",
      "default": "http://loki:3100/loki/api/v1/push",
      "description": "Loki endpoint URL for sending logs"
    },
    {
      "key": "logs_system",
      "type": "boolean",
      "label": "Enable system and journalctl log collection",
      "required": false,
      "section": {
        "key": "logs",
        "title": "Log Collection",
        "toggle": "logs_enabled"
      },
      "source_type": "bool",
      "default": true,
      "description": "Enable system and journalctl log collection"
    },
    {
      "key": "metrics_docker",
      "type": "boolean",
      "label": "Enable Docker container metrics collection (cAdvisor)",
      "required": false,
      "section": {
        "key": "metrics",
        "title": "Metrics Collection",
        "toggle": "metrics_enabled"
      },
      "source_type": "bool",
      "default": true,
      "description": "Enable Docker container metrics collection (cAdvisor)"
    },
    {
      "key": "metrics_enabled",
      "type": "boolean",
      "label": "Enable metrics collection",
      "required": false,
      "section": {
        "key": "metrics",
        "title": "Metrics Collection",
        "toggle": "metrics_enabled"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable metrics collection"
    },
    {
      "key": "metrics_prometheus_url",
      "type": "string",
      "label": "Prometheus remote write endpoint",
      "required": true,
      "section": {
        "key": "metrics",
        "title": "Metrics Collection",
        "toggle": "metrics_enabled"
      },
      "source_type": "url",
      "default": "http://prometheus:9090/api/v1/write",
      "description": "Prometheus remote write endpoint"
    },
    {
      "key": "metrics_system",
      "type": "boolean",
      "label": "Enable system (node) metrics collection",
      "required": false,
      "section": {
        "key": "metrics",
        "title": "Metrics Collection",
        "toggle": "metrics_enabled"
      },
      "source_type": "bool",
      "default": true,
      "description": "Enable system (node) metrics collection"
    },
    {
      "key": "ports_webui",
      "type": "number",
      "label": "Port for Alloy web UI",
      "required": false,
      "section": {
        "key": "ports",
        "title": "Ports"
      },
      "source_type": "int",
      "default": 12345,
      "description": "Port for Alloy web UI"
    },
    {
      "key": "traefik_enabled",
      "type": "boolean",
      "label": "Enable Traefik reverse proxy integration",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik reverse proxy integration"
    },
    {
      "key": "traefik_network",
      "type": "string",
      "label": "Traefik network name",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled"
      },
      "source_type": "str",
      "default": "traefik",
      "description": "Traefik network name"
    },
    {
      "key": "traefik_host",
      "type": "string",
      "label": "Traefik Host",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled"
      },
      "source_type": "str",
      "default": "alloy"
    },
    {
      "key": "traefik_domain",
      "type": "string",
      "label": "Base domain (e.g., example.com)",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled"
      },
      "source_type": "str",
      "default": "home.arpa",
      "description": "Base domain (e.g., example.com)"
    },
    {
      "key": "traefik_tls_enabled",
      "type": "boolean",
      "label": "Enable HTTPS/TLS",
      "required": false,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS/SSL",
        "toggle": "traefik_tls_enabled"
      },
      "source_type": "bool",
      "default": true,
      "description": "Enable HTTPS/TLS"
    },
    {
      "key": "traefik_tls_certresolver",
      "type": "string",
      "label": "Traefik certificate resolver name",
      "required": true,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS/SSL",
        "toggle": "traefik_tls_enabled"
      },
      "source_type": "str",
      "default": "cloudflare",
      "description": "Traefik certificate resolver name"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
