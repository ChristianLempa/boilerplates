{
  "version": "1",
  "slug": "checkmk",
  "kind": "compose",
  "metadata": {
    "name": "Checkmk",
    "description": "Checkmk is a comprehensive IT monitoring solution that provides real-time insights\ninto the health and performance of your infrastructure, applications, and services.\nIt offers a wide range of monitoring capabilities, including server, network, cloud,\nand application monitoring, with an emphasis on ease of use and scalability.\n## References\n* **Project:** https://checkmk.com/\n* **Documentation:** https://docs.checkmk.com/latest/en/\n* **GitHub:** https://github.com/tribe29/checkmk",
    "tags": [
      "traefik"
    ],
    "author": "Christian Lempa",
    "template_version": "2.4.0-latest",
    "icon": {
      "provider": "simple-icons",
      "id": "checkmk"
    },
    "next_steps": "Log in with your initial admin user:\n```bash\nUsername: cmkadmin\nPassword: {{ cmk_password }}\n```",
    "date": "2025-12-10"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "checkmk"
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false
        },
        {
          "name": "user_uid",
          "type": "int",
          "title": "User Uid",
          "required": false,
          "default": 1000
        },
        {
          "name": "user_gid",
          "type": "int",
          "title": "User Gid",
          "required": false,
          "default": 1000
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        },
        {
          "name": "cmk_password",
          "type": "str",
          "title": "CheckMK admin password",
          "required": true,
          "description": "CheckMK admin password",
          "sensitive": true,
          "autogenerated": true
        },
        {
          "name": "cmk_site_id",
          "type": "str",
          "title": "CheckMK site ID",
          "required": true,
          "default": "cmk",
          "description": "CheckMK site ID"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "checkmk"
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik Network",
          "required": true,
          "default": "traefik"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik Domain",
          "required": true,
          "default": "home.arpa"
        },
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_http",
          "type": "str",
          "title": "Ports Http",
          "required": false,
          "default": 8000
        },
        {
          "name": "ports_agent",
          "type": "int",
          "title": "Agent port",
          "required": true,
          "default": 5000,
          "description": "Agent port"
        },
        {
          "name": "ports_snmp",
          "type": "int",
          "title": "SNMP trap port",
          "required": true,
          "default": 162,
          "description": "SNMP trap port"
        }
      ]
    },
    {
      "key": "traefik-tls",
      "title": "Traefik TLS",
      "variables": [
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik Tls Certresolver",
          "required": true,
          "default": "cloudflare"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable Traefik TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
