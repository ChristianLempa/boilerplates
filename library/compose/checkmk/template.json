{
  "version": "1",
  "slug": "checkmk",
  "kind": "compose",
  "metadata": {
    "name": "Checkmk",
    "description": "Checkmk is a comprehensive IT monitoring solution that provides real-time insights\ninto the health and performance of your infrastructure, applications, and services.\nIt offers a wide range of monitoring capabilities, including server, network, cloud,\nand application monitoring, with an emphasis on ease of use and scalability.\n## References\n* **Project:** https://checkmk.com/\n* **Documentation:** https://docs.checkmk.com/latest/en/\n* **GitHub:** https://github.com/tribe29/checkmk",
    "tags": [
      "traefik"
    ],
    "author": "Christian Lempa",
    "template_version": "2.4.0-latest",
    "icon": {
      "provider": "selfh",
      "id": "checkmk"
    },
    "next_steps": "Log in with your initial admin user:\n```bash\nUsername: cmkadmin\nPassword: {{ cmk_password }}\n```",
    "date": "2025-12-10"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "service_name",
      "type": "string",
      "label": "Service Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "checkmk"
    },
    {
      "key": "container_timezone",
      "type": "string",
      "label": "Container Timezone",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str"
    },
    {
      "key": "user_uid",
      "type": "number",
      "label": "User Uid",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "int",
      "default": 1000
    },
    {
      "key": "user_gid",
      "type": "number",
      "label": "User Gid",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "int",
      "default": 1000
    },
    {
      "key": "restart_policy",
      "type": "string",
      "label": "Restart Policy",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "enum",
      "default": "unless-stopped",
      "options": [
        "unless-stopped",
        "always",
        "on-failure",
        "no"
      ]
    },
    {
      "key": "cmk_password",
      "type": "string",
      "label": "CheckMK admin password",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "description": "CheckMK admin password",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "cmk_site_id",
      "type": "string",
      "label": "CheckMK site ID",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "cmk",
      "description": "CheckMK site ID"
    },
    {
      "key": "traefik_host",
      "type": "string",
      "label": "Traefik Host",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "checkmk"
    },
    {
      "key": "traefik_network",
      "type": "string",
      "label": "Traefik Network",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "traefik"
    },
    {
      "key": "traefik_domain",
      "type": "string",
      "label": "Traefik Domain",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "home.arpa"
    },
    {
      "key": "traefik_enabled",
      "type": "boolean",
      "label": "Enable Traefik integration",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik integration"
    },
    {
      "key": "ports_http",
      "type": "string",
      "label": "Ports Http",
      "required": false,
      "section": {
        "key": "ports"
      },
      "source_type": "str",
      "default": 8000
    },
    {
      "key": "ports_agent",
      "type": "number",
      "label": "Agent port",
      "required": true,
      "section": {
        "key": "ports"
      },
      "source_type": "int",
      "default": 5000,
      "description": "Agent port"
    },
    {
      "key": "ports_snmp",
      "type": "number",
      "label": "SNMP trap port",
      "required": true,
      "section": {
        "key": "ports"
      },
      "source_type": "int",
      "default": 162,
      "description": "SNMP trap port"
    },
    {
      "key": "traefik_tls_certresolver",
      "type": "string",
      "label": "Traefik Tls Certresolver",
      "required": true,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "str",
      "default": "cloudflare"
    },
    {
      "key": "traefik_tls_enabled",
      "type": "boolean",
      "label": "Enable Traefik TLS",
      "required": false,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik TLS"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
