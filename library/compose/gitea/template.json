{
  "version": "1",
  "slug": "gitea",
  "kind": "compose",
  "metadata": {
    "name": "Gitea",
    "description": "Self-hosted Git service with web interface. Gitea is a painless, self-hosted Git service\nwritten in Go. It's similar to GitHub, Bitbucket, and GitLab, providing Git repository\nhosting, code review, team collaboration, and more.\n## Prerequisites\n- :info: Gitea supports multiple database backends. You can choose between SQLite (default),\nPostgreSQL, or MySQL. SQLite is suitable for small deployments, while PostgreSQL and MySQL\nare recommended for larger installations.\n## References\n- **Project:** https://gitea.io/\n- **Documentation:** https://docs.gitea.io/\n- **GitHub:** https://github.com/go-gitea/gitea",
    "tags": [
      "traefik"
    ],
    "author": "Christian Lempa",
    "template_version": "1.25.4",
    "icon": {
      "provider": "selfh",
      "id": "gitea"
    },
    "date": "2026-01-22"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "service_name",
      "type": "string",
      "label": "Service Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "gitea"
    },
    {
      "key": "container_timezone",
      "type": "string",
      "label": "Container Timezone",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str"
    },
    {
      "key": "user_uid",
      "type": "number",
      "label": "User Uid",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "int",
      "default": 1000
    },
    {
      "key": "user_gid",
      "type": "number",
      "label": "User Gid",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "int",
      "default": 1000
    },
    {
      "key": "restart_policy",
      "type": "string",
      "label": "Restart Policy",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "enum",
      "default": "unless-stopped",
      "options": [
        "unless-stopped",
        "always",
        "on-failure",
        "no"
      ]
    },
    {
      "key": "gitea_url",
      "type": "string",
      "label": "Public URL",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "https://git.example.com",
      "description": "Public URL",
      "needs": [
        "traefik_enabled=false"
      ]
    },
    {
      "key": "database_type",
      "type": "string",
      "label": "Database backend type",
      "required": false,
      "section": {
        "key": "database"
      },
      "source_type": "enum",
      "default": "sqlite",
      "description": "Database backend type",
      "options": [
        "sqlite",
        "postgres",
        "mysql"
      ]
    },
    {
      "key": "database_name",
      "type": "string",
      "label": "Database name",
      "required": false,
      "section": {
        "key": "database"
      },
      "source_type": "str",
      "default": "gitea",
      "description": "Database name",
      "needs": [
        "database_type=postgres,mysql"
      ]
    },
    {
      "key": "database_user",
      "type": "string",
      "label": "Database user",
      "required": false,
      "section": {
        "key": "database"
      },
      "source_type": "str",
      "default": "gitea",
      "description": "Database user",
      "needs": [
        "database_type=postgres,mysql"
      ]
    },
    {
      "key": "database_host",
      "type": "string",
      "label": "Database host",
      "required": false,
      "section": {
        "key": "database"
      },
      "source_type": "str",
      "default": "postgres",
      "description": "Database host",
      "needs": [
        "database_type=postgres,mysql;database_external=true"
      ]
    },
    {
      "key": "database_password",
      "type": "string",
      "label": "Database password",
      "required": false,
      "section": {
        "key": "database"
      },
      "source_type": "str",
      "description": "Database password",
      "needs": [
        "database_type=postgres,mysql"
      ],
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "database_external",
      "type": "boolean",
      "label": "Use external database",
      "required": false,
      "section": {
        "key": "database"
      },
      "source_type": "bool",
      "default": false,
      "description": "Use external database",
      "needs": [
        "database_type=postgres,mysql"
      ]
    },
    {
      "key": "ports_http",
      "type": "string",
      "label": "Ports Http",
      "required": false,
      "section": {
        "key": "ports"
      },
      "source_type": "str",
      "default": 3000
    },
    {
      "key": "ports_ssh",
      "type": "string",
      "label": "Ports Ssh",
      "required": false,
      "section": {
        "key": "ports"
      },
      "source_type": "str",
      "default": 2221
    },
    {
      "key": "traefik_host",
      "type": "string",
      "label": "Traefik Host",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "gitea"
    },
    {
      "key": "traefik_network",
      "type": "string",
      "label": "Traefik Network",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "traefik"
    },
    {
      "key": "traefik_domain",
      "type": "string",
      "label": "Traefik Domain",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "home.arpa"
    },
    {
      "key": "traefik_enabled",
      "type": "boolean",
      "label": "Enable Traefik integration",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik integration"
    },
    {
      "key": "traefik_tls_certresolver",
      "type": "string",
      "label": "Traefik Tls Certresolver",
      "required": true,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "str",
      "default": "cloudflare"
    },
    {
      "key": "traefik_tls_enabled",
      "type": "boolean",
      "label": "Enable Traefik TLS",
      "required": false,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik TLS"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
