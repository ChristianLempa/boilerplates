{
  "version": "1",
  "slug": "gitea",
  "kind": "compose",
  "metadata": {
    "name": "Gitea",
    "description": "Self-hosted Git service with web interface. Gitea is a painless, self-hosted Git service\nwritten in Go. It's similar to GitHub, Bitbucket, and GitLab, providing Git repository\nhosting, code review, team collaboration, and more.\n## Prerequisites\n- :info: Gitea supports multiple database backends. You can choose between SQLite (default),\nPostgreSQL, or MySQL. SQLite is suitable for small deployments, while PostgreSQL and MySQL\nare recommended for larger installations.\n## References\n- **Project:** https://gitea.io/\n- **Documentation:** https://docs.gitea.io/\n- **GitHub:** https://github.com/go-gitea/gitea",
    "tags": [
      "traefik"
    ],
    "author": "Christian Lempa",
    "template_version": "1.25.4",
    "icon": {
      "provider": "simple-icons",
      "id": "gitea"
    },
    "date": "2026-01-22"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "gitea"
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false
        },
        {
          "name": "user_uid",
          "type": "int",
          "title": "User Uid",
          "required": false,
          "default": 1000
        },
        {
          "name": "user_gid",
          "type": "int",
          "title": "User Gid",
          "required": false,
          "default": 1000
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        },
        {
          "name": "gitea_url",
          "type": "str",
          "title": "Public URL",
          "required": false,
          "default": "https://git.example.com",
          "description": "Public URL",
          "needs": [
            "traefik_enabled=false"
          ]
        }
      ]
    },
    {
      "key": "database",
      "title": "Database",
      "variables": [
        {
          "name": "database_type",
          "type": "str",
          "title": "Database backend type",
          "required": false,
          "default": "sqlite",
          "description": "Database backend type",
          "options": [
            "sqlite",
            "postgres",
            "mysql"
          ]
        },
        {
          "name": "database_name",
          "type": "str",
          "title": "Database name",
          "required": false,
          "default": "gitea",
          "description": "Database name",
          "needs": [
            "database_type=postgres,mysql"
          ]
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database user",
          "required": false,
          "default": "gitea",
          "description": "Database user",
          "needs": [
            "database_type=postgres,mysql"
          ]
        },
        {
          "name": "database_host",
          "type": "str",
          "title": "Database host",
          "required": false,
          "default": "postgres",
          "description": "Database host",
          "needs": [
            "database_type=postgres,mysql;database_external=true"
          ]
        },
        {
          "name": "database_password",
          "type": "str",
          "title": "Database password",
          "required": false,
          "description": "Database password",
          "sensitive": true,
          "autogenerated": true,
          "needs": [
            "database_type=postgres,mysql"
          ]
        },
        {
          "name": "database_external",
          "type": "bool",
          "title": "Use external database",
          "required": false,
          "default": false,
          "description": "Use external database",
          "needs": [
            "database_type=postgres,mysql"
          ]
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_http",
          "type": "str",
          "title": "Ports Http",
          "required": false,
          "default": 3000
        },
        {
          "name": "ports_ssh",
          "type": "str",
          "title": "Ports Ssh",
          "required": false,
          "default": 2221
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "gitea"
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik Network",
          "required": true,
          "default": "traefik"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik Domain",
          "required": true,
          "default": "home.arpa"
        },
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        }
      ]
    },
    {
      "key": "traefik-tls",
      "title": "Traefik TLS",
      "variables": [
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik Tls Certresolver",
          "required": true,
          "default": "cloudflare"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable Traefik TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
