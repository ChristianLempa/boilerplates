{
  "version": "1",
  "slug": "influxdb",
  "kind": "compose",
  "metadata": {
    "name": "Influxdb",
    "description": "InfluxDB is a powerful, open-source time series database designed for high-performance handling of time-stamped data.\nIt is commonly used for monitoring, analytics, and IoT applications.\n## References\n* **Project:** https://www.influxdata.com/\n* **Documentation:** https://docs.influxdata.com/influxdb/\n* **GitHub:** https://github.com/influxdata/influxdb",
    "tags": [
      "traefik"
    ],
    "author": "Christian Lempa",
    "template_version": "2.8.0-alpine",
    "icon": {
      "provider": "simple-icons",
      "id": "influxdb"
    },
    "next_steps": "Log in with your initial admin user:\n```bash\nUsername: {{ influxdb_init_username }}\nPassword: {{ influxdb_init_password }}\n```",
    "date": "2025-12-11",
    "draft": true
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_http",
          "type": "int",
          "title": "Host port for HTTP API (8086)",
          "required": false,
          "default": 8086,
          "description": "Host port for HTTP API (8086)"
        }
      ]
    },
    {
      "key": "influxdb",
      "title": "Influxdb",
      "variables": [
        {
          "name": "influxdb_init_username",
          "type": "str",
          "title": "Initial admin username",
          "required": true,
          "default": "admin",
          "description": "Initial admin username"
        },
        {
          "name": "influxdb_init_password",
          "type": "str",
          "title": "Initial admin password",
          "required": true,
          "description": "Initial admin password",
          "sensitive": true,
          "autogenerated": true
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "influxdb"
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik Network",
          "required": true,
          "default": "traefik"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik Domain",
          "required": true,
          "default": "home.arpa"
        },
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        }
      ]
    },
    {
      "key": "traefik-tls",
      "title": "Traefik TLS",
      "variables": [
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik Tls Certresolver",
          "required": true,
          "default": "cloudflare"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable Traefik TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        }
      ]
    },
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "influxdb"
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        },
        {
          "name": "influxdb_version",
          "type": "str",
          "title": "Influxdb version",
          "required": false,
          "default": "latest",
          "description": "Influxdb version"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
