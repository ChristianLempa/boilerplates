{
  "version": "1",
  "slug": "influxdb",
  "kind": "compose",
  "metadata": {
    "name": "Influxdb",
    "description": "InfluxDB is a powerful, open-source time series database designed for high-performance handling of time-stamped data.\nIt is commonly used for monitoring, analytics, and IoT applications.\n## References\n* **Project:** https://www.influxdata.com/\n* **Documentation:** https://docs.influxdata.com/influxdb/\n* **GitHub:** https://github.com/influxdata/influxdb",
    "tags": [
      "traefik"
    ],
    "author": "Christian Lempa",
    "template_version": "2.8.0-alpine",
    "icon": {
      "provider": "selfh",
      "id": "influxdb"
    },
    "next_steps": "Log in with your initial admin user:\n```bash\nUsername: {{ influxdb_init_username }}\nPassword: {{ influxdb_init_password }}\n```",
    "date": "2025-12-11",
    "draft": true
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "ports_http",
      "type": "number",
      "label": "Host port for HTTP API (8086)",
      "required": false,
      "section": {
        "key": "ports"
      },
      "source_type": "int",
      "default": 8086,
      "description": "Host port for HTTP API (8086)"
    },
    {
      "key": "influxdb_init_username",
      "type": "string",
      "label": "Initial admin username",
      "required": true,
      "section": {
        "key": "influxdb",
        "required": true,
        "description": "InfluxDB initialization settings"
      },
      "source_type": "str",
      "default": "admin",
      "description": "Initial admin username"
    },
    {
      "key": "influxdb_init_password",
      "type": "string",
      "label": "Initial admin password",
      "required": true,
      "section": {
        "key": "influxdb",
        "required": true,
        "description": "InfluxDB initialization settings"
      },
      "source_type": "str",
      "description": "Initial admin password",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "traefik_host",
      "type": "string",
      "label": "Traefik Host",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "influxdb"
    },
    {
      "key": "traefik_network",
      "type": "string",
      "label": "Traefik Network",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "traefik"
    },
    {
      "key": "traefik_domain",
      "type": "string",
      "label": "Traefik Domain",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "home.arpa"
    },
    {
      "key": "traefik_enabled",
      "type": "boolean",
      "label": "Enable Traefik integration",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik integration"
    },
    {
      "key": "traefik_tls_certresolver",
      "type": "string",
      "label": "Traefik Tls Certresolver",
      "required": true,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "str",
      "default": "cloudflare"
    },
    {
      "key": "traefik_tls_enabled",
      "type": "boolean",
      "label": "Enable Traefik TLS",
      "required": false,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik TLS"
    },
    {
      "key": "service_name",
      "type": "string",
      "label": "Service Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "influxdb"
    },
    {
      "key": "container_timezone",
      "type": "string",
      "label": "Container Timezone",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str"
    },
    {
      "key": "restart_policy",
      "type": "string",
      "label": "Restart Policy",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "enum",
      "default": "unless-stopped",
      "options": [
        "unless-stopped",
        "always",
        "on-failure",
        "no"
      ]
    },
    {
      "key": "influxdb_version",
      "type": "string",
      "label": "Influxdb version",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "latest",
      "description": "Influxdb version"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
