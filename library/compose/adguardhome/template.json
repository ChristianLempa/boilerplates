{
  "version": "1",
  "slug": "adguardhome",
  "kind": "compose",
  "metadata": {
    "name": "AdGuard Home",
    "description": "Network-wide software for blocking ads and tracking. AdGuard Home operates as a DNS server that\nre-routes tracking domains to a \"black hole\", thus preventing your devices from connecting to those servers.\nIt features advanced DNS filtering, parental controls, safe browsing, and HTTPS/DNS-over-TLS/DNS-over-QUIC support.\n## Prerequisites\n- :info: During the initial setup, AdGuard Home runs an HTTP server on port 3000 to guide you through configuration.\n**With Traefik enabled:** Access initial setup via container IP at `http://<container-ip>:3000`.\nAfter setup completes, access the admin interface via the configured domain.\n- :warning: **Security Notice:** The initial setup on port 3000 uses an unencrypted HTTP connection.\nOnly use this for initial configuration and disable it (`initial_setup=false`) after setup is complete.\n- :warning: If you require DHCP functionality or want AdGuard Home to bind directly to port 53,\nyou must set `network_mode` to `host` or `macvlan`. Note this exposes all container ports directly on the host.\nYou can't use `traefik_enabled` in this case!\n## References\n- **Project:** https://adguard.com/adguard-home/overview.html\n- **Documentation:** https://github.com/AdguardTeam/AdGuardHome/wiki\n- **GitHub:** https://github.com/AdguardTeam/AdGuardHome",
    "tags": [
      "traefik",
      "network",
      "volume"
    ],
    "author": "Christian Lempa",
    "template_version": "v0.107.71",
    "icon": {
      "provider": "simple-icons",
      "id": "adguard"
    },
    "date": "2025-12-11",
    "next_steps": null
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "adguardhome"
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        },
        {
          "name": "initial_setup",
          "type": "bool",
          "title": "Enable initial setup wizard on port 3000 (only used without Traefik)",
          "required": false,
          "default": true,
          "description": "Enable initial setup wizard on port 3000 (only used without Traefik)"
        }
      ]
    },
    {
      "key": "network",
      "title": "Network",
      "variables": [
        {
          "name": "network_mode",
          "type": "str",
          "title": "Network Mode",
          "required": false
        },
        {
          "name": "network_name",
          "type": "str",
          "title": "Network Name",
          "required": false,
          "default": "adguardhome_network"
        },
        {
          "name": "network_macvlan_ipv4_address",
          "type": "str",
          "title": "Network Macvlan Ipv4 Address",
          "required": true,
          "default": "192.168.1.253",
          "needs": [
            "network_mode=macvlan"
          ]
        },
        {
          "name": "network_macvlan_parent_interface",
          "type": "str",
          "title": "Network Macvlan Parent Interface",
          "required": true,
          "default": "eth0",
          "needs": [
            "network_mode=macvlan"
          ]
        },
        {
          "name": "network_macvlan_subnet",
          "type": "str",
          "title": "Network Macvlan Subnet",
          "required": true,
          "default": "192.168.1.0/24",
          "needs": [
            "network_mode=macvlan"
          ]
        },
        {
          "name": "network_macvlan_gateway",
          "type": "str",
          "title": "Network Macvlan Gateway",
          "required": true,
          "default": "192.168.1.1",
          "needs": [
            "network_mode=macvlan"
          ]
        },
        {
          "name": "network_external",
          "type": "bool",
          "title": "Whether the network is external",
          "required": false,
          "default": false,
          "description": "Whether the network is external"
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_http",
          "type": "str",
          "title": "Ports Http",
          "required": false,
          "default": 80
        },
        {
          "name": "ports_https",
          "type": "str",
          "title": "Ports Https",
          "required": false,
          "default": 443
        },
        {
          "name": "ports_dns",
          "type": "int",
          "title": "Ports Dns",
          "required": true,
          "default": 53
        },
        {
          "name": "ports_initial",
          "type": "int",
          "title": "Initial setup wizard port (only when Traefik is disabled)",
          "required": false,
          "default": 3000,
          "description": "Initial setup wizard port (only when Traefik is disabled)",
          "needs": [
            "traefik_enabled=false",
            "initial_setup=true"
          ]
        },
        {
          "name": "ports_tls",
          "type": "int",
          "title": "DNS over TLS Port",
          "required": true,
          "default": 853,
          "description": "DNS over TLS Port"
        },
        {
          "name": "ports_dnscrypt",
          "type": "int",
          "title": "DNSCrypt Port",
          "required": true,
          "default": 5443,
          "description": "DNSCrypt Port"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "adguardhome"
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik Network",
          "required": true,
          "default": "traefik"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik Domain",
          "required": true,
          "default": "home.arpa"
        },
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        }
      ]
    },
    {
      "key": "traefik-tls",
      "title": "Traefik TLS",
      "variables": [
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik Tls Certresolver",
          "required": true,
          "default": "cloudflare"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable Traefik TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        }
      ]
    },
    {
      "key": "volume",
      "title": "Volume",
      "variables": [
        {
          "name": "volume_mode",
          "type": "str",
          "title": "Volume Mode",
          "required": true,
          "default": "local",
          "options": [
            "local",
            "mount",
            "nfs"
          ]
        },
        {
          "name": "volume_mount_path",
          "type": "str",
          "title": "Volume Mount Path",
          "required": true,
          "default": "/mnt/storage",
          "needs": [
            "volume_mode=mount"
          ]
        },
        {
          "name": "volume_nfs_server",
          "type": "str",
          "title": "Volume Nfs Server",
          "required": true,
          "default": "192.168.1.1",
          "needs": [
            "volume_mode=nfs"
          ]
        },
        {
          "name": "volume_nfs_path",
          "type": "str",
          "title": "Volume Nfs Path",
          "required": true,
          "default": "/export",
          "needs": [
            "volume_mode=nfs"
          ]
        },
        {
          "name": "volume_nfs_options",
          "type": "str",
          "title": "Volume Nfs Options",
          "required": true,
          "default": "rw,nolock,soft",
          "needs": [
            "volume_mode=nfs"
          ]
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
