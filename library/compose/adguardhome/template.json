{
  "version": "1",
  "slug": "adguardhome",
  "kind": "compose",
  "metadata": {
    "name": "AdGuard Home",
    "description": "Network-wide software for blocking ads and tracking. AdGuard Home operates as a DNS server that\nre-routes tracking domains to a \"black hole\", thus preventing your devices from connecting to those servers.\nIt features advanced DNS filtering, parental controls, safe browsing, and HTTPS/DNS-over-TLS/DNS-over-QUIC support.\n## Prerequisites\n- :info: During the initial setup, AdGuard Home runs an HTTP server on port 3000 to guide you through configuration.\n**With Traefik enabled:** Access initial setup via container IP at `http://<container-ip>:3000`.\nAfter setup completes, access the admin interface via the configured domain.\n- :warning: **Security Notice:** The initial setup on port 3000 uses an unencrypted HTTP connection.\nOnly use this for initial configuration and disable it (`initial_setup=false`) after setup is complete.\n- :warning: If you require DHCP functionality or want AdGuard Home to bind directly to port 53,\nyou must set `network_mode` to `host` or `macvlan`. Note this exposes all container ports directly on the host.\nYou can't use `traefik_enabled` in this case!\n## References\n- **Project:** https://adguard.com/adguard-home/overview.html\n- **Documentation:** https://github.com/AdguardTeam/AdGuardHome/wiki\n- **GitHub:** https://github.com/AdguardTeam/AdGuardHome",
    "tags": [
      "traefik",
      "network",
      "volume"
    ],
    "author": "Christian Lempa",
    "template_version": "v0.107.71",
    "icon": {
      "provider": "selfh",
      "id": "adguard-home"
    },
    "date": "2025-12-11",
    "next_steps": null
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "service_name",
      "type": "string",
      "label": "Service Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "adguardhome"
    },
    {
      "key": "restart_policy",
      "type": "string",
      "label": "Restart Policy",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "enum",
      "default": "unless-stopped",
      "options": [
        "unless-stopped",
        "always",
        "on-failure",
        "no"
      ]
    },
    {
      "key": "initial_setup",
      "type": "boolean",
      "label": "Enable initial setup wizard on port 3000 (only used without Traefik)",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "bool",
      "default": true,
      "description": "Enable initial setup wizard on port 3000 (only used without Traefik)",
      "extra": "Port 3000 is only used during the initial setup wizard when Traefik is disabled. With Traefik enabled, access setup via container IP instead. After completing setup, AdGuard Home switches to port 80 and port 3000 becomes inactive. "
    },
    {
      "key": "network_mode",
      "type": "string",
      "label": "Network Mode",
      "required": false,
      "section": {
        "key": "network"
      },
      "source_type": "str",
      "extra": "Use 'host' mode if you need DHCP functionality or want AdGuard Home to bind directly to port 53.\n"
    },
    {
      "key": "network_name",
      "type": "string",
      "label": "Network Name",
      "required": false,
      "section": {
        "key": "network"
      },
      "source_type": "str",
      "default": "adguardhome_network"
    },
    {
      "key": "network_macvlan_ipv4_address",
      "type": "string",
      "label": "Network Macvlan Ipv4 Address",
      "required": true,
      "section": {
        "key": "network"
      },
      "source_type": "str",
      "default": "192.168.1.253",
      "needs": [
        "network_mode=macvlan"
      ]
    },
    {
      "key": "network_macvlan_parent_interface",
      "type": "string",
      "label": "Network Macvlan Parent Interface",
      "required": true,
      "section": {
        "key": "network"
      },
      "source_type": "str",
      "default": "eth0",
      "needs": [
        "network_mode=macvlan"
      ]
    },
    {
      "key": "network_macvlan_subnet",
      "type": "string",
      "label": "Network Macvlan Subnet",
      "required": true,
      "section": {
        "key": "network"
      },
      "source_type": "str",
      "default": "192.168.1.0/24",
      "needs": [
        "network_mode=macvlan"
      ]
    },
    {
      "key": "network_macvlan_gateway",
      "type": "string",
      "label": "Network Macvlan Gateway",
      "required": true,
      "section": {
        "key": "network"
      },
      "source_type": "str",
      "default": "192.168.1.1",
      "needs": [
        "network_mode=macvlan"
      ]
    },
    {
      "key": "network_external",
      "type": "boolean",
      "label": "Whether the network is external",
      "required": false,
      "section": {
        "key": "network"
      },
      "source_type": "bool",
      "default": false,
      "description": "Whether the network is external"
    },
    {
      "key": "ports_http",
      "type": "string",
      "label": "Ports Http",
      "required": false,
      "section": {
        "key": "ports"
      },
      "source_type": "str",
      "default": 80
    },
    {
      "key": "ports_https",
      "type": "string",
      "label": "Ports Https",
      "required": false,
      "section": {
        "key": "ports"
      },
      "source_type": "str",
      "default": 443
    },
    {
      "key": "ports_dns",
      "type": "number",
      "label": "Ports Dns",
      "required": true,
      "section": {
        "key": "ports"
      },
      "source_type": "int",
      "default": 53
    },
    {
      "key": "ports_initial",
      "type": "number",
      "label": "Initial setup wizard port (only when Traefik is disabled)",
      "required": false,
      "section": {
        "key": "ports"
      },
      "source_type": "int",
      "default": 3000,
      "description": "Initial setup wizard port (only when Traefik is disabled)",
      "needs": [
        "traefik_enabled=false",
        "initial_setup=true"
      ],
      "extra": "Only used during first-time setup without Traefik. After configuration, port becomes inactive. With Traefik, access setup via container IP instead.\n"
    },
    {
      "key": "ports_tls",
      "type": "number",
      "label": "DNS over TLS Port",
      "required": true,
      "section": {
        "key": "ports"
      },
      "source_type": "int",
      "default": 853,
      "description": "DNS over TLS Port"
    },
    {
      "key": "ports_dnscrypt",
      "type": "number",
      "label": "DNSCrypt Port",
      "required": true,
      "section": {
        "key": "ports"
      },
      "source_type": "int",
      "default": 5443,
      "description": "DNSCrypt Port"
    },
    {
      "key": "traefik_host",
      "type": "string",
      "label": "Traefik Host",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "adguardhome"
    },
    {
      "key": "traefik_network",
      "type": "string",
      "label": "Traefik Network",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "traefik"
    },
    {
      "key": "traefik_domain",
      "type": "string",
      "label": "Traefik Domain",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "home.arpa"
    },
    {
      "key": "traefik_enabled",
      "type": "boolean",
      "label": "Enable Traefik integration",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik integration"
    },
    {
      "key": "traefik_tls_certresolver",
      "type": "string",
      "label": "Traefik Tls Certresolver",
      "required": true,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "str",
      "default": "cloudflare"
    },
    {
      "key": "traefik_tls_enabled",
      "type": "boolean",
      "label": "Enable Traefik TLS",
      "required": false,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik TLS"
    },
    {
      "key": "volume_mode",
      "type": "string",
      "label": "Volume Mode",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "enum",
      "default": "local",
      "options": [
        "local",
        "mount",
        "nfs"
      ]
    },
    {
      "key": "volume_mount_path",
      "type": "string",
      "label": "Volume Mount Path",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "str",
      "default": "/mnt/storage",
      "needs": [
        "volume_mode=mount"
      ]
    },
    {
      "key": "volume_nfs_server",
      "type": "string",
      "label": "Volume Nfs Server",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "str",
      "default": "192.168.1.1",
      "needs": [
        "volume_mode=nfs"
      ]
    },
    {
      "key": "volume_nfs_path",
      "type": "string",
      "label": "Volume Nfs Path",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "str",
      "default": "/export",
      "needs": [
        "volume_mode=nfs"
      ]
    },
    {
      "key": "volume_nfs_options",
      "type": "string",
      "label": "Volume Nfs Options",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "str",
      "default": "rw,nolock,soft",
      "needs": [
        "volume_mode=nfs"
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
