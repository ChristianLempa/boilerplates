{
  "version": "1",
  "slug": "homepage",
  "kind": "compose",
  "metadata": {
    "name": "Homepage",
    "description": "Homepage is a modern, fully static, fast, secure fully customizable application dashboard with integrations\nfor over 100 services and translations into multiple languages.\n\nProject: https://gethomepage.dev/\nDocumentation: https://gethomepage.dev/latest/\nGitHub: https://github.com/gethomepage/homepage",
    "tags": [
      "traefik",
      "swarm",
      "volume_modes"
    ],
    "author": "Christian Lempa",
    "template_version": "v1.10.1",
    "date": "2026-02-10",
    "icon": {
      "provider": "simple-icons",
      "id": "homepage"
    },
    "draft": true,
    "next_steps": ""
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "The service name",
          "required": true,
          "default": "homepage",
          "description": "The service name"
        },
        {
          "name": "container_name",
          "type": "str",
          "title": "The container name",
          "required": false,
          "default": "homepage",
          "description": "The container name"
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "The container timezone",
          "required": false,
          "description": "The container timezone"
        },
        {
          "name": "container_loglevel",
          "type": "str",
          "title": "The container log level",
          "required": false,
          "description": "The container log level",
          "options": [
            "debug",
            "info",
            "warn",
            "error"
          ]
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "The container restart policy",
          "required": true,
          "default": "unless-stopped",
          "description": "The container restart policy",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        },
        {
          "name": "swarm_replicas",
          "type": "int",
          "title": "Swarm Replicas",
          "required": false,
          "default": 1
        },
        {
          "name": "swarm_placement_host",
          "type": "str",
          "title": "Swarm Placement Host",
          "required": false,
          "default": ""
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_http",
          "type": "int",
          "title": "The HTTP port",
          "required": true,
          "default": 3000,
          "description": "The HTTP port",
          "needs": [
            "traefik_enabled=false"
          ]
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_entrypoint",
          "type": "str",
          "title": "The Traefik entrypoint",
          "required": true,
          "default": "web",
          "description": "The Traefik entrypoint"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "homepage"
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik Network",
          "required": true,
          "default": "traefik"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik Domain",
          "required": true,
          "default": "home.arpa"
        }
      ]
    },
    {
      "key": "traefik-tls",
      "title": "Traefik TLS",
      "variables": [
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable Traefik TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "The Traefik TLS entrypoint",
          "required": true,
          "default": "websecure",
          "description": "The Traefik TLS entrypoint"
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik Tls Certresolver",
          "required": true,
          "default": "cloudflare"
        }
      ]
    },
    {
      "key": "volume",
      "title": "Volume",
      "variables": [
        {
          "name": "volume_mode",
          "type": "str",
          "title": "Volume Mode",
          "required": true,
          "default": "local",
          "options": [
            "local",
            "mount",
            "nfs"
          ]
        },
        {
          "name": "volume_mount_path",
          "type": "str",
          "title": "Volume Mount Path",
          "required": true,
          "default": "/mnt/storage",
          "needs": [
            "volume_mode=mount"
          ]
        },
        {
          "name": "volume_nfs_options",
          "type": "str",
          "title": "The NFS mount options",
          "required": false,
          "default": "nfsvers=4,soft,timeo=180,intr",
          "description": "The NFS mount options"
        },
        {
          "name": "volume_nfs_path",
          "type": "str",
          "title": "The NFS path",
          "required": false,
          "default": "",
          "description": "The NFS path"
        },
        {
          "name": "volume_nfs_server",
          "type": "str",
          "title": "The NFS server",
          "required": false,
          "default": "",
          "description": "The NFS server"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
