{
  "version": "1",
  "slug": "netbox",
  "kind": "compose",
  "metadata": {
    "name": "NetBox",
    "description": "Network infrastructure management (IPAM/DCIM) and network automation source of truth. Provides comprehensive API\nfor managing IP addresses, circuits, devices, racks, cables, and other network infrastructure components with powerful\nautomation capabilities.\n## References\n- **Project:** https://netbox.dev/\n- **Documentation:** https://docs.netbox.dev/\n- **GitHub:** https://github.com/netbox-community/netbox",
    "tags": [
      "traefik",
      "database",
      "email"
    ],
    "author": "Christian Lempa",
    "template_version": "v4.5.2",
    "date": "2026-02-03",
    "icon": {
      "provider": "selfh",
      "id": "netbox"
    },
    "draft": false,
    "next_steps": "Log in with your initial admin user:\n```bash\nUsername: admin\nPassword: admin\n```"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "database_name",
      "type": "string",
      "label": "Database Name",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database",
        "toggle": "database_external",
        "description": "Configure external database connection"
      },
      "source_type": "str",
      "default": "netbox"
    },
    {
      "key": "database_user",
      "type": "string",
      "label": "Database User",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database",
        "toggle": "database_external",
        "description": "Configure external database connection"
      },
      "source_type": "str",
      "default": "netbox"
    },
    {
      "key": "database_host",
      "type": "string",
      "label": "Database Host",
      "required": true,
      "section": {
        "key": "database",
        "title": "Database",
        "toggle": "database_external",
        "description": "Configure external database connection"
      },
      "source_type": "str"
    },
    {
      "key": "database_password",
      "type": "string",
      "label": "Database Password",
      "required": true,
      "section": {
        "key": "database",
        "title": "Database",
        "toggle": "database_external",
        "description": "Configure external database connection"
      },
      "source_type": "str",
      "sensitive": true
    },
    {
      "key": "redis_password",
      "type": "string",
      "label": "Redis password for authentication",
      "required": true,
      "section": {
        "key": "database",
        "title": "Database",
        "toggle": "database_external",
        "description": "Configure external database connection"
      },
      "source_type": "str",
      "description": "Redis password for authentication",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "database_external",
      "type": "boolean",
      "label": "Use external database",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database",
        "toggle": "database_external",
        "description": "Configure external database connection"
      },
      "source_type": "bool",
      "default": false,
      "description": "Use external database"
    },
    {
      "key": "email_host",
      "type": "string",
      "label": "SMTP server hostname",
      "required": true,
      "section": {
        "key": "email",
        "title": "Email",
        "toggle": "email_enabled",
        "description": "Configure email/SMTP integration"
      },
      "source_type": "str",
      "description": "SMTP server hostname"
    },
    {
      "key": "email_port",
      "type": "number",
      "label": "SMTP server port",
      "required": true,
      "section": {
        "key": "email",
        "title": "Email",
        "toggle": "email_enabled",
        "description": "Configure email/SMTP integration"
      },
      "source_type": "int",
      "default": 25,
      "description": "SMTP server port"
    },
    {
      "key": "email_username",
      "type": "string",
      "label": "SMTP username",
      "required": true,
      "section": {
        "key": "email",
        "title": "Email",
        "toggle": "email_enabled",
        "description": "Configure email/SMTP integration"
      },
      "source_type": "str",
      "description": "SMTP username"
    },
    {
      "key": "email_password",
      "type": "string",
      "label": "SMTP password",
      "required": true,
      "section": {
        "key": "email",
        "title": "Email",
        "toggle": "email_enabled",
        "description": "Configure email/SMTP integration"
      },
      "source_type": "str",
      "description": "SMTP password",
      "sensitive": true
    },
    {
      "key": "email_from",
      "type": "string",
      "label": "From email address",
      "required": true,
      "section": {
        "key": "email",
        "title": "Email",
        "toggle": "email_enabled",
        "description": "Configure email/SMTP integration"
      },
      "source_type": "str",
      "description": "From email address"
    },
    {
      "key": "email_enabled",
      "type": "boolean",
      "label": "Enable email integration",
      "required": false,
      "section": {
        "key": "email",
        "title": "Email",
        "toggle": "email_enabled",
        "description": "Configure email/SMTP integration"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable email integration"
    },
    {
      "key": "email_encryption",
      "type": "string",
      "label": "The email encryption type",
      "required": false,
      "section": {
        "key": "email",
        "title": "Email",
        "toggle": "email_enabled",
        "description": "Configure email/SMTP integration"
      },
      "source_type": "str",
      "default": "tls",
      "description": "The email encryption type"
    },
    {
      "key": "service_name",
      "type": "string",
      "label": "Service Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "netbox"
    },
    {
      "key": "container_timezone",
      "type": "string",
      "label": "Container Timezone",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str"
    },
    {
      "key": "restart_policy",
      "type": "string",
      "label": "Restart Policy",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "enum",
      "default": "unless-stopped",
      "options": [
        "unless-stopped",
        "always",
        "on-failure",
        "no"
      ]
    },
    {
      "key": "netbox_metrics_enabled",
      "type": "boolean",
      "label": "Enable Prometheus metrics endpoint",
      "required": false,
      "section": {
        "key": "netbox",
        "title": "NetBox Configuration",
        "toggle": "netbox_metrics_enabled",
        "description": "Configure NetBox application settings"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Prometheus metrics endpoint"
    },
    {
      "key": "netbox_secret_key",
      "type": "string",
      "label": "Secret Key",
      "required": true,
      "section": {
        "key": "netbox",
        "title": "NetBox Configuration",
        "toggle": "netbox_metrics_enabled",
        "description": "Configure NetBox application settings"
      },
      "source_type": "str",
      "description": "Secret Key",
      "extra": "Used for cryptographic signing and session management",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "ports_http",
      "type": "string",
      "label": "Host port for HTTP",
      "required": false,
      "section": {
        "key": "ports"
      },
      "source_type": "str",
      "default": 8000,
      "description": "Host port for HTTP"
    },
    {
      "key": "traefik_host",
      "type": "string",
      "label": "Traefik Host",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "netbox"
    },
    {
      "key": "traefik_network",
      "type": "string",
      "label": "Traefik Network",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "traefik"
    },
    {
      "key": "traefik_domain",
      "type": "string",
      "label": "Traefik Domain",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "home.arpa"
    },
    {
      "key": "traefik_enabled",
      "type": "boolean",
      "label": "Enable Traefik integration",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik integration"
    },
    {
      "key": "traefik_tls_certresolver",
      "type": "string",
      "label": "Traefik Tls Certresolver",
      "required": true,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "str",
      "default": "cloudflare"
    },
    {
      "key": "traefik_tls_enabled",
      "type": "boolean",
      "label": "Enable Traefik TLS",
      "required": false,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik TLS"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
