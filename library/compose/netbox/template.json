{
  "version": "1",
  "slug": "netbox",
  "kind": "compose",
  "metadata": {
    "name": "NetBox",
    "description": "Network infrastructure management (IPAM/DCIM) and network automation source of truth. Provides comprehensive API\nfor managing IP addresses, circuits, devices, racks, cables, and other network infrastructure components with powerful\nautomation capabilities.\n## References\n- **Project:** https://netbox.dev/\n- **Documentation:** https://docs.netbox.dev/\n- **GitHub:** https://github.com/netbox-community/netbox",
    "tags": [
      "traefik",
      "database",
      "email"
    ],
    "author": "Christian Lempa",
    "template_version": "v4.5.2",
    "date": "2026-02-03",
    "icon": {
      "provider": "simple-icons",
      "id": "netbox"
    },
    "draft": false,
    "next_steps": "Log in with your initial admin user:\n```bash\nUsername: admin\nPassword: admin\n```"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "database",
      "title": "Database",
      "variables": [
        {
          "name": "database_name",
          "type": "str",
          "title": "Database Name",
          "required": false,
          "default": "netbox"
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database User",
          "required": false,
          "default": "netbox"
        },
        {
          "name": "database_host",
          "type": "str",
          "title": "Database Host",
          "required": true
        },
        {
          "name": "database_password",
          "type": "str",
          "title": "Database Password",
          "required": true,
          "sensitive": true
        },
        {
          "name": "redis_password",
          "type": "str",
          "title": "Redis password for authentication",
          "required": true,
          "description": "Redis password for authentication",
          "sensitive": true,
          "autogenerated": true
        },
        {
          "name": "database_external",
          "type": "bool",
          "title": "Use external database",
          "required": false,
          "default": false,
          "description": "Use external database"
        }
      ]
    },
    {
      "key": "email",
      "title": "Email",
      "variables": [
        {
          "name": "email_host",
          "type": "str",
          "title": "SMTP server hostname",
          "required": true,
          "description": "SMTP server hostname"
        },
        {
          "name": "email_port",
          "type": "int",
          "title": "SMTP server port",
          "required": true,
          "default": 25,
          "description": "SMTP server port"
        },
        {
          "name": "email_username",
          "type": "str",
          "title": "SMTP username",
          "required": true,
          "description": "SMTP username"
        },
        {
          "name": "email_password",
          "type": "str",
          "title": "SMTP password",
          "required": true,
          "description": "SMTP password",
          "sensitive": true
        },
        {
          "name": "email_from",
          "type": "str",
          "title": "From email address",
          "required": true,
          "description": "From email address"
        },
        {
          "name": "email_enabled",
          "type": "bool",
          "title": "Enable email integration",
          "required": false,
          "default": false,
          "description": "Enable email integration"
        },
        {
          "name": "email_encryption",
          "type": "str",
          "title": "The email encryption type",
          "required": false,
          "default": "tls",
          "description": "The email encryption type"
        }
      ]
    },
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "netbox"
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        }
      ]
    },
    {
      "key": "netbox",
      "title": "NetBox Configuration",
      "variables": [
        {
          "name": "netbox_metrics_enabled",
          "type": "bool",
          "title": "Enable Prometheus metrics endpoint",
          "required": false,
          "default": false,
          "description": "Enable Prometheus metrics endpoint"
        },
        {
          "name": "netbox_secret_key",
          "type": "str",
          "title": "Secret Key",
          "required": true,
          "description": "Secret Key",
          "sensitive": true,
          "autogenerated": true
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_http",
          "type": "str",
          "title": "Host port for HTTP",
          "required": false,
          "default": 8000,
          "description": "Host port for HTTP"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "netbox"
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik Network",
          "required": true,
          "default": "traefik"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik Domain",
          "required": true,
          "default": "home.arpa"
        },
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        }
      ]
    },
    {
      "key": "traefik-tls",
      "title": "Traefik TLS",
      "variables": [
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik Tls Certresolver",
          "required": true,
          "default": "cloudflare"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable Traefik TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
