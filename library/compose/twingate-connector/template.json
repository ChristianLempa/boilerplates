{
  "version": "1",
  "slug": "twingate-connector",
  "kind": "compose",
  "metadata": {
    "name": "Twingate_Connector",
    "description": "The Twingate Connector is a lightweight software component that establishes secure connections between your private network and the Twingate service. It acts as a bridge, allowing authorized users to access internal resources without exposing them directly to the internet. The Connector uses strong encryption and authentication mechanisms to ensure that all data transmitted between users and resources remains confidential and secure.\n\nProject: https://www.twingate.com/\nDocumentation: https://docs.twingate.com/docs/architecture/connectors\nGitHub: https://github.com/twingate/twingate-connector\n",
    "tags": [
      "swarm"
    ],
    "author": "Christian Lempa",
    "template_version": "1.80.0",
    "icon": {
      "provider": "simple-icons",
      "id": "twingate"
    },
    "date": "2025-11-11",
    "draft": true
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "twingate"
        },
        {
          "name": "container_name",
          "type": "str",
          "title": "Container Name",
          "required": false,
          "default": "twingate_connector"
        },
        {
          "name": "container_hostname",
          "type": "str",
          "title": "Container Hostname",
          "required": false,
          "default": "twingate_connector"
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        },
        {
          "name": "twingate_version",
          "type": "str",
          "title": "Twingate Connector version",
          "required": false,
          "default": "1.79.0",
          "description": "Twingate Connector version"
        },
        {
          "name": "swarm_replicas",
          "type": "int",
          "title": "Swarm Replicas",
          "required": false,
          "default": 1
        },
        {
          "name": "swarm_placement_host",
          "type": "str",
          "title": "Swarm Placement Host",
          "required": false,
          "default": ""
        }
      ]
    },
    {
      "key": "twingate",
      "title": "Twingate Configuration",
      "variables": [
        {
          "name": "twingate_network",
          "type": "str",
          "title": "Enter your Twingate network name",
          "required": false,
          "description": "Your Twingate network name"
        },
        {
          "name": "twingate_log_level",
          "type": "int",
          "title": "Log level (1=ERROR, 2=WARN, 3=INFO, 4=DEBUG)",
          "required": false,
          "default": 1,
          "description": "Log level (1=ERROR, 2=WARN, 3=INFO, 4=DEBUG)"
        },
        {
          "name": "twingate_dns",
          "type": "str",
          "title": "Local DNS server IP (optional, leave empty to use default)",
          "required": false,
          "default": "",
          "description": "Local DNS server IP (optional, leave empty to use default)"
        }
      ]
    },
    {
      "key": "resources",
      "title": "Resource Limits",
      "variables": [
        {
          "name": "resources_enabled",
          "type": "bool",
          "title": "Resources Enabled",
          "required": false,
          "default": false
        },
        {
          "name": "resources_cpu_limit",
          "type": "str",
          "title": "Resources Cpu Limit",
          "required": true,
          "default": 1.0
        },
        {
          "name": "resources_cpu_reservation",
          "type": "str",
          "title": "Resources Cpu Reservation",
          "required": true,
          "default": 0.25,
          "needs": [
            "swarm_enabled=true"
          ]
        },
        {
          "name": "resources_memory_limit",
          "type": "str",
          "title": "Resources Memory Limit",
          "required": true,
          "default": "1G"
        },
        {
          "name": "resources_memory_reservation",
          "type": "str",
          "title": "Resources Memory Reservation",
          "required": true,
          "default": "512M",
          "needs": [
            "swarm_enabled=true"
          ]
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
