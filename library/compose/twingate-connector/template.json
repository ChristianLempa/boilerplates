{
  "version": "1",
  "slug": "twingate-connector",
  "kind": "compose",
  "metadata": {
    "name": "Twingate_Connector",
    "description": "The Twingate Connector is a lightweight software component that establishes secure connections between your private network and the Twingate service. It acts as a bridge, allowing authorized users to access internal resources without exposing them directly to the internet. The Connector uses strong encryption and authentication mechanisms to ensure that all data transmitted between users and resources remains confidential and secure.\n\nProject: https://www.twingate.com/\nDocumentation: https://docs.twingate.com/docs/architecture/connectors\nGitHub: https://github.com/twingate/twingate-connector\n",
    "tags": [
      "swarm"
    ],
    "author": "Christian Lempa",
    "template_version": "1.80.0",
    "icon": {
      "provider": "selfh",
      "id": "twingate"
    },
    "date": "2025-11-11",
    "draft": true
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "service_name",
      "type": "string",
      "label": "Service Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "twingate"
    },
    {
      "key": "container_name",
      "type": "string",
      "label": "Container Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "twingate_connector"
    },
    {
      "key": "container_hostname",
      "type": "string",
      "label": "Container Hostname",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "twingate_connector"
    },
    {
      "key": "container_timezone",
      "type": "string",
      "label": "Container Timezone",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str"
    },
    {
      "key": "restart_policy",
      "type": "string",
      "label": "Restart Policy",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "enum",
      "default": "unless-stopped",
      "options": [
        "unless-stopped",
        "always",
        "on-failure",
        "no"
      ]
    },
    {
      "key": "twingate_version",
      "type": "string",
      "label": "Twingate Connector version",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "1.79.0",
      "description": "Twingate Connector version"
    },
    {
      "key": "twingate_network",
      "type": "string",
      "label": "Enter your Twingate network name",
      "required": false,
      "section": {
        "key": "twingate",
        "title": "Twingate Configuration",
        "required": true
      },
      "source_type": "str",
      "description": "Your Twingate network name",
      "prompt": "Enter your Twingate network name"
    },
    {
      "key": "twingate_log_level",
      "type": "number",
      "label": "Log level (1=ERROR, 2=WARN, 3=INFO, 4=DEBUG)",
      "required": false,
      "section": {
        "key": "twingate",
        "title": "Twingate Configuration",
        "required": true
      },
      "source_type": "int",
      "default": 1,
      "description": "Log level (1=ERROR, 2=WARN, 3=INFO, 4=DEBUG)"
    },
    {
      "key": "twingate_dns",
      "type": "string",
      "label": "Local DNS server IP (optional, leave empty to use default)",
      "required": false,
      "section": {
        "key": "twingate",
        "title": "Twingate Configuration",
        "required": true
      },
      "source_type": "str",
      "default": "",
      "description": "Local DNS server IP (optional, leave empty to use default)"
    },
    {
      "key": "resources_enabled",
      "type": "boolean",
      "label": "Resources Enabled",
      "required": false,
      "section": {
        "key": "resources",
        "title": "Resource Limits",
        "toggle": "resources_enabled",
        "description": "Configure container resource limits"
      },
      "source_type": "bool",
      "default": false
    },
    {
      "key": "resources_cpu_limit",
      "type": "string",
      "label": "Resources Cpu Limit",
      "required": true,
      "section": {
        "key": "resources",
        "title": "Resource Limits",
        "toggle": "resources_enabled",
        "description": "Configure container resource limits"
      },
      "source_type": "str",
      "default": 1.0
    },
    {
      "key": "resources_cpu_reservation",
      "type": "string",
      "label": "Resources Cpu Reservation",
      "required": true,
      "section": {
        "key": "resources",
        "title": "Resource Limits",
        "toggle": "resources_enabled",
        "description": "Configure container resource limits"
      },
      "source_type": "str",
      "default": 0.25,
      "needs": [
        "swarm_enabled=true"
      ]
    },
    {
      "key": "resources_memory_limit",
      "type": "string",
      "label": "Resources Memory Limit",
      "required": true,
      "section": {
        "key": "resources",
        "title": "Resource Limits",
        "toggle": "resources_enabled",
        "description": "Configure container resource limits"
      },
      "source_type": "str",
      "default": "1G"
    },
    {
      "key": "resources_memory_reservation",
      "type": "string",
      "label": "Resources Memory Reservation",
      "required": true,
      "section": {
        "key": "resources",
        "title": "Resource Limits",
        "toggle": "resources_enabled",
        "description": "Configure container resource limits"
      },
      "source_type": "str",
      "default": "512M",
      "needs": [
        "swarm_enabled=true"
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
