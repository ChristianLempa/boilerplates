{
  "version": "1",
  "slug": "authentik",
  "kind": "compose",
  "metadata": {
    "name": "Authentik",
    "description": "Integrate Authentik Single Sign-On (SSO) for secure and streamlined user authentication.\nAuthentik is an open-source identity provider that supports various authentication protocols.\nThis configuration enables OAuth-based SSO, allowing users to log in using their Authentik\ncredentials, enhancing security and user experience.\n## Prerequisites\n- :warning: The `authentik_secret_key` must be generated using the following command\naccording to the official documentation.\n```bash\necho \"$(openssl rand -base64 60 | tr -d '\\n')\"\n```\n## References\n* **Project:** https://goauthentik.io/\n* **Documentation:** https://goauthentik.io/docs/\n* **GitHub:** https://github.com/goauthentik/authentik",
    "tags": [
      "traefik",
      "volume"
    ],
    "author": "Christian Lempa",
    "template_version": "2025.12.4",
    "icon": {
      "provider": "selfh",
      "id": "authentik"
    },
    "next_steps": "Log in with your initial admin user:\n```bash\nUsername: akadmin\nPassword: {{ authentik_admin_password }}\n```",
    "date": "2026-02-12"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "service_name",
      "type": "string",
      "label": "Service Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "authentik"
    },
    {
      "key": "restart_policy",
      "type": "string",
      "label": "Restart Policy",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "enum",
      "default": "unless-stopped",
      "options": [
        "unless-stopped",
        "always",
        "on-failure",
        "no"
      ]
    },
    {
      "key": "database_password",
      "type": "string",
      "label": "Database password",
      "required": true,
      "section": {
        "key": "database"
      },
      "source_type": "str",
      "description": "Database password",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "database_user",
      "type": "string",
      "label": "The database user",
      "required": false,
      "section": {
        "key": "database"
      },
      "source_type": "str",
      "default": "authentik",
      "description": "The database user"
    },
    {
      "key": "database_name",
      "type": "string",
      "label": "The database name",
      "required": false,
      "section": {
        "key": "database"
      },
      "source_type": "str",
      "default": "authentik",
      "description": "The database name"
    },
    {
      "key": "database_external",
      "type": "boolean",
      "label": "Use external database",
      "required": false,
      "section": {
        "key": "database"
      },
      "source_type": "bool",
      "default": false,
      "description": "Use external database"
    },
    {
      "key": "ports_http",
      "type": "string",
      "label": "Ports Http",
      "required": false,
      "section": {
        "key": "ports"
      },
      "source_type": "str",
      "default": 8000
    },
    {
      "key": "ports_https",
      "type": "string",
      "label": "Ports Https",
      "required": false,
      "section": {
        "key": "ports"
      },
      "source_type": "str",
      "default": 8443
    },
    {
      "key": "traefik_host",
      "type": "string",
      "label": "Traefik Host",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "authentik"
    },
    {
      "key": "traefik_network",
      "type": "string",
      "label": "Traefik Network",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "traefik"
    },
    {
      "key": "traefik_domain",
      "type": "string",
      "label": "Traefik Domain",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "home.arpa"
    },
    {
      "key": "traefik_enabled",
      "type": "boolean",
      "label": "Enable Traefik integration",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik integration"
    },
    {
      "key": "authentik_secret_key",
      "type": "string",
      "label": "Secret Key",
      "required": true,
      "section": {
        "key": "authentik",
        "required": true,
        "description": "Configure Authentik application settings"
      },
      "source_type": "str",
      "description": "Secret Key",
      "extra": "Used for cookie signing and unique user IDs",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "authentik_admin_password",
      "type": "string",
      "label": "Initial admin user password",
      "required": false,
      "section": {
        "key": "authentik",
        "required": true,
        "description": "Configure Authentik application settings"
      },
      "source_type": "str",
      "description": "Initial admin user password",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "authentik_error_reporting",
      "type": "boolean",
      "label": "Enable error reporting to Authentik developers",
      "required": false,
      "section": {
        "key": "authentik",
        "required": true,
        "description": "Configure Authentik application settings"
      },
      "source_type": "bool",
      "description": "Enable error reporting to Authentik developers"
    },
    {
      "key": "traefik_tls_certresolver",
      "type": "string",
      "label": "Traefik Tls Certresolver",
      "required": true,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "str",
      "default": "cloudflare"
    },
    {
      "key": "traefik_tls_enabled",
      "type": "boolean",
      "label": "Enable Traefik TLS",
      "required": false,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik TLS"
    },
    {
      "key": "volume_mode",
      "type": "string",
      "label": "Volume Mode",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "enum",
      "default": "local",
      "options": [
        "local",
        "mount",
        "nfs"
      ]
    },
    {
      "key": "volume_mount_path",
      "type": "string",
      "label": "Volume Mount Path",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "str",
      "default": "/mnt/storage",
      "needs": [
        "volume_mode=mount"
      ]
    },
    {
      "key": "volume_nfs_server",
      "type": "string",
      "label": "Volume Nfs Server",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "str",
      "default": "192.168.1.1",
      "needs": [
        "volume_mode=nfs"
      ]
    },
    {
      "key": "volume_nfs_path",
      "type": "string",
      "label": "Volume Nfs Path",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "str",
      "default": "/export",
      "needs": [
        "volume_mode=nfs"
      ]
    },
    {
      "key": "volume_nfs_options",
      "type": "string",
      "label": "Volume Nfs Options",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "str",
      "default": "rw,nolock,soft",
      "needs": [
        "volume_mode=nfs"
      ]
    },
    {
      "key": "email_host",
      "type": "string",
      "label": "SMTP server hostname",
      "required": true,
      "section": {
        "key": "email",
        "title": "Email",
        "toggle": "email_enabled",
        "description": "Configure email/SMTP integration"
      },
      "source_type": "str",
      "description": "SMTP server hostname"
    },
    {
      "key": "email_port",
      "type": "number",
      "label": "SMTP server port",
      "required": true,
      "section": {
        "key": "email",
        "title": "Email",
        "toggle": "email_enabled",
        "description": "Configure email/SMTP integration"
      },
      "source_type": "int",
      "default": 25,
      "description": "SMTP server port"
    },
    {
      "key": "email_username",
      "type": "string",
      "label": "SMTP username",
      "required": true,
      "section": {
        "key": "email",
        "title": "Email",
        "toggle": "email_enabled",
        "description": "Configure email/SMTP integration"
      },
      "source_type": "str",
      "description": "SMTP username"
    },
    {
      "key": "email_password",
      "type": "string",
      "label": "SMTP password",
      "required": true,
      "section": {
        "key": "email",
        "title": "Email",
        "toggle": "email_enabled",
        "description": "Configure email/SMTP integration"
      },
      "source_type": "str",
      "description": "SMTP password",
      "sensitive": true
    },
    {
      "key": "email_from",
      "type": "string",
      "label": "From email address",
      "required": true,
      "section": {
        "key": "email",
        "title": "Email",
        "toggle": "email_enabled",
        "description": "Configure email/SMTP integration"
      },
      "source_type": "str",
      "description": "From email address"
    },
    {
      "key": "email_enabled",
      "type": "boolean",
      "label": "Enable email integration",
      "required": false,
      "section": {
        "key": "email",
        "title": "Email",
        "toggle": "email_enabled",
        "description": "Configure email/SMTP integration"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable email integration"
    },
    {
      "key": "email_encryption",
      "type": "string",
      "label": "The email encryption type",
      "required": false,
      "section": {
        "key": "email",
        "title": "Email",
        "toggle": "email_enabled",
        "description": "Configure email/SMTP integration"
      },
      "source_type": "str",
      "default": "tls",
      "description": "The email encryption type"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
