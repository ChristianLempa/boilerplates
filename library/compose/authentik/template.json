{
  "version": "1",
  "slug": "authentik",
  "kind": "compose",
  "metadata": {
    "name": "Authentik",
    "description": "Integrate Authentik Single Sign-On (SSO) for secure and streamlined user authentication.\nAuthentik is an open-source identity provider that supports various authentication protocols.\nThis configuration enables OAuth-based SSO, allowing users to log in using their Authentik\ncredentials, enhancing security and user experience.\n## Prerequisites\n- :warning: The `authentik_secret_key` must be generated using the following command\naccording to the official documentation.\n```bash\necho \"$(openssl rand -base64 60 | tr -d '\\n')\"\n```\n## References\n* **Project:** https://goauthentik.io/\n* **Documentation:** https://goauthentik.io/docs/\n* **GitHub:** https://github.com/goauthentik/authentik",
    "tags": [
      "traefik",
      "volume"
    ],
    "author": "Christian Lempa",
    "template_version": "2025.12.4",
    "icon": {
      "provider": "simple-icons",
      "id": "authentik"
    },
    "next_steps": "Log in with your initial admin user:\n```bash\nUsername: akadmin\nPassword: {{ authentik_admin_password }}\n```",
    "date": "2026-02-12"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "authentik"
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        }
      ]
    },
    {
      "key": "database",
      "title": "Database",
      "variables": [
        {
          "name": "database_password",
          "type": "str",
          "title": "Database password",
          "required": true,
          "description": "Database password",
          "sensitive": true,
          "autogenerated": true
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "The database user",
          "required": false,
          "default": "authentik",
          "description": "The database user"
        },
        {
          "name": "database_name",
          "type": "str",
          "title": "The database name",
          "required": false,
          "default": "authentik",
          "description": "The database name"
        },
        {
          "name": "database_external",
          "type": "bool",
          "title": "Use external database",
          "required": false,
          "default": false,
          "description": "Use external database"
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_http",
          "type": "str",
          "title": "Ports Http",
          "required": false,
          "default": 8000
        },
        {
          "name": "ports_https",
          "type": "str",
          "title": "Ports Https",
          "required": false,
          "default": 8443
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "authentik"
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik Network",
          "required": true,
          "default": "traefik"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik Domain",
          "required": true,
          "default": "home.arpa"
        },
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        }
      ]
    },
    {
      "key": "authentik",
      "title": "Authentik",
      "variables": [
        {
          "name": "authentik_secret_key",
          "type": "str",
          "title": "Secret Key",
          "required": true,
          "description": "Secret Key",
          "sensitive": true,
          "autogenerated": true
        },
        {
          "name": "authentik_admin_password",
          "type": "str",
          "title": "Initial admin user password",
          "required": false,
          "description": "Initial admin user password",
          "sensitive": true,
          "autogenerated": true
        },
        {
          "name": "authentik_error_reporting",
          "type": "bool",
          "title": "Enable error reporting to Authentik developers",
          "required": false,
          "description": "Enable error reporting to Authentik developers"
        }
      ]
    },
    {
      "key": "traefik-tls",
      "title": "Traefik TLS",
      "variables": [
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik Tls Certresolver",
          "required": true,
          "default": "cloudflare"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable Traefik TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        }
      ]
    },
    {
      "key": "volume",
      "title": "Volume",
      "variables": [
        {
          "name": "volume_mode",
          "type": "str",
          "title": "Volume Mode",
          "required": true,
          "default": "local",
          "options": [
            "local",
            "mount",
            "nfs"
          ]
        },
        {
          "name": "volume_mount_path",
          "type": "str",
          "title": "Volume Mount Path",
          "required": true,
          "default": "/mnt/storage",
          "needs": [
            "volume_mode=mount"
          ]
        },
        {
          "name": "volume_nfs_server",
          "type": "str",
          "title": "Volume Nfs Server",
          "required": true,
          "default": "192.168.1.1",
          "needs": [
            "volume_mode=nfs"
          ]
        },
        {
          "name": "volume_nfs_path",
          "type": "str",
          "title": "Volume Nfs Path",
          "required": true,
          "default": "/export",
          "needs": [
            "volume_mode=nfs"
          ]
        },
        {
          "name": "volume_nfs_options",
          "type": "str",
          "title": "Volume Nfs Options",
          "required": true,
          "default": "rw,nolock,soft",
          "needs": [
            "volume_mode=nfs"
          ]
        }
      ]
    },
    {
      "key": "email",
      "title": "Email",
      "variables": [
        {
          "name": "email_host",
          "type": "str",
          "title": "SMTP server hostname",
          "required": true,
          "description": "SMTP server hostname"
        },
        {
          "name": "email_port",
          "type": "int",
          "title": "SMTP server port",
          "required": true,
          "default": 25,
          "description": "SMTP server port"
        },
        {
          "name": "email_username",
          "type": "str",
          "title": "SMTP username",
          "required": true,
          "description": "SMTP username"
        },
        {
          "name": "email_password",
          "type": "str",
          "title": "SMTP password",
          "required": true,
          "description": "SMTP password",
          "sensitive": true
        },
        {
          "name": "email_from",
          "type": "str",
          "title": "From email address",
          "required": true,
          "description": "From email address"
        },
        {
          "name": "email_enabled",
          "type": "bool",
          "title": "Enable email integration",
          "required": false,
          "default": false,
          "description": "Enable email integration"
        },
        {
          "name": "email_encryption",
          "type": "str",
          "title": "The email encryption type",
          "required": false,
          "default": "tls",
          "description": "The email encryption type"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
