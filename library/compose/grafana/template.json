{
  "version": "1",
  "slug": "grafana",
  "kind": "compose",
  "metadata": {
    "name": "Grafana",
    "description": "Grafana is an open-source platform for monitoring and observability that allows you to visualize and analyze metrics, logs, and traces from various data\nsources. It provides a powerful and flexible dashboarding solution for IT infrastructure and application monitoring.\n## Prerequisites\n- **Project:** https://grafana.com/\n- **Documentation:** https://grafana.com/docs/grafana/latest/\n- **GitHub:** https://github.com/grafana/grafana",
    "tags": [
      "traefik",
      "authentik"
    ],
    "author": "Christian Lempa",
    "template_version": "12.3.3",
    "icon": {
      "provider": "simple-icons",
      "id": "grafana"
    },
    "next_steps": "Log in with the initial admin user:\n```bash\nUsername: admin\nPassword: admin\n```",
    "date": "2026-02-12"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "grafana"
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_http",
          "type": "str",
          "title": "Ports Http",
          "required": false,
          "default": 3000
        }
      ]
    },
    {
      "key": "authentik",
      "title": "Authentik",
      "variables": [
        {
          "name": "authentik_enabled",
          "type": "bool",
          "title": "Enable Authentik SSO integration",
          "required": false,
          "default": false,
          "description": "Enable Authentik SSO integration"
        },
        {
          "name": "authentik_url",
          "type": "str",
          "title": "Authentik Url",
          "required": true,
          "default": "https://auth.home.arpa",
          "needs": "authentik_enabled=true"
        },
        {
          "name": "authentik_slug",
          "type": "str",
          "title": "Authentik Slug",
          "required": true,
          "default": "grafana",
          "needs": "authentik_enabled=true"
        },
        {
          "name": "authentik_client_id",
          "type": "str",
          "title": "Authentik Client Id",
          "required": true,
          "sensitive": true,
          "needs": "authentik_enabled=true"
        },
        {
          "name": "authentik_client_secret",
          "type": "str",
          "title": "Authentik Client Secret",
          "required": true,
          "sensitive": true,
          "needs": "authentik_enabled=true"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "grafana"
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik Network",
          "required": true,
          "default": "traefik"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik Domain",
          "required": true,
          "default": "home.arpa"
        },
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        }
      ]
    },
    {
      "key": "traefik-tls",
      "title": "Traefik TLS",
      "variables": [
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik Tls Certresolver",
          "required": true,
          "default": "cloudflare"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable Traefik TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        }
      ]
    },
    {
      "key": "database",
      "title": "Database",
      "variables": [
        {
          "name": "database_type",
          "type": "str",
          "title": "Database Type",
          "required": false,
          "options": [
            "sqlite",
            "postgres"
          ]
        },
        {
          "name": "database_external",
          "type": "bool",
          "title": "Use external database",
          "required": false,
          "default": false,
          "description": "Use external database",
          "needs": "database_type=postgres"
        },
        {
          "name": "database_name",
          "type": "str",
          "title": "Database Name",
          "required": false,
          "default": "grafana",
          "needs": "database_type=postgres"
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database User",
          "required": false,
          "default": "grafana",
          "needs": "database_type=postgres"
        },
        {
          "name": "database_password",
          "type": "str",
          "title": "Database Password",
          "required": true,
          "sensitive": true,
          "needs": "database_type=postgres"
        },
        {
          "name": "database_host",
          "type": "str",
          "title": "Database Host",
          "required": true,
          "needs": [
            "database_type=postgres",
            "database_external=true"
          ]
        }
      ]
    },
    {
      "key": "swarm",
      "title": "Swarm",
      "variables": [
        {
          "name": "swarm_enabled",
          "type": "bool",
          "title": "Enable Docker Swarm mode",
          "required": false,
          "default": false,
          "description": "Enable Docker Swarm mode"
        },
        {
          "name": "swarm_placement_mode",
          "type": "str",
          "title": "The placement mode",
          "required": false,
          "default": "replicated",
          "description": "The placement mode",
          "needs": [
            "swarm_enabled=true"
          ]
        },
        {
          "name": "swarm_replicas",
          "type": "int",
          "title": "The number of replicas",
          "required": false,
          "default": 1,
          "description": "The number of replicas",
          "needs": [
            "swarm_placement_mode=replicated"
          ]
        },
        {
          "name": "swarm_placement_host",
          "type": "str",
          "title": "The placement host",
          "required": false,
          "default": "",
          "description": "The placement host",
          "needs": [
            "swarm_placement_mode=replicated"
          ]
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
