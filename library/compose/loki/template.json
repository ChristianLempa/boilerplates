{
  "version": "1",
  "slug": "loki",
  "kind": "compose",
  "metadata": {
    "name": "Loki",
    "description": "Loki is a horizontally scalable, highly available, multi-tenant log aggregation system inspired by Prometheus.\nThis template sets up Loki in a Docker container using Docker Compose.\n## References\n* **Project:** https://grafana.com/oss/loki/\n* **Documentation:** https://grafana.com/docs/loki/latest/\n* **GitHub:** https://github.com/grafana/loki",
    "tags": [
      "traefik",
      "authentik"
    ],
    "author": "Christian Lempa",
    "template_version": "3.6.5",
    "icon": {
      "provider": "selfh",
      "id": "loki"
    },
    "date": "2026-02-06"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "service_name",
      "type": "string",
      "label": "Service Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "loki"
    },
    {
      "key": "restart_policy",
      "type": "string",
      "label": "Restart Policy",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "enum",
      "default": "unless-stopped",
      "options": [
        "unless-stopped",
        "always",
        "on-failure",
        "no"
      ]
    },
    {
      "key": "data_retention_days",
      "type": "number",
      "label": "Number of days to retain logs",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "int",
      "default": 7,
      "description": "Number of days to retain logs"
    },
    {
      "key": "ports_http",
      "type": "string",
      "label": "Ports Http",
      "required": false,
      "section": {
        "key": "ports"
      },
      "source_type": "str",
      "default": 3100
    },
    {
      "key": "traefik_host",
      "type": "string",
      "label": "Traefik Host",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "loki"
    },
    {
      "key": "traefik_network",
      "type": "string",
      "label": "Traefik Network",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "traefik"
    },
    {
      "key": "traefik_domain",
      "type": "string",
      "label": "Traefik Domain",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "home.arpa"
    },
    {
      "key": "traefik_enabled",
      "type": "boolean",
      "label": "Enable Traefik integration",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik integration"
    },
    {
      "key": "traefik_tls_certresolver",
      "type": "string",
      "label": "Traefik Tls Certresolver",
      "required": true,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "str",
      "default": "cloudflare"
    },
    {
      "key": "traefik_tls_enabled",
      "type": "boolean",
      "label": "Enable Traefik TLS",
      "required": false,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik TLS"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
