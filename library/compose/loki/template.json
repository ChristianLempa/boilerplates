{
  "version": "1",
  "slug": "loki",
  "kind": "compose",
  "metadata": {
    "name": "Loki",
    "description": "Loki is a horizontally scalable, highly available, multi-tenant log aggregation system inspired by Prometheus.\nThis template sets up Loki in a Docker container using Docker Compose.\n## References\n* **Project:** https://grafana.com/oss/loki/\n* **Documentation:** https://grafana.com/docs/loki/latest/\n* **GitHub:** https://github.com/grafana/loki",
    "tags": [
      "traefik",
      "authentik"
    ],
    "author": "Christian Lempa",
    "template_version": "3.6.5",
    "icon": {
      "provider": "mdi",
      "id": "text-search"
    },
    "date": "2026-02-06"
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "loki"
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        },
        {
          "name": "data_retention_days",
          "type": "int",
          "title": "Number of days to retain logs",
          "required": false,
          "default": 7,
          "description": "Number of days to retain logs"
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_http",
          "type": "str",
          "title": "Ports Http",
          "required": false,
          "default": 3100
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "loki"
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik Network",
          "required": true,
          "default": "traefik"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik Domain",
          "required": true,
          "default": "home.arpa"
        },
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        }
      ]
    },
    {
      "key": "traefik-tls",
      "title": "Traefik TLS",
      "variables": [
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik Tls Certresolver",
          "required": true,
          "default": "cloudflare"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable Traefik TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
