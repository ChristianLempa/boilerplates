{
  "version": "1",
  "slug": "nextcloud",
  "kind": "compose",
  "metadata": {
    "name": "Nextcloud",
    "description": "Self-hosted file sync and share platform. Nextcloud is a suite of client-server software for creating and using file hosting services. It provides functionality similar to Dropbox, with the added benefit of being self-hosted and open-source.\n\nProject: https://nextcloud.com/\nDocumentation: https://docs.nextcloud.com/\nGitHub: https://github.com/nextcloud/server\n",
    "tags": [
      "traefik"
    ],
    "author": "Christian Lempa",
    "template_version": "32.0.6-apache",
    "icon": {
      "provider": "simple-icons",
      "id": "nextcloud"
    },
    "date": "2026-02-13",
    "draft": true
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "database",
      "title": "Database",
      "variables": [
        {
          "name": "database_type",
          "type": "str",
          "title": "Database type (Nextcloud supports PostgreSQL or MySQL/MariaDB)",
          "required": false,
          "default": "postgres",
          "description": "Database type (Nextcloud supports PostgreSQL or MySQL/MariaDB)",
          "options": [
            "postgres",
            "mysql"
          ]
        },
        {
          "name": "database_name",
          "type": "str",
          "title": "Database Name",
          "required": true
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database User",
          "required": true
        },
        {
          "name": "database_password",
          "type": "str",
          "title": "Database Password",
          "required": true,
          "sensitive": true
        }
      ]
    },
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "nextcloud"
        },
        {
          "name": "container_name",
          "type": "str",
          "title": "Container Name",
          "required": false,
          "default": "nextcloud"
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        },
        {
          "name": "traefik_entrypoint",
          "type": "str",
          "title": "Traefik Entrypoint",
          "required": false,
          "default": ""
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "Traefik Tls Entrypoint",
          "required": false,
          "default": ""
        },
        {
          "name": "swarm_replicas",
          "type": "int",
          "title": "Swarm Replicas",
          "required": false,
          "default": 1
        }
      ]
    },
    {
      "key": "network",
      "title": "Network",
      "variables": [
        {
          "name": "network_mode",
          "type": "str",
          "title": "Network Mode",
          "required": false,
          "default": "bridge",
          "options": [
            "bridge",
            "macvlan"
          ]
        },
        {
          "name": "network_macvlan_ipv4_address_db",
          "type": "str",
          "title": "Static IP address for database container (macvlan only)",
          "required": false,
          "default": "192.168.1.252",
          "description": "Static IP address for database container (macvlan only)",
          "needs": [
            "network_mode=macvlan"
          ]
        }
      ]
    },
    {
      "key": "ports",
      "title": "Ports",
      "variables": [
        {
          "name": "ports_http",
          "type": "int",
          "title": "Host port for HTTP",
          "required": false,
          "default": 80,
          "description": "Host port for HTTP"
        }
      ]
    },
    {
      "key": "nextcloud",
      "title": "Nextcloud",
      "variables": [
        {
          "name": "admin_user",
          "type": "str",
          "title": "Nextcloud admin username",
          "required": false,
          "default": "admin",
          "description": "Nextcloud admin username"
        },
        {
          "name": "admin_password",
          "type": "str",
          "title": "Nextcloud admin password",
          "required": false,
          "default": "",
          "description": "Nextcloud admin password",
          "sensitive": true,
          "autogenerated": true
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik Host",
          "required": false,
          "default": "nextcloud"
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik Network",
          "required": true,
          "default": "traefik"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik Domain",
          "required": true,
          "default": "home.arpa"
        },
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        }
      ]
    },
    {
      "key": "traefik-tls",
      "title": "Traefik TLS",
      "variables": [
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Traefik Tls Certresolver",
          "required": true,
          "default": "cloudflare"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable Traefik TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
