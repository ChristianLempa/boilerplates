{
  "version": "1",
  "slug": "nextcloud",
  "kind": "compose",
  "metadata": {
    "name": "Nextcloud",
    "description": "Self-hosted file sync and share platform. Nextcloud is a suite of client-server software for creating and using file hosting services. It provides functionality similar to Dropbox, with the added benefit of being self-hosted and open-source.\n\nProject: https://nextcloud.com/\nDocumentation: https://docs.nextcloud.com/\nGitHub: https://github.com/nextcloud/server\n",
    "tags": [
      "traefik"
    ],
    "author": "Christian Lempa",
    "template_version": "32.0.6-apache",
    "icon": {
      "provider": "selfh",
      "id": "nextcloud"
    },
    "date": "2026-02-13",
    "draft": true
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "database_type",
      "type": "string",
      "label": "Database type (Nextcloud supports PostgreSQL or MySQL/MariaDB)",
      "required": false,
      "section": {
        "key": "database",
        "required": true
      },
      "source_type": "enum",
      "default": "postgres",
      "description": "Database type (Nextcloud supports PostgreSQL or MySQL/MariaDB)",
      "options": [
        "postgres",
        "mysql"
      ]
    },
    {
      "key": "database_name",
      "type": "string",
      "label": "Database Name",
      "required": true,
      "section": {
        "key": "database",
        "required": true
      },
      "source_type": "str"
    },
    {
      "key": "database_user",
      "type": "string",
      "label": "Database User",
      "required": true,
      "section": {
        "key": "database",
        "required": true
      },
      "source_type": "str"
    },
    {
      "key": "database_password",
      "type": "string",
      "label": "Database Password",
      "required": true,
      "section": {
        "key": "database",
        "required": true
      },
      "source_type": "str",
      "sensitive": true
    },
    {
      "key": "service_name",
      "type": "string",
      "label": "Service Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "nextcloud"
    },
    {
      "key": "container_name",
      "type": "string",
      "label": "Container Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "nextcloud"
    },
    {
      "key": "container_timezone",
      "type": "string",
      "label": "Container Timezone",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str"
    },
    {
      "key": "restart_policy",
      "type": "string",
      "label": "Restart Policy",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "enum",
      "default": "unless-stopped",
      "options": [
        "unless-stopped",
        "always",
        "on-failure",
        "no"
      ]
    },
    {
      "key": "network_macvlan_ipv4_address_db",
      "type": "string",
      "label": "Static IP address for database container (macvlan only)",
      "required": false,
      "section": {
        "key": "network"
      },
      "source_type": "str",
      "default": "192.168.1.252",
      "description": "Static IP address for database container (macvlan only)",
      "needs": "network_mode=macvlan"
    },
    {
      "key": "ports_http",
      "type": "number",
      "label": "Host port for HTTP",
      "required": false,
      "section": {
        "key": "ports"
      },
      "source_type": "int",
      "default": 80,
      "description": "Host port for HTTP"
    },
    {
      "key": "admin_user",
      "type": "string",
      "label": "Nextcloud admin username",
      "required": false,
      "section": {
        "key": "nextcloud",
        "description": "Configure Nextcloud application settings"
      },
      "source_type": "str",
      "default": "admin",
      "description": "Nextcloud admin username"
    },
    {
      "key": "admin_password",
      "type": "string",
      "label": "Nextcloud admin password",
      "required": false,
      "section": {
        "key": "nextcloud",
        "description": "Configure Nextcloud application settings"
      },
      "source_type": "str",
      "default": "",
      "description": "Nextcloud admin password",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "traefik_host",
      "type": "string",
      "label": "Traefik Host",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "nextcloud"
    },
    {
      "key": "traefik_network",
      "type": "string",
      "label": "Traefik Network",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "traefik"
    },
    {
      "key": "traefik_domain",
      "type": "string",
      "label": "Traefik Domain",
      "required": true,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "str",
      "default": "home.arpa"
    },
    {
      "key": "traefik_enabled",
      "type": "boolean",
      "label": "Enable Traefik integration",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik",
        "toggle": "traefik_enabled",
        "description": "Configure Traefik reverse proxy integration"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik integration"
    },
    {
      "key": "traefik_tls_certresolver",
      "type": "string",
      "label": "Traefik Tls Certresolver",
      "required": true,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "str",
      "default": "cloudflare"
    },
    {
      "key": "traefik_tls_enabled",
      "type": "boolean",
      "label": "Enable Traefik TLS",
      "required": false,
      "section": {
        "key": "traefik_tls",
        "title": "Traefik TLS",
        "toggle": "traefik_tls_enabled",
        "needs": "traefik",
        "description": "Configure Traefik TLS/SSL certificates"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik TLS"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
