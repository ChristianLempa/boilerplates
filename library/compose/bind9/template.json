{
  "version": "1",
  "slug": "bind9",
  "kind": "compose",
  "metadata": {
    "name": "BIND9",
    "description": "BIND9 is the most widely used DNS server on the Internet.\nThis template provides an authoritative and recursive DNS server with example zones,\nTSIG authentication for secure zone transfers, and DNSSEC support.\n## References\n* **Project:** https://www.isc.org/bind/\n* **Documentation:** https://bind9.readthedocs.io/",
    "tags": [
      "network",
      "volume"
    ],
    "author": "Christian Lempa",
    "template_version": "9.20-24.10_edge",
    "date": "2025-10-02",
    "icon": {
      "provider": "simple-icons",
      "id": "iscbind"
    },
    "draft": true
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "dns-security",
      "title": "dns_security",
      "variables": [
        {
          "name": "dnssec_enabled",
          "type": "bool",
          "title": "Enable DNSSEC",
          "required": false,
          "description": "Enable DNSSEC"
        }
      ]
    },
    {
      "key": "dns-zone",
      "title": "dns_zone",
      "variables": [
        {
          "name": "domain_name",
          "type": "str",
          "title": "Primary domain name",
          "required": false,
          "default": "home.arpa",
          "description": "Primary domain name"
        },
        {
          "name": "tsig_enabled",
          "type": "bool",
          "title": "Enable TSIG",
          "required": false,
          "description": "Enable TSIG"
        },
        {
          "name": "tsig_key_secret",
          "type": "str",
          "title": "TSIG key secret",
          "required": false,
          "description": "TSIG key secret",
          "sensitive": true,
          "autogenerated": true,
          "needs": [
            "tsig_enabled=true"
          ]
        }
      ]
    },
    {
      "key": "volume",
      "title": "Volume",
      "variables": [
        {
          "name": "volume_mode",
          "type": "str",
          "title": "Volume Mode",
          "required": true,
          "default": "local",
          "options": [
            "local",
            "mount",
            "nfs"
          ]
        },
        {
          "name": "volume_mount_path",
          "type": "str",
          "title": "Volume Mount Path",
          "required": true,
          "default": "/mnt/storage",
          "needs": [
            "volume_mode=mount"
          ]
        },
        {
          "name": "volume_nfs_server",
          "type": "str",
          "title": "Volume Nfs Server",
          "required": true,
          "default": "192.168.1.1",
          "needs": [
            "volume_mode=nfs"
          ]
        },
        {
          "name": "volume_nfs_path",
          "type": "str",
          "title": "Volume Nfs Path",
          "required": true,
          "default": "/export",
          "needs": [
            "volume_mode=nfs"
          ]
        },
        {
          "name": "volume_nfs_options",
          "type": "str",
          "title": "Volume Nfs Options",
          "required": true,
          "default": "rw,nolock,soft",
          "needs": [
            "volume_mode=nfs"
          ]
        }
      ]
    },
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "bind9"
        },
        {
          "name": "container_hostname",
          "type": "str",
          "title": "Container Hostname",
          "required": false
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false
        },
        {
          "name": "restart_policy",
          "type": "str",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "options": [
            "unless-stopped",
            "always",
            "on-failure",
            "no"
          ]
        },
        {
          "name": "network_macvlan_parent_interface",
          "type": "str",
          "title": "Network Macvlan Parent Interface",
          "required": false,
          "default": ""
        },
        {
          "name": "network_macvlan_gateway",
          "type": "str",
          "title": "Network Macvlan Gateway",
          "required": false,
          "default": ""
        },
        {
          "name": "network_name",
          "type": "str",
          "title": "Network Name",
          "required": false,
          "default": ""
        },
        {
          "name": "network_macvlan_subnet",
          "type": "str",
          "title": "Network Macvlan Subnet",
          "required": false,
          "default": ""
        },
        {
          "name": "network_macvlan_ipv4_address",
          "type": "str",
          "title": "Network Macvlan Ipv4 Address",
          "required": false,
          "default": ""
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
