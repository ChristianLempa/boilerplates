{
  "version": "1",
  "slug": "bind9",
  "kind": "compose",
  "metadata": {
    "name": "BIND9",
    "description": "BIND9 is the most widely used DNS server on the Internet.\nThis template provides an authoritative and recursive DNS server with example zones,\nTSIG authentication for secure zone transfers, and DNSSEC support.\n## References\n* **Project:** https://www.isc.org/bind/\n* **Documentation:** https://bind9.readthedocs.io/",
    "tags": [
      "network",
      "volume"
    ],
    "author": "Christian Lempa",
    "template_version": "9.20-24.10_edge",
    "date": "2025-10-02",
    "icon": {
      "provider": "selfh",
      "id": "bind-9"
    },
    "draft": true
  },
  "entrypoint": {
    "path": "compose.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "dnssec_enabled",
      "type": "boolean",
      "label": "Enable DNSSEC",
      "required": false,
      "section": {
        "key": "dns_security",
        "title": "dns_security",
        "toggle": "dnssec_enabled",
        "description": "Configure DNSSEC signing"
      },
      "source_type": "bool",
      "description": "Enable DNSSEC"
    },
    {
      "key": "domain_name",
      "type": "string",
      "label": "Primary domain name",
      "required": false,
      "section": {
        "key": "dns_zone",
        "title": "dns_zone",
        "toggle": "tsig_enabled",
        "description": "Configure TSIG authentication for zone transfers"
      },
      "source_type": "str",
      "default": "home.arpa",
      "description": "Primary domain name"
    },
    {
      "key": "tsig_enabled",
      "type": "boolean",
      "label": "Enable TSIG",
      "required": false,
      "section": {
        "key": "dns_zone",
        "title": "dns_zone",
        "toggle": "tsig_enabled",
        "description": "Configure TSIG authentication for zone transfers"
      },
      "source_type": "bool",
      "description": "Enable TSIG"
    },
    {
      "key": "tsig_key_secret",
      "type": "string",
      "label": "TSIG key secret",
      "required": false,
      "section": {
        "key": "dns_zone",
        "title": "dns_zone",
        "toggle": "tsig_enabled",
        "description": "Configure TSIG authentication for zone transfers"
      },
      "source_type": "str",
      "description": "TSIG key secret",
      "needs": [
        "tsig_enabled=true"
      ],
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "volume_mode",
      "type": "string",
      "label": "Volume Mode",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "enum",
      "default": "local",
      "options": [
        "local",
        "mount",
        "nfs"
      ]
    },
    {
      "key": "volume_mount_path",
      "type": "string",
      "label": "Volume Mount Path",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "str",
      "default": "/mnt/storage",
      "needs": [
        "volume_mode=mount"
      ]
    },
    {
      "key": "volume_nfs_server",
      "type": "string",
      "label": "Volume Nfs Server",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "str",
      "default": "192.168.1.1",
      "needs": [
        "volume_mode=nfs"
      ]
    },
    {
      "key": "volume_nfs_path",
      "type": "string",
      "label": "Volume Nfs Path",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "str",
      "default": "/export",
      "needs": [
        "volume_mode=nfs"
      ]
    },
    {
      "key": "volume_nfs_options",
      "type": "string",
      "label": "Volume Nfs Options",
      "required": true,
      "section": {
        "key": "volume"
      },
      "source_type": "str",
      "default": "rw,nolock,soft",
      "needs": [
        "volume_mode=nfs"
      ]
    },
    {
      "key": "service_name",
      "type": "string",
      "label": "Service Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "bind9"
    },
    {
      "key": "container_hostname",
      "type": "string",
      "label": "Container Hostname",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str"
    },
    {
      "key": "container_timezone",
      "type": "string",
      "label": "Container Timezone",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str"
    },
    {
      "key": "restart_policy",
      "type": "string",
      "label": "Restart Policy",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "enum",
      "default": "unless-stopped",
      "options": [
        "unless-stopped",
        "always",
        "on-failure",
        "no"
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
