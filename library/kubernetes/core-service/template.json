{
  "version": "1",
  "slug": "core-service",
  "kind": "kubernetes",
  "metadata": {
    "name": "Kubernetes Service",
    "description": "Kubernetes Service resource for exposing applications running on a set of Pods.\n\nServices provide stable network endpoints and load balancing.\n\nDocumentation: https://kubernetes.io/docs/concepts/services-networking/service/\n",
    "author": "Christian Lempa",
    "template_version": "1.31.0",
    "icon": {
      "provider": "simple-icons",
      "id": "kubernetes"
    },
    "date": "2025-01-11"
  },
  "entrypoint": {
    "path": "service.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "resource_name",
          "type": "str",
          "title": "Resource Name",
          "required": false,
          "default": "app-service"
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Namespace",
          "required": false,
          "default": "default"
        },
        {
          "name": "service_type",
          "type": "str",
          "title": "Service type",
          "required": false,
          "default": "ClusterIP",
          "description": "Service type",
          "options": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer",
            "ExternalName"
          ]
        },
        {
          "name": "service_port",
          "type": "int",
          "title": "Service port",
          "required": false,
          "default": 80,
          "description": "Service port"
        },
        {
          "name": "target_port",
          "type": "int",
          "title": "Target port on pods",
          "required": false,
          "default": 8080,
          "description": "Target port on pods"
        },
        {
          "name": "protocol",
          "type": "str",
          "title": "Protocol",
          "required": false,
          "default": "TCP",
          "description": "Protocol",
          "options": [
            "TCP",
            "UDP",
            "SCTP"
          ]
        }
      ]
    },
    {
      "key": "resources",
      "title": "Resource Limits",
      "variables": [
        {
          "name": "resources_enabled",
          "type": "bool",
          "title": "Enable resource limits and requests",
          "required": false,
          "default": false,
          "description": "Enable resource limits and requests"
        },
        {
          "name": "resources_cpu_limit",
          "type": "str",
          "title": "CPU limit",
          "required": false,
          "default": "100m",
          "description": "CPU limit"
        },
        {
          "name": "resources_cpu_request",
          "type": "str",
          "title": "CPU request",
          "required": false,
          "default": "50m",
          "description": "CPU request"
        },
        {
          "name": "resources_memory_limit",
          "type": "str",
          "title": "Memory limit",
          "required": false,
          "default": "128Mi",
          "description": "Memory limit"
        },
        {
          "name": "resources_memory_request",
          "type": "str",
          "title": "Memory request",
          "required": false,
          "default": "64Mi",
          "description": "Memory request"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik Integration",
      "variables": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik host",
          "required": false,
          "description": "Traefik host"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik domain",
          "required": false,
          "description": "Traefik domain"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable TLS",
          "required": false,
          "default": true,
          "description": "Enable TLS"
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "TLS certificate resolver",
          "required": false,
          "default": "letsencrypt-prod",
          "description": "TLS certificate resolver"
        },
        {
          "name": "app_selector",
          "type": "str",
          "title": "App label selector (e.g., app.kubernetes.io/name value)",
          "required": false,
          "description": "App label selector (e.g., app.kubernetes.io/name value)"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
