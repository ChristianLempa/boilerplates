{
  "version": "1",
  "slug": "core-service",
  "kind": "kubernetes",
  "metadata": {
    "name": "Kubernetes Service",
    "description": "Kubernetes Service resource for exposing applications running on a set of Pods.\n\nServices provide stable network endpoints and load balancing.\n\nDocumentation: https://kubernetes.io/docs/concepts/services-networking/service/\n",
    "author": "Christian Lempa",
    "template_version": "1.31.0",
    "icon": {
      "provider": "selfh",
      "id": "kubernetes"
    },
    "date": "2025-01-11"
  },
  "entrypoint": {
    "path": "service.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "resource_name",
      "type": "string",
      "label": "Resource Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "app-service"
    },
    {
      "key": "namespace",
      "type": "string",
      "label": "Namespace",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "default"
    },
    {
      "key": "service_type",
      "type": "string",
      "label": "Service type",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "enum",
      "default": "ClusterIP",
      "description": "Service type",
      "options": [
        "ClusterIP",
        "NodePort",
        "LoadBalancer",
        "ExternalName"
      ]
    },
    {
      "key": "service_port",
      "type": "number",
      "label": "Service port",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "int",
      "default": 80,
      "description": "Service port"
    },
    {
      "key": "target_port",
      "type": "number",
      "label": "Target port on pods",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "int",
      "default": 8080,
      "description": "Target port on pods"
    },
    {
      "key": "protocol",
      "type": "string",
      "label": "Protocol",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "enum",
      "default": "TCP",
      "description": "Protocol",
      "options": [
        "TCP",
        "UDP",
        "SCTP"
      ]
    },
    {
      "key": "resources_enabled",
      "type": "boolean",
      "label": "Enable resource limits and requests",
      "required": false,
      "section": {
        "key": "resources",
        "title": "Resource Limits",
        "toggle": "resources_enabled"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable resource limits and requests"
    },
    {
      "key": "resources_cpu_limit",
      "type": "string",
      "label": "CPU limit",
      "required": false,
      "section": {
        "key": "resources",
        "title": "Resource Limits",
        "toggle": "resources_enabled"
      },
      "source_type": "str",
      "default": "100m",
      "description": "CPU limit"
    },
    {
      "key": "resources_cpu_request",
      "type": "string",
      "label": "CPU request",
      "required": false,
      "section": {
        "key": "resources",
        "title": "Resource Limits",
        "toggle": "resources_enabled"
      },
      "source_type": "str",
      "default": "50m",
      "description": "CPU request"
    },
    {
      "key": "resources_memory_limit",
      "type": "string",
      "label": "Memory limit",
      "required": false,
      "section": {
        "key": "resources",
        "title": "Resource Limits",
        "toggle": "resources_enabled"
      },
      "source_type": "str",
      "default": "128Mi",
      "description": "Memory limit"
    },
    {
      "key": "resources_memory_request",
      "type": "string",
      "label": "Memory request",
      "required": false,
      "section": {
        "key": "resources",
        "title": "Resource Limits",
        "toggle": "resources_enabled"
      },
      "source_type": "str",
      "default": "64Mi",
      "description": "Memory request"
    },
    {
      "key": "traefik_enabled",
      "type": "boolean",
      "label": "Enable Traefik integration",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Integration",
        "toggle": "traefik_enabled"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik integration"
    },
    {
      "key": "traefik_host",
      "type": "string",
      "label": "Traefik host",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Integration",
        "toggle": "traefik_enabled"
      },
      "source_type": "hostname",
      "description": "Traefik host"
    },
    {
      "key": "traefik_domain",
      "type": "string",
      "label": "Traefik domain",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Integration",
        "toggle": "traefik_enabled"
      },
      "source_type": "str",
      "description": "Traefik domain"
    },
    {
      "key": "traefik_tls_enabled",
      "type": "boolean",
      "label": "Enable TLS",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Integration",
        "toggle": "traefik_enabled"
      },
      "source_type": "bool",
      "default": true,
      "description": "Enable TLS"
    },
    {
      "key": "traefik_tls_certresolver",
      "type": "string",
      "label": "TLS certificate resolver",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Integration",
        "toggle": "traefik_enabled"
      },
      "source_type": "str",
      "default": "letsencrypt-prod",
      "description": "TLS certificate resolver"
    },
    {
      "key": "app_selector",
      "type": "string",
      "label": "App label selector (e.g., app.kubernetes.io/name value)",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Integration",
        "toggle": "traefik_enabled"
      },
      "source_type": "str",
      "description": "App label selector (e.g., app.kubernetes.io/name value)"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
