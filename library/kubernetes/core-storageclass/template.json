{
  "version": "1",
  "slug": "core-storageclass",
  "kind": "kubernetes",
  "metadata": {
    "name": "Kubernetes StorageClass",
    "description": "Kubernetes StorageClass for defining different types of storage that can be dynamically provisioned.\n\nStorageClass allows administrators to describe different storage \"classes\" available.\n\nDocumentation: https://kubernetes.io/docs/concepts/storage/storage-classes/\n",
    "author": "Christian Lempa",
    "template_version": "1.31.0",
    "icon": {
      "provider": "simple-icons",
      "id": "kubernetes"
    },
    "date": "2025-01-11"
  },
  "entrypoint": {
    "path": "storageclass.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "resource_name",
          "type": "str",
          "title": "Resource Name",
          "required": false,
          "default": "standard"
        },
        {
          "name": "provisioner",
          "type": "str",
          "title": "Storage provisioner (e.g., kubernetes.io/no-provisioner, longhorn)",
          "required": false,
          "default": "kubernetes.io/no-provisioner",
          "description": "Storage provisioner (e.g., kubernetes.io/no-provisioner, longhorn)"
        },
        {
          "name": "volume_binding_mode",
          "type": "str",
          "title": "Volume binding mode",
          "required": false,
          "default": "WaitForFirstConsumer",
          "description": "Volume binding mode",
          "options": [
            "Immediate",
            "WaitForFirstConsumer"
          ]
        },
        {
          "name": "reclaim_policy",
          "type": "str",
          "title": "Reclaim policy for volumes",
          "required": false,
          "default": "Delete",
          "description": "Reclaim policy for volumes",
          "options": [
            "Retain",
            "Delete"
          ]
        }
      ]
    },
    {
      "key": "resources",
      "title": "Resource Limits",
      "variables": [
        {
          "name": "resources_enabled",
          "type": "bool",
          "title": "Enable resource limits and requests",
          "required": false,
          "default": false,
          "description": "Enable resource limits and requests"
        },
        {
          "name": "resources_cpu_limit",
          "type": "str",
          "title": "CPU limit",
          "required": false,
          "default": "100m",
          "description": "CPU limit"
        },
        {
          "name": "resources_cpu_request",
          "type": "str",
          "title": "CPU request",
          "required": false,
          "default": "50m",
          "description": "CPU request"
        },
        {
          "name": "resources_memory_limit",
          "type": "str",
          "title": "Memory limit",
          "required": false,
          "default": "128Mi",
          "description": "Memory limit"
        },
        {
          "name": "resources_memory_request",
          "type": "str",
          "title": "Memory request",
          "required": false,
          "default": "64Mi",
          "description": "Memory request"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik Integration",
      "variables": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik host",
          "required": false,
          "description": "Traefik host"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik domain",
          "required": false,
          "description": "Traefik domain"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable TLS",
          "required": false,
          "default": true,
          "description": "Enable TLS"
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "TLS certificate resolver",
          "required": false,
          "default": "letsencrypt-prod",
          "description": "TLS certificate resolver"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
