{
  "version": "1",
  "slug": "certmanager-certificate",
  "kind": "kubernetes",
  "metadata": {
    "name": "Cert-Manager Certificate",
    "description": "Cert-manager Certificate resource for requesting TLS certificates from an Issuer or ClusterIssuer.\n\nThe certificate will be stored in a Kubernetes secret.\n\nRequires cert-manager to be installed in the cluster.\n\nProject: https://cert-manager.io\nDocumentation: https://cert-manager.io/docs/usage/certificate/\n",
    "author": "Christian Lempa",
    "template_version": "1.16.2",
    "icon": {
      "provider": "simple-icons",
      "id": "letsencrypt"
    },
    "date": "2025-01-11"
  },
  "entrypoint": {
    "path": "certificate.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "resource_name",
          "type": "str",
          "title": "Resource Name",
          "required": false,
          "default": "tls-certificate"
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Namespace",
          "required": false,
          "default": "default"
        },
        {
          "name": "secret_name",
          "type": "str",
          "title": "Name of secret to store the certificate",
          "required": false,
          "default": "tls-secret",
          "description": "Name of secret to store the certificate"
        },
        {
          "name": "dns_name",
          "type": "str",
          "title": "Dns Name",
          "required": false,
          "default": ""
        }
      ]
    },
    {
      "key": "resources",
      "title": "Resource Limits",
      "variables": [
        {
          "name": "resources_enabled",
          "type": "bool",
          "title": "Enable resource limits and requests",
          "required": false,
          "default": false,
          "description": "Enable resource limits and requests"
        },
        {
          "name": "resources_cpu_limit",
          "type": "str",
          "title": "CPU limit",
          "required": false,
          "default": "100m",
          "description": "CPU limit"
        },
        {
          "name": "resources_cpu_request",
          "type": "str",
          "title": "CPU request",
          "required": false,
          "default": "50m",
          "description": "CPU request"
        },
        {
          "name": "resources_memory_limit",
          "type": "str",
          "title": "Memory limit",
          "required": false,
          "default": "128Mi",
          "description": "Memory limit"
        },
        {
          "name": "resources_memory_request",
          "type": "str",
          "title": "Memory request",
          "required": false,
          "default": "64Mi",
          "description": "Memory request"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik Integration",
      "variables": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik host",
          "required": false,
          "description": "Traefik host"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik domain",
          "required": false,
          "description": "Traefik domain"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable TLS",
          "required": false,
          "default": true,
          "description": "Enable TLS"
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "TLS certificate resolver",
          "required": false,
          "default": "letsencrypt-prod",
          "description": "TLS certificate resolver"
        }
      ]
    },
    {
      "key": "dns",
      "title": "DNS Settings",
      "variables": [
        {
          "name": "dns_names",
          "type": "str",
          "title": "DNS names for certificate (comma-separated, e.g., example.com,*.example.com)",
          "required": false,
          "description": "DNS names for certificate (comma-separated, e.g., example.com,*.example.com)"
        }
      ]
    },
    {
      "key": "certmanager",
      "title": "Cert-Manager Settings",
      "variables": [
        {
          "name": "certmanager_issuer",
          "type": "str",
          "title": "Cert-manager Issuer or ClusterIssuer name",
          "required": false,
          "default": "letsencrypt-prod",
          "description": "Cert-manager Issuer or ClusterIssuer name"
        },
        {
          "name": "certmanager_issuer_kind",
          "type": "str",
          "title": "Issuer type",
          "required": false,
          "default": "ClusterIssuer",
          "description": "Issuer type",
          "options": [
            "Issuer",
            "ClusterIssuer"
          ]
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
