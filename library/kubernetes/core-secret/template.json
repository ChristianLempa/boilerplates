{
  "version": "1",
  "slug": "core-secret",
  "kind": "kubernetes",
  "metadata": {
    "name": "Kubernetes Secret (Opaque)",
    "description": "Basic Kubernetes Secret with Opaque type for storing sensitive data like API tokens, passwords, or keys.\n\nData must be base64 encoded.\n\nDocumentation: https://kubernetes.io/docs/concepts/configuration/secret/\n",
    "author": "Christian Lempa",
    "template_version": "1.31.0",
    "icon": {
      "provider": "selfh",
      "id": "kubernetes"
    },
    "date": "2025-01-11"
  },
  "entrypoint": {
    "path": "secret.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "resource_name",
      "type": "string",
      "label": "Resource Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "api-token-secret"
    },
    {
      "key": "namespace",
      "type": "string",
      "label": "Namespace",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "default"
    },
    {
      "key": "secret_type",
      "type": "string",
      "label": "Secret type",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "Opaque",
      "description": "Secret type"
    },
    {
      "key": "api_token",
      "type": "string",
      "label": "API token value (plain text, Kubernetes will encode it)",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "",
      "description": "API token value (plain text, Kubernetes will encode it)",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "resources_enabled",
      "type": "boolean",
      "label": "Enable resource limits and requests",
      "required": false,
      "section": {
        "key": "resources",
        "title": "Resource Limits",
        "toggle": "resources_enabled"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable resource limits and requests"
    },
    {
      "key": "resources_cpu_limit",
      "type": "string",
      "label": "CPU limit",
      "required": false,
      "section": {
        "key": "resources",
        "title": "Resource Limits",
        "toggle": "resources_enabled"
      },
      "source_type": "str",
      "default": "100m",
      "description": "CPU limit"
    },
    {
      "key": "resources_cpu_request",
      "type": "string",
      "label": "CPU request",
      "required": false,
      "section": {
        "key": "resources",
        "title": "Resource Limits",
        "toggle": "resources_enabled"
      },
      "source_type": "str",
      "default": "50m",
      "description": "CPU request"
    },
    {
      "key": "resources_memory_limit",
      "type": "string",
      "label": "Memory limit",
      "required": false,
      "section": {
        "key": "resources",
        "title": "Resource Limits",
        "toggle": "resources_enabled"
      },
      "source_type": "str",
      "default": "128Mi",
      "description": "Memory limit"
    },
    {
      "key": "resources_memory_request",
      "type": "string",
      "label": "Memory request",
      "required": false,
      "section": {
        "key": "resources",
        "title": "Resource Limits",
        "toggle": "resources_enabled"
      },
      "source_type": "str",
      "default": "64Mi",
      "description": "Memory request"
    },
    {
      "key": "traefik_enabled",
      "type": "boolean",
      "label": "Enable Traefik integration",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Integration",
        "toggle": "traefik_enabled"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik integration"
    },
    {
      "key": "traefik_host",
      "type": "string",
      "label": "Traefik host",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Integration",
        "toggle": "traefik_enabled"
      },
      "source_type": "hostname",
      "description": "Traefik host"
    },
    {
      "key": "traefik_domain",
      "type": "string",
      "label": "Traefik domain",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Integration",
        "toggle": "traefik_enabled"
      },
      "source_type": "str",
      "description": "Traefik domain"
    },
    {
      "key": "traefik_tls_enabled",
      "type": "boolean",
      "label": "Enable TLS",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Integration",
        "toggle": "traefik_enabled"
      },
      "source_type": "bool",
      "default": true,
      "description": "Enable TLS"
    },
    {
      "key": "traefik_tls_certresolver",
      "type": "string",
      "label": "TLS certificate resolver",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Integration",
        "toggle": "traefik_enabled"
      },
      "source_type": "str",
      "default": "letsencrypt-prod",
      "description": "TLS certificate resolver"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
