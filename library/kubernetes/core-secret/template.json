{
  "version": "1",
  "slug": "core-secret",
  "kind": "kubernetes",
  "metadata": {
    "name": "Kubernetes Secret (Opaque)",
    "description": "Basic Kubernetes Secret with Opaque type for storing sensitive data like API tokens, passwords, or keys.\n\nData must be base64 encoded.\n\nDocumentation: https://kubernetes.io/docs/concepts/configuration/secret/\n",
    "author": "Christian Lempa",
    "template_version": "1.31.0",
    "icon": {
      "provider": "simple-icons",
      "id": "kubernetes"
    },
    "date": "2025-01-11"
  },
  "entrypoint": {
    "path": "manifest.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "resource_name",
          "type": "str",
          "title": "Resource Name",
          "required": false,
          "default": "api-token-secret"
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Namespace",
          "required": false,
          "default": "default"
        },
        {
          "name": "secret_type",
          "type": "str",
          "title": "Secret type",
          "required": false,
          "default": "Opaque",
          "description": "Secret type"
        },
        {
          "name": "api_token",
          "type": "str",
          "title": "API token value (plain text, Kubernetes will encode it)",
          "required": false,
          "default": "",
          "description": "API token value (plain text, Kubernetes will encode it)",
          "sensitive": true,
          "autogenerated": true
        }
      ]
    },
    {
      "key": "resources",
      "title": "Resource Limits",
      "variables": [
        {
          "name": "resources_enabled",
          "type": "bool",
          "title": "Enable resource limits and requests",
          "required": false,
          "default": false,
          "description": "Enable resource limits and requests"
        },
        {
          "name": "resources_cpu_limit",
          "type": "str",
          "title": "CPU limit",
          "required": false,
          "default": "100m",
          "description": "CPU limit"
        },
        {
          "name": "resources_cpu_request",
          "type": "str",
          "title": "CPU request",
          "required": false,
          "default": "50m",
          "description": "CPU request"
        },
        {
          "name": "resources_memory_limit",
          "type": "str",
          "title": "Memory limit",
          "required": false,
          "default": "128Mi",
          "description": "Memory limit"
        },
        {
          "name": "resources_memory_request",
          "type": "str",
          "title": "Memory request",
          "required": false,
          "default": "64Mi",
          "description": "Memory request"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik Integration",
      "variables": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik host",
          "required": false,
          "description": "Traefik host"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik domain",
          "required": false,
          "description": "Traefik domain"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable TLS",
          "required": false,
          "default": true,
          "description": "Enable TLS"
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "TLS certificate resolver",
          "required": false,
          "default": "letsencrypt-prod",
          "description": "TLS certificate resolver"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
