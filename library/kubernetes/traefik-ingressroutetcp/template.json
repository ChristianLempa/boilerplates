{
  "version": "1",
  "slug": "traefik-ingressroutetcp",
  "kind": "kubernetes",
  "metadata": {
    "name": "Traefik IngressRouteTCP",
    "description": "Traefik IngressRouteTCP CRD for TCP routing (non-HTTP protocols).\n\nUse for database connections, SSH, or any TCP-based protocol.\n\nRequires Traefik to be installed as the Ingress controller.\n\nProject: https://traefik.io\nDocumentation: https://doc.traefik.io/traefik/routing/providers/kubernetes-crd/#kind-ingressroutetcp\n",
    "author": "Christian Lempa",
    "template_version": "3.5.3",
    "icon": {
      "provider": "simple-icons",
      "id": "traefikproxy"
    },
    "date": "2025-01-11"
  },
  "entrypoint": {
    "path": "ingressroutetcp.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "resource_name",
          "type": "str",
          "title": "Resource Name",
          "required": false,
          "default": "app-tcp-route"
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Namespace",
          "required": false,
          "default": "default"
        }
      ]
    },
    {
      "key": "resources",
      "title": "Resource Limits",
      "variables": [
        {
          "name": "resources_enabled",
          "type": "bool",
          "title": "Enable resource limits and requests",
          "required": false,
          "default": false,
          "description": "Enable resource limits and requests"
        },
        {
          "name": "resources_cpu_limit",
          "type": "str",
          "title": "CPU limit",
          "required": false,
          "default": "100m",
          "description": "CPU limit"
        },
        {
          "name": "resources_cpu_request",
          "type": "str",
          "title": "CPU request",
          "required": false,
          "default": "50m",
          "description": "CPU request"
        },
        {
          "name": "resources_memory_limit",
          "type": "str",
          "title": "Memory limit",
          "required": false,
          "default": "128Mi",
          "description": "Memory limit"
        },
        {
          "name": "resources_memory_request",
          "type": "str",
          "title": "Memory request",
          "required": false,
          "default": "64Mi",
          "description": "Memory request"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik Configuration",
      "variables": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": true,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik host",
          "required": false,
          "description": "Traefik host"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik domain",
          "required": false,
          "description": "Traefik domain"
        },
        {
          "name": "traefik_entrypoint",
          "type": "str",
          "title": "Traefik entrypoint for TCP routing",
          "required": false,
          "default": "tcp",
          "description": "Traefik entrypoint for TCP routing"
        },
        {
          "name": "traefik_service_name",
          "type": "str",
          "title": "Backend service name for TCP routing",
          "required": false,
          "description": "Backend service name for TCP routing"
        },
        {
          "name": "traefik_service_port",
          "type": "int",
          "title": "Backend service port for TCP routing",
          "required": false,
          "default": 5432,
          "description": "Backend service port for TCP routing"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable TLS",
          "required": false,
          "default": false,
          "description": "Enable TLS"
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "TLS certificate resolver",
          "required": false,
          "default": "letsencrypt-prod",
          "description": "TLS certificate resolver"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
