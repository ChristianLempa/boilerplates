{
  "version": "1",
  "slug": "certmanager-issuer",
  "kind": "kubernetes",
  "metadata": {
    "name": "Cert-Manager Issuer (Cloudflare)",
    "description": "Cert-manager Issuer for automatic TLS certificate management with Let's Encrypt and Cloudflare DNS-01 challenge.\n\nIssuer is namespace-scoped (unlike ClusterIssuer which is cluster-wide).\n\nRequires cert-manager to be installed in the cluster.\n\nProject: https://cert-manager.io\nDocumentation: https://cert-manager.io/docs/configuration/acme/dns01/cloudflare/\n",
    "author": "Christian Lempa",
    "template_version": "1.16.2",
    "icon": {
      "provider": "simple-icons",
      "id": "letsencrypt"
    },
    "date": "2025-01-11"
  },
  "entrypoint": {
    "path": "issuer.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "resource_name",
          "type": "str",
          "title": "Resource Name",
          "required": false,
          "default": "cloudflare-issuer"
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Namespace",
          "required": false,
          "default": "default"
        },
        {
          "name": "acme_email",
          "type": "str",
          "title": "Email address for ACME account registration",
          "required": false,
          "description": "Email address for ACME account registration"
        },
        {
          "name": "acme_server",
          "type": "str",
          "title": "ACME server URL",
          "required": false,
          "default": "https://acme-v02.api.letsencrypt.org/directory",
          "description": "ACME server URL"
        },
        {
          "name": "privatekey_secret_name",
          "type": "str",
          "title": "Name of secret to store ACME account private key",
          "required": false,
          "default": "cloudflare-issuer-account-key",
          "description": "Name of secret to store ACME account private key"
        },
        {
          "name": "api_token_secret_name",
          "type": "str",
          "title": "Name of secret containing Cloudflare API token",
          "required": false,
          "default": "cloudflare-api-token-secret",
          "description": "Name of secret containing Cloudflare API token"
        },
        {
          "name": "api_token_secret_key",
          "type": "str",
          "title": "Key name in secret containing Cloudflare API token",
          "required": false,
          "default": "api-token",
          "description": "Key name in secret containing Cloudflare API token"
        }
      ]
    },
    {
      "key": "resources",
      "title": "Resource Limits",
      "variables": [
        {
          "name": "resources_enabled",
          "type": "bool",
          "title": "Enable resource limits and requests",
          "required": false,
          "default": false,
          "description": "Enable resource limits and requests"
        },
        {
          "name": "resources_cpu_limit",
          "type": "str",
          "title": "CPU limit",
          "required": false,
          "default": "100m",
          "description": "CPU limit"
        },
        {
          "name": "resources_cpu_request",
          "type": "str",
          "title": "CPU request",
          "required": false,
          "default": "50m",
          "description": "CPU request"
        },
        {
          "name": "resources_memory_limit",
          "type": "str",
          "title": "Memory limit",
          "required": false,
          "default": "128Mi",
          "description": "Memory limit"
        },
        {
          "name": "resources_memory_request",
          "type": "str",
          "title": "Memory request",
          "required": false,
          "default": "64Mi",
          "description": "Memory request"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik Integration",
      "variables": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik host",
          "required": false,
          "description": "Traefik host"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik domain",
          "required": false,
          "description": "Traefik domain"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable TLS",
          "required": false,
          "default": true,
          "description": "Enable TLS"
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "TLS certificate resolver",
          "required": false,
          "default": "letsencrypt-prod",
          "description": "TLS certificate resolver"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
