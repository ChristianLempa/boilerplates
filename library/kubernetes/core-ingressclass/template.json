{
  "version": "1",
  "slug": "core-ingressclass",
  "kind": "kubernetes",
  "metadata": {
    "name": "Kubernetes IngressClass",
    "description": "Kubernetes IngressClass for specifying which Ingress controller should handle Ingress resources.\n\nIngressClass is cluster-scoped and defines ingress controller implementations.\n\nDocumentation: https://kubernetes.io/docs/concepts/services-networking/ingress/#ingress-class\n",
    "author": "Christian Lempa",
    "template_version": "1.31.0",
    "icon": {
      "provider": "simple-icons",
      "id": "kubernetes"
    },
    "date": "2025-01-11"
  },
  "entrypoint": {
    "path": "ingressclass.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "resource_name",
          "type": "str",
          "title": "Resource Name",
          "required": false,
          "default": "nginx"
        },
        {
          "name": "controller",
          "type": "str",
          "title": "Ingress controller identifier (e.g., k8s.io/ingress-nginx)",
          "required": false,
          "default": "k8s.io/ingress-nginx",
          "description": "Ingress controller identifier (e.g., k8s.io/ingress-nginx)"
        },
        {
          "name": "is_default",
          "type": "bool",
          "title": "Set as default IngressClass",
          "required": false,
          "default": false,
          "description": "Set as default IngressClass"
        }
      ]
    },
    {
      "key": "resources",
      "title": "Resource Limits",
      "variables": [
        {
          "name": "resources_enabled",
          "type": "bool",
          "title": "Enable resource limits and requests",
          "required": false,
          "default": false,
          "description": "Enable resource limits and requests"
        },
        {
          "name": "resources_cpu_limit",
          "type": "str",
          "title": "CPU limit",
          "required": false,
          "default": "100m",
          "description": "CPU limit"
        },
        {
          "name": "resources_cpu_request",
          "type": "str",
          "title": "CPU request",
          "required": false,
          "default": "50m",
          "description": "CPU request"
        },
        {
          "name": "resources_memory_limit",
          "type": "str",
          "title": "Memory limit",
          "required": false,
          "default": "128Mi",
          "description": "Memory limit"
        },
        {
          "name": "resources_memory_request",
          "type": "str",
          "title": "Memory request",
          "required": false,
          "default": "64Mi",
          "description": "Memory request"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik Integration",
      "variables": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik host",
          "required": false,
          "description": "Traefik host"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik domain",
          "required": false,
          "description": "Traefik domain"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable TLS",
          "required": false,
          "default": true,
          "description": "Enable TLS"
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "TLS certificate resolver",
          "required": false,
          "default": "letsencrypt-prod",
          "description": "TLS certificate resolver"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
