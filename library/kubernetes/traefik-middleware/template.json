{
  "version": "1",
  "slug": "traefik-middleware",
  "kind": "kubernetes",
  "metadata": {
    "name": "Traefik Middleware",
    "description": "Traefik Middleware CRD for modifying requests and responses.\n\nMiddlewares can add headers, redirect, rate-limit, authenticate, and more.\n\nRequires Traefik to be installed as the Ingress controller.\n\nProject: https://traefik.io\nDocumentation: https://doc.traefik.io/traefik/middlewares/overview/",
    "tags": [],
    "author": "Christian Lempa",
    "template_version": "3.5.3",
    "date": "2025-01-11",
    "icon": {
      "provider": "simple-icons",
      "id": "traefikproxy"
    },
    "draft": false,
    "next_steps": ""
  },
  "entrypoint": {
    "path": "middleware.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "resource_name",
          "type": "str",
          "title": "Resource Name",
          "required": false,
          "default": "app-middleware"
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Namespace",
          "required": false,
          "default": "default"
        },
        {
          "name": "middleware_type",
          "type": "str",
          "title": "Middleware type",
          "required": false,
          "default": "redirectScheme",
          "description": "Middleware type",
          "options": [
            "redirectScheme",
            "stripPrefix",
            "addPrefix",
            "headers",
            "rateLimit"
          ]
        }
      ]
    },
    {
      "key": "resources",
      "title": "Resource Limits",
      "variables": [
        {
          "name": "resources_enabled",
          "type": "bool",
          "title": "Enable resource limits and requests",
          "required": false,
          "default": false,
          "description": "Enable resource limits and requests"
        },
        {
          "name": "resources_cpu_limit",
          "type": "str",
          "title": "CPU limit",
          "required": false,
          "default": "100m",
          "description": "CPU limit"
        },
        {
          "name": "resources_cpu_request",
          "type": "str",
          "title": "CPU request",
          "required": false,
          "default": "50m",
          "description": "CPU request"
        },
        {
          "name": "resources_memory_limit",
          "type": "str",
          "title": "Memory limit",
          "required": false,
          "default": "128Mi",
          "description": "Memory limit"
        },
        {
          "name": "resources_memory_request",
          "type": "str",
          "title": "Memory request",
          "required": false,
          "default": "64Mi",
          "description": "Memory request"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik Integration",
      "variables": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik host",
          "required": false,
          "description": "Traefik host"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik domain",
          "required": false,
          "description": "Traefik domain"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable TLS",
          "required": false,
          "default": true,
          "description": "Enable TLS"
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "TLS certificate resolver",
          "required": false,
          "default": "letsencrypt-prod",
          "description": "TLS certificate resolver"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
