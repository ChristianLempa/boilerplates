{
  "version": "1",
  "slug": "traefik-ingressroute",
  "kind": "kubernetes",
  "metadata": {
    "name": "Traefik IngressRoute",
    "description": "Traefik IngressRoute CRD for HTTP/HTTPS routing with advanced features.\n\nRequires Traefik to be installed as the Ingress controller.\n\nProject: https://traefik.io\nDocumentation: https://doc.traefik.io/traefik/routing/providers/kubernetes-crd/\n",
    "author": "Christian Lempa",
    "template_version": "3.5.3",
    "icon": {
      "provider": "simple-icons",
      "id": "traefikproxy"
    },
    "date": "2025-01-11"
  },
  "entrypoint": {
    "path": "ingressroute.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "resource_name",
          "type": "str",
          "title": "Resource Name",
          "required": false,
          "default": "app-ingressroute"
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Namespace",
          "required": false,
          "default": "default"
        },
        {
          "name": "traefik_entrypoint",
          "type": "str",
          "title": "Traefik entrypoint for HTTP (e.g., web)",
          "required": false,
          "default": "web",
          "description": "Traefik entrypoint for HTTP (e.g., web)"
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "Traefik entrypoint for HTTPS (e.g., websecure)",
          "required": false,
          "default": "websecure",
          "description": "Traefik entrypoint for HTTPS (e.g., websecure)"
        },
        {
          "name": "traefik_service_name",
          "type": "str",
          "title": "Kubernetes service name to route traffic to",
          "required": false,
          "description": "Kubernetes service name to route traffic to"
        },
        {
          "name": "traefik_service_port",
          "type": "int",
          "title": "Kubernetes service port",
          "required": false,
          "default": 80,
          "description": "Kubernetes service port"
        }
      ]
    },
    {
      "key": "resources",
      "title": "Resource Limits",
      "variables": [
        {
          "name": "resources_enabled",
          "type": "bool",
          "title": "Enable resource limits and requests",
          "required": false,
          "default": false,
          "description": "Enable resource limits and requests"
        },
        {
          "name": "resources_cpu_limit",
          "type": "str",
          "title": "CPU limit",
          "required": false,
          "default": "100m",
          "description": "CPU limit"
        },
        {
          "name": "resources_cpu_request",
          "type": "str",
          "title": "CPU request",
          "required": false,
          "default": "50m",
          "description": "CPU request"
        },
        {
          "name": "resources_memory_limit",
          "type": "str",
          "title": "Memory limit",
          "required": false,
          "default": "128Mi",
          "description": "Memory limit"
        },
        {
          "name": "resources_memory_request",
          "type": "str",
          "title": "Memory request",
          "required": false,
          "default": "64Mi",
          "description": "Memory request"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik Configuration",
      "variables": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": true,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Domain name for the IngressRoute",
          "required": false,
          "description": "Domain name for the IngressRoute"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik domain",
          "required": false,
          "description": "Traefik domain"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable TLS",
          "required": false,
          "default": true,
          "description": "Enable TLS"
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "TLS certificate resolver",
          "required": false,
          "default": "letsencrypt-prod",
          "description": "TLS certificate resolver"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
