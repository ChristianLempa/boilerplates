{
  "version": "1",
  "slug": "twingate-connector",
  "kind": "kubernetes",
  "metadata": {
    "name": "Twingate Connector",
    "description": "Twingate Connector for secure zero-trust network access.\n\nRequires the Twingate Kubernetes Operator to be installed in the cluster.\n\nProject: https://www.twingate.com\nDocumentation: https://docs.twingate.com/docs/connector-kubernetes-operator",
    "tags": [],
    "author": "Christian Lempa",
    "template_version": "1.74.0",
    "date": "2025-01-11",
    "icon": {
      "provider": "selfh",
      "id": "twingate"
    },
    "draft": false,
    "next_steps": ""
  },
  "entrypoint": {
    "path": "connector.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "resource_name",
      "type": "string",
      "label": "Resource Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "twingate-connector"
    },
    {
      "key": "namespace",
      "type": "string",
      "label": "Namespace",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "default"
    },
    {
      "key": "image_tag",
      "type": "string",
      "label": "Twingate connector image tag",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "1.74.0",
      "description": "Twingate connector image tag"
    },
    {
      "key": "connector_name",
      "type": "string",
      "label": "Twingate connector name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "description": "Twingate connector name"
    },
    {
      "key": "status_notifications",
      "type": "boolean",
      "label": "Enable status notifications",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "bool",
      "default": true,
      "description": "Enable status notifications"
    },
    {
      "key": "resources_enabled",
      "type": "boolean",
      "label": "Enable resource limits and requests",
      "required": false,
      "section": {
        "key": "resources",
        "title": "Resource Limits",
        "toggle": "resources_enabled"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable resource limits and requests"
    },
    {
      "key": "resources_cpu_limit",
      "type": "string",
      "label": "CPU limit",
      "required": false,
      "section": {
        "key": "resources",
        "title": "Resource Limits",
        "toggle": "resources_enabled"
      },
      "source_type": "str",
      "default": "100m",
      "description": "CPU limit"
    },
    {
      "key": "resources_cpu_request",
      "type": "string",
      "label": "CPU request",
      "required": false,
      "section": {
        "key": "resources",
        "title": "Resource Limits",
        "toggle": "resources_enabled"
      },
      "source_type": "str",
      "default": "50m",
      "description": "CPU request"
    },
    {
      "key": "resources_memory_limit",
      "type": "string",
      "label": "Memory limit",
      "required": false,
      "section": {
        "key": "resources",
        "title": "Resource Limits",
        "toggle": "resources_enabled"
      },
      "source_type": "str",
      "default": "128Mi",
      "description": "Memory limit"
    },
    {
      "key": "resources_memory_request",
      "type": "string",
      "label": "Memory request",
      "required": false,
      "section": {
        "key": "resources",
        "title": "Resource Limits",
        "toggle": "resources_enabled"
      },
      "source_type": "str",
      "default": "64Mi",
      "description": "Memory request"
    },
    {
      "key": "traefik_enabled",
      "type": "boolean",
      "label": "Enable Traefik integration",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Integration",
        "toggle": "traefik_enabled"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik integration"
    },
    {
      "key": "traefik_host",
      "type": "string",
      "label": "Traefik host",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Integration",
        "toggle": "traefik_enabled"
      },
      "source_type": "hostname",
      "description": "Traefik host"
    },
    {
      "key": "traefik_domain",
      "type": "string",
      "label": "Traefik domain",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Integration",
        "toggle": "traefik_enabled"
      },
      "source_type": "str",
      "description": "Traefik domain"
    },
    {
      "key": "traefik_tls_enabled",
      "type": "boolean",
      "label": "Enable TLS",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Integration",
        "toggle": "traefik_enabled"
      },
      "source_type": "bool",
      "default": true,
      "description": "Enable TLS"
    },
    {
      "key": "traefik_tls_certresolver",
      "type": "string",
      "label": "TLS certificate resolver",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Integration",
        "toggle": "traefik_enabled"
      },
      "source_type": "str",
      "default": "letsencrypt-prod",
      "description": "TLS certificate resolver"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
