{
  "version": "1",
  "slug": "twingate-connector",
  "kind": "kubernetes",
  "metadata": {
    "name": "Twingate Connector",
    "description": "Twingate Connector for secure zero-trust network access.\n\nRequires the Twingate Kubernetes Operator to be installed in the cluster.\n\nProject: https://www.twingate.com\nDocumentation: https://docs.twingate.com/docs/connector-kubernetes-operator",
    "tags": [],
    "author": "Christian Lempa",
    "template_version": "1.74.0",
    "date": "2025-01-11",
    "icon": {
      "provider": "simple-icons",
      "id": "twingate"
    },
    "draft": false,
    "next_steps": ""
  },
  "entrypoint": {
    "path": "connector.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "resource_name",
          "type": "str",
          "title": "Resource Name",
          "required": false,
          "default": "twingate-connector"
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Namespace",
          "required": false,
          "default": "default"
        },
        {
          "name": "image_tag",
          "type": "str",
          "title": "Twingate connector image tag",
          "required": false,
          "default": "1.74.0",
          "description": "Twingate connector image tag"
        },
        {
          "name": "connector_name",
          "type": "str",
          "title": "Twingate connector name",
          "required": false,
          "description": "Twingate connector name"
        },
        {
          "name": "status_notifications",
          "type": "bool",
          "title": "Enable status notifications",
          "required": false,
          "default": true,
          "description": "Enable status notifications"
        }
      ]
    },
    {
      "key": "resources",
      "title": "Resource Limits",
      "variables": [
        {
          "name": "resources_enabled",
          "type": "bool",
          "title": "Enable resource limits and requests",
          "required": false,
          "default": false,
          "description": "Enable resource limits and requests"
        },
        {
          "name": "resources_cpu_limit",
          "type": "str",
          "title": "CPU limit",
          "required": false,
          "default": "100m",
          "description": "CPU limit"
        },
        {
          "name": "resources_cpu_request",
          "type": "str",
          "title": "CPU request",
          "required": false,
          "default": "50m",
          "description": "CPU request"
        },
        {
          "name": "resources_memory_limit",
          "type": "str",
          "title": "Memory limit",
          "required": false,
          "default": "128Mi",
          "description": "Memory limit"
        },
        {
          "name": "resources_memory_request",
          "type": "str",
          "title": "Memory request",
          "required": false,
          "default": "64Mi",
          "description": "Memory request"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik Integration",
      "variables": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik integration",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik host",
          "required": false,
          "description": "Traefik host"
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik domain",
          "required": false,
          "description": "Traefik domain"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable TLS",
          "required": false,
          "default": true,
          "description": "Enable TLS"
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "TLS certificate resolver",
          "required": false,
          "default": "letsencrypt-prod",
          "description": "TLS certificate resolver"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
