{
  "version": "1",
  "slug": "checkmk-install-agent",
  "kind": "ansible",
  "metadata": {
    "name": "Install Checkmk Agent",
    "description": "Ansible playbook to install Checkmk monitoring agent on hosts. Uses the checkmk.general.agent role with automatic registration.\n## References\n- **Project**: https://github.com/Checkmk/ansible-collection-checkmk.general\n- **Documentation**: https://docs.checkmk.com/",
    "tags": [],
    "author": "Christian Lempa",
    "template_version": "2.4.0",
    "date": "2025-11-11",
    "icon": {
      "provider": "selfh",
      "id": "checkmk"
    },
    "draft": false,
    "next_steps": ""
  },
  "entrypoint": {
    "path": "playbook.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "target_hosts",
      "type": "string",
      "label": "Target hosts",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "description": "Target hosts"
    },
    {
      "key": "checkmk_server",
      "type": "string",
      "label": "Checkmk Server",
      "required": true,
      "section": {
        "key": "checkmk",
        "title": "Checkmk Configuration"
      },
      "source_type": "str",
      "description": "Checkmk Server"
    },
    {
      "key": "checkmk_protocol",
      "type": "string",
      "label": "Checkmk Server Protocol",
      "required": true,
      "section": {
        "key": "checkmk",
        "title": "Checkmk Configuration"
      },
      "source_type": "str",
      "default": "https",
      "description": "Checkmk Server Protocol"
    },
    {
      "key": "checkmk_site",
      "type": "string",
      "label": "Checkmk Site",
      "required": true,
      "section": {
        "key": "checkmk",
        "title": "Checkmk Configuration"
      },
      "source_type": "str",
      "default": "cmk",
      "description": "Checkmk Site"
    },
    {
      "key": "checkmk_auto_activate",
      "type": "boolean",
      "label": "Auto Activate Agent",
      "required": false,
      "section": {
        "key": "checkmk",
        "title": "Checkmk Configuration"
      },
      "source_type": "bool",
      "description": "Auto Activate Agent"
    },
    {
      "key": "checkmk_tls",
      "type": "boolean",
      "label": "Use TLS for Agent Communication",
      "required": false,
      "section": {
        "key": "checkmk",
        "title": "Checkmk Configuration"
      },
      "source_type": "bool",
      "description": "Use TLS for Agent Communication"
    },
    {
      "key": "checkmk_user",
      "type": "string",
      "label": "Checkmk Automation User",
      "required": true,
      "section": {
        "key": "checkmk",
        "title": "Checkmk Configuration"
      },
      "source_type": "str",
      "description": "Checkmk Automation User"
    },
    {
      "key": "checkmk_pass",
      "type": "string",
      "label": "Checkmk Automation User Password",
      "required": true,
      "section": {
        "key": "checkmk",
        "title": "Checkmk Configuration"
      },
      "source_type": "str",
      "description": "Checkmk Automation User Password",
      "sensitive": true
    },
    {
      "key": "checkmk_host",
      "type": "string",
      "label": "Checkmk Host Name",
      "required": true,
      "section": {
        "key": "checkmk",
        "title": "Checkmk Configuration"
      },
      "source_type": "str",
      "description": "Checkmk Host Name"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
