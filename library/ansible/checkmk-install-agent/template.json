{
  "version": "1",
  "slug": "checkmk-install-agent",
  "kind": "ansible",
  "metadata": {
    "name": "Install Checkmk Agent",
    "description": "Ansible playbook to install Checkmk monitoring agent on hosts. Uses the checkmk.general.agent role with automatic registration.\n## References\n- **Project**: https://github.com/Checkmk/ansible-collection-checkmk.general\n- **Documentation**: https://docs.checkmk.com/",
    "tags": [],
    "author": "Christian Lempa",
    "template_version": "2.4.0",
    "date": "2025-11-11",
    "icon": {
      "provider": "simple-icons",
      "id": "checkmk"
    },
    "draft": false,
    "next_steps": ""
  },
  "entrypoint": {
    "path": "playbook.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "target_hosts",
          "type": "str",
          "title": "Target hosts",
          "required": true,
          "description": "Target hosts"
        }
      ]
    },
    {
      "key": "checkmk",
      "title": "Checkmk Configuration",
      "variables": [
        {
          "name": "checkmk_server",
          "type": "str",
          "title": "Checkmk Server",
          "required": true,
          "description": "Checkmk Server"
        },
        {
          "name": "checkmk_protocol",
          "type": "str",
          "title": "Checkmk Server Protocol",
          "required": true,
          "default": "https",
          "description": "Checkmk Server Protocol"
        },
        {
          "name": "checkmk_site",
          "type": "str",
          "title": "Checkmk Site",
          "required": true,
          "default": "cmk",
          "description": "Checkmk Site"
        },
        {
          "name": "checkmk_auto_activate",
          "type": "bool",
          "title": "Auto Activate Agent",
          "required": false,
          "description": "Auto Activate Agent"
        },
        {
          "name": "checkmk_tls",
          "type": "bool",
          "title": "Use TLS for Agent Communication",
          "required": false,
          "description": "Use TLS for Agent Communication"
        },
        {
          "name": "checkmk_user",
          "type": "str",
          "title": "Checkmk Automation User",
          "required": true,
          "description": "Checkmk Automation User"
        },
        {
          "name": "checkmk_pass",
          "type": "str",
          "title": "Checkmk Automation User Password",
          "required": true,
          "description": "Checkmk Automation User Password",
          "sensitive": true
        },
        {
          "name": "checkmk_host",
          "type": "str",
          "title": "Checkmk Host Name",
          "required": true,
          "description": "Checkmk Host Name"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
