{
  "version": "1",
  "slug": "docker-certs",
  "kind": "ansible",
  "metadata": {
    "name": "Generate Docker TLS Certificates",
    "description": "Ansible playbook to generate TLS certificates for Docker daemon. Creates CA, server, and client certificates for secure Docker remote access.\n\nProject: https://www.docker.com\nDocumentation: https://docs.docker.com/engine/security/protect-access/\n",
    "author": "Christian Lempa",
    "template_version": "1.0.0",
    "icon": {
      "provider": "selfh",
      "id": "docker"
    },
    "date": "2025-11-11",
    "draft": true
  },
  "entrypoint": {
    "path": "playbook.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "target_hosts",
      "type": "string",
      "label": "Target hosts",
      "required": true,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "description": "Target hosts"
    },
    {
      "key": "playbook_name",
      "type": "string",
      "label": "Playbook Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "Docker Certs"
    },
    {
      "key": "become",
      "type": "string",
      "label": "Become",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": true
    },
    {
      "key": "certs_path",
      "type": "string",
      "label": "Path where certificates will be stored",
      "required": false,
      "section": {
        "key": "certificates",
        "title": "Certificate Configuration",
        "required": true
      },
      "source_type": "str",
      "default": "/root/docker-certs",
      "description": "Path where certificates will be stored"
    },
    {
      "key": "cert_validity_days",
      "type": "number",
      "label": "Certificate validity period in days",
      "required": false,
      "section": {
        "key": "certificates",
        "title": "Certificate Configuration",
        "required": true
      },
      "source_type": "int",
      "default": 3650,
      "description": "Certificate validity period in days"
    },
    {
      "key": "cn_domain",
      "type": "string",
      "label": "Common Name (CN) for the CA certificate",
      "required": false,
      "section": {
        "key": "certificates",
        "title": "Certificate Configuration",
        "required": true
      },
      "source_type": "hostname",
      "default": "your-domain.tld",
      "description": "Common Name (CN) for the CA certificate"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
