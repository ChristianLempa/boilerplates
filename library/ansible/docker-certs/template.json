{
  "version": "1",
  "slug": "docker-certs",
  "kind": "ansible",
  "metadata": {
    "name": "Generate Docker TLS Certificates",
    "description": "Ansible playbook to generate TLS certificates for Docker daemon. Creates CA, server, and client certificates for secure Docker remote access.\n\nProject: https://www.docker.com\nDocumentation: https://docs.docker.com/engine/security/protect-access/\n",
    "author": "Christian Lempa",
    "template_version": "1.0.0",
    "icon": {
      "provider": "simple-icons",
      "id": "docker"
    },
    "date": "2025-11-11",
    "draft": true
  },
  "entrypoint": {
    "path": "playbook.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "target_hosts",
          "type": "str",
          "title": "Target hosts",
          "required": true,
          "description": "Target hosts"
        },
        {
          "name": "playbook_name",
          "type": "str",
          "title": "Playbook Name",
          "required": false,
          "default": "Docker Certs"
        },
        {
          "name": "become",
          "type": "str",
          "title": "Become",
          "required": false,
          "default": true
        },
        {
          "name": "secrets_file",
          "type": "str",
          "title": "Secrets File",
          "required": false,
          "default": ""
        }
      ]
    },
    {
      "key": "certificates",
      "title": "Certificate Configuration",
      "variables": [
        {
          "name": "certs_path",
          "type": "str",
          "title": "Path where certificates will be stored",
          "required": false,
          "default": "/root/docker-certs",
          "description": "Path where certificates will be stored"
        },
        {
          "name": "cert_validity_days",
          "type": "int",
          "title": "Certificate validity period in days",
          "required": false,
          "default": 3650,
          "description": "Certificate validity period in days"
        },
        {
          "name": "cn_domain",
          "type": "str",
          "title": "Common Name (CN) for the CA certificate",
          "required": false,
          "default": "your-domain.tld",
          "description": "Common Name (CN) for the CA certificate"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
