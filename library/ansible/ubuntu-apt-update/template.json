{
  "version": "1",
  "slug": "ubuntu-apt-update",
  "kind": "ansible",
  "metadata": {
    "name": "Update and Upgrade Ubuntu Packages",
    "description": "Ansible playbook to update and upgrade APT packages on Ubuntu systems. Performs apt update and dist-upgrade.\n\nProject: https://ubuntu.com\nDocumentation: https://ubuntu.com/server/docs\n",
    "author": "Christian Lempa",
    "template_version": "1.0.0",
    "icon": {
      "provider": "simple-icons",
      "id": "ansible"
    },
    "date": "2025-11-11",
    "draft": true
  },
  "entrypoint": {
    "path": "playbook.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "playbook_name",
          "type": "str",
          "title": "Playbook Name",
          "required": false,
          "default": "Update and upgrade apt packages"
        },
        {
          "name": "target_hosts",
          "type": "str",
          "title": "Target Hosts",
          "required": false,
          "default": "all"
        },
        {
          "name": "become",
          "type": "str",
          "title": "Become",
          "required": false,
          "default": false
        },
        {
          "name": "secrets_file",
          "type": "str",
          "title": "Secrets File",
          "required": false,
          "default": ""
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
