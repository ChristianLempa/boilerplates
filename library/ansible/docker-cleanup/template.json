{
  "version": "1",
  "slug": "docker-cleanup",
  "kind": "ansible",
  "metadata": {
    "name": "Docker Cleanup",
    "description": "Ansible playbook to safely prune Docker resources. Keeps a conservative default and only removes resources that are explicitly enabled.\n\nProject: https://www.docker.com\nDocumentation: https://docs.docker.com/engine/reference/commandline/system_prune/\n",
    "tags": [
      "docker",
      "cleanup",
      "prune",
      "maintenance"
    ],
    "author": "Christian Lempa",
    "icon": {
      "provider": "mdi",
      "id": "broom",
      "color": "teal"
    },
    "date": "2025-11-11"
  },
  "entrypoint": {
    "path": "playbook.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "prune",
      "title": "Prune Options",
      "variables": [
        {
          "name": "prune_include_unused_tagged_images",
          "type": "bool",
          "title": "Prune Unused Tagged Images",
          "required": false,
          "default": false,
          "description": "Enable pruning of unused tagged images in addition to dangling images"
        },
        {
          "name": "prune_stopped_containers",
          "type": "bool",
          "title": "Prune Stopped Containers",
          "required": false,
          "default": false,
          "description": "Remove stopped containers"
        },
        {
          "name": "prune_unused_volumes",
          "type": "bool",
          "title": "Prune Unused Volumes",
          "required": false,
          "default": false,
          "description": "Remove unused volumes"
        },
        {
          "name": "prune_unused_networks",
          "type": "bool",
          "title": "Prune Unused Networks",
          "required": false,
          "default": false,
          "description": "Remove unused networks"
        },
        {
          "name": "prune_builder_cache",
          "type": "bool",
          "title": "Prune Builder Cache",
          "required": false,
          "default": false,
          "description": "Remove unused build cache"
        },
        {
          "name": "prune_keep_storage_mb",
          "type": "int",
          "title": "Keep Storage (MB)",
          "required": false,
          "default": 1024,
          "description": "Minimum amount of cache/storage to keep when pruning (where supported)"
        }
      ]
    }
  ]
}
