{
  "version": "1",
  "slug": "docker-cleanup",
  "kind": "ansible",
  "metadata": {
    "name": "Docker Cleanup",
    "description": "Ansible playbook to clean up Docker resources. Prunes non-dangling images to free up disk space.\n\nProject: https://www.docker.com\nDocumentation: https://docs.docker.com/engine/reference/commandline/system_prune/\n",
    "author": "Christian Lempa",
    "template_version": "1.0.0",
    "icon": {
      "provider": "mdi",
      "id": "broom"
    },
    "date": "2025-11-11",
    "draft": true
  },
  "entrypoint": {
    "path": "playbook.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "target_hosts",
          "type": "str",
          "title": "Target hosts",
          "required": true,
          "description": "Target hosts"
        },
        {
          "name": "playbook_name",
          "type": "str",
          "title": "Playbook Name",
          "required": false,
          "default": "Clean docker"
        },
        {
          "name": "become",
          "type": "str",
          "title": "Become",
          "required": false,
          "default": false
        },
        {
          "name": "secrets_file",
          "type": "str",
          "title": "Secrets File",
          "required": false,
          "default": ""
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
