{
  "version": "1",
  "slug": "ubuntu-vm-core",
  "kind": "ansible",
  "metadata": {
    "name": "Install Ubuntu VM Core Packages",
    "description": "Ansible playbook to install essential packages for Ubuntu virtual machines. Includes Prometheus node exporter, NFS client, and QEMU guest agent.\n\nProject: https://ubuntu.com\nDocumentation: https://ubuntu.com/server/docs\n",
    "author": "Christian Lempa",
    "template_version": "1.0.0",
    "icon": {
      "provider": "simple-icons",
      "id": "ansible"
    },
    "date": "2025-11-11",
    "draft": true
  },
  "entrypoint": {
    "path": "playbook.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "target_hosts",
          "type": "str",
          "title": "Target hosts",
          "required": true,
          "description": "Target hosts"
        },
        {
          "name": "playbook_name",
          "type": "str",
          "title": "Playbook Name",
          "required": false,
          "default": "Install core packages for virtual machines"
        },
        {
          "name": "become",
          "type": "str",
          "title": "Become",
          "required": false,
          "default": true
        },
        {
          "name": "secrets_file",
          "type": "str",
          "title": "Secrets File",
          "required": false,
          "default": ""
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
