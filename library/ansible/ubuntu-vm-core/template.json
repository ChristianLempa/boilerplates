    "author": "Christian Lempa",
    "template_version": "1.0.0",
    "icon": {
      "provider": "selfh",
      "id": "ansible"
    },
    "date": "2025-11-11",
    "draft": true
  },
  "entrypoint": {
    "path": "playbook.yaml",
    "type": "file"
  },
  "variables": [
    {
