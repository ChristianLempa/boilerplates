    "description": "Ansible playbook to clean up Docker resources. Prunes non-dangling images to free up disk space.\n\nProject: https://www.docker.com\nDocumentation: https://docs.docker.com/engine/reference/commandline/system_prune/\n",
    "author": "Christian Lempa",
    "template_version": "1.0.0",
    "icon": {
      "provider": "selfh",
      "id": "docker"
    },
    "date": "2025-11-11",
    "draft": true
  },
  "entrypoint": {
    "path": "playbook.yaml",
    "type": "file"
  },
  "variables": [
