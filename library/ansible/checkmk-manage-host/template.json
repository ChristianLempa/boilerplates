{
  "version": "1",
  "slug": "checkmk-manage-host",
  "kind": "ansible",
  "metadata": {
    "name": "Manage Checkmk Host",
    "description": "Ansible playbook to manage hosts in Checkmk monitoring. Uses the checkmk.general.host module to create or update host configuration.\n## References\n- **Project**: https://github.com/Checkmk/ansible-collection-checkmk.general\n- **Documentation**: https://docs.checkmk.com/",
    "tags": [],
    "author": "Christian Lempa",
    "template_version": "2.4.0",
    "date": "2025-11-11",
    "icon": {
      "provider": "simple-icons",
      "id": "checkmk"
    },
    "draft": false,
    "next_steps": ""
  },
  "entrypoint": {
    "path": "playbook.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "target_hosts",
          "type": "str",
          "title": "Target hosts or group",
          "required": true,
          "description": "Target hosts or group"
        }
      ]
    },
    {
      "key": "checkmk",
      "title": "Checkmk Configuration",
      "variables": [
        {
          "name": "checkmk_server",
          "type": "str",
          "title": "Checkmk Server",
          "required": true,
          "description": "Checkmk Server"
        },
        {
          "name": "checkmk_protocol",
          "type": "str",
          "title": "Checkmk Server Protocol",
          "required": true,
          "default": "https",
          "description": "Checkmk Server Protocol"
        },
        {
          "name": "checkmk_site",
          "type": "str",
          "title": "Checkmk Site",
          "required": true,
          "default": "cmk",
          "description": "Checkmk Site"
        },
        {
          "name": "checkmk_user",
          "type": "str",
          "title": "Checkmk Automation User",
          "required": true,
          "description": "Checkmk Automation User"
        },
        {
          "name": "checkmk_pass",
          "type": "str",
          "title": "Checkmk Automation User Password",
          "required": true,
          "description": "Checkmk Automation User Password",
          "sensitive": true
        }
      ]
    },
    {
      "key": "host",
      "title": "Host Configuration",
      "variables": [
        {
          "name": "host_name",
          "type": "str",
          "title": "Hostname to add to Checkmk",
          "required": true,
          "description": "Hostname to add to Checkmk"
        },
        {
          "name": "host_ip",
          "type": "str",
          "title": "IP address of the host",
          "required": true,
          "description": "IP address of the host"
        },
        {
          "name": "host_folder",
          "type": "str",
          "title": "Folder path in Checkmk",
          "required": true,
          "default": "/",
          "description": "Folder path in Checkmk"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
