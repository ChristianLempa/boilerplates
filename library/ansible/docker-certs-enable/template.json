{
  "version": "1",
  "slug": "docker-certs-enable",
  "kind": "ansible",
  "metadata": {
    "name": "Enable Docker TLS",
    "description": "Ansible playbook to enable TLS on Docker daemon using existing certificates. Configures Docker to use TLS for secure remote access.\n\nProject: https://www.docker.com\nDocumentation: https://docs.docker.com/engine/security/protect-access/\n",
    "author": "Christian Lempa",
    "template_version": "1.0.0",
    "icon": {
      "provider": "simple-icons",
      "id": "docker"
    },
    "date": "2025-11-11",
    "draft": true
  },
  "entrypoint": {
    "path": "playbook.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "target_hosts",
          "type": "str",
          "title": "Target hosts",
          "required": true,
          "description": "Target hosts"
        },
        {
          "name": "playbook_name",
          "type": "str",
          "title": "Playbook Name",
          "required": false,
          "default": "Docker Certs enable"
        },
        {
          "name": "become",
          "type": "str",
          "title": "Become",
          "required": false,
          "default": true
        },
        {
          "name": "secrets_file",
          "type": "str",
          "title": "Secrets File",
          "required": false,
          "default": ""
        }
      ]
    },
    {
      "key": "certificates",
      "title": "Certificate Configuration",
      "variables": [
        {
          "name": "certs_path",
          "type": "str",
          "title": "Path where certificates are stored",
          "required": false,
          "default": "/root/docker-certs",
          "description": "Path where certificates are stored"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
