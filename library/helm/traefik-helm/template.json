{
  "version": "1",
  "slug": "traefik-helm",
  "kind": "helm",
  "metadata": {
    "name": "Traefik Ingress Controller",
    "description": "Helm values template for Traefik v3, a modern HTTP reverse proxy and load balancer designed for microservices.\n\nChart Repository: https://traefik.github.io/charts\nChart Name: traefik\nChart Version: Compatible with Traefik v3.5.3\n\nProject: https://traefik.io/\nDocumentation: https://doc.traefik.io/traefik/",
    "tags": [],
    "author": "Christian Lempa",
    "template_version": "3.5.3",
    "date": "2025-01-11",
    "icon": {
      "provider": "simple-icons",
      "id": "traefikproxy"
    },
    "draft": true,
    "next_steps": ""
  },
  "entrypoint": {
    "path": "values.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "release_name",
          "type": "str",
          "title": "Helm release name",
          "required": false,
          "default": "traefik",
          "description": "Helm release name"
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Kubernetes namespace",
          "required": false,
          "default": "traefik",
          "description": "Kubernetes namespace"
        }
      ]
    },
    {
      "key": "networking",
      "title": "Networking Configuration",
      "variables": [
        {
          "name": "network_mode",
          "type": "str",
          "title": "Network mode for service",
          "required": false,
          "default": "LoadBalancer",
          "description": "Network mode for service"
        }
      ]
    },
    {
      "key": "database",
      "title": "Database Configuration",
      "variables": [
        {
          "name": "database_enabled",
          "type": "bool",
          "title": "Enable database",
          "required": false,
          "default": false,
          "description": "Enable database"
        },
        {
          "name": "database_type",
          "type": "str",
          "title": "Database type",
          "required": false,
          "default": "postgres",
          "description": "Database type",
          "options": [
            "postgres",
            "mysql"
          ]
        },
        {
          "name": "database_host",
          "type": "str",
          "title": "Database host",
          "required": false,
          "description": "Database host"
        },
        {
          "name": "database_port",
          "type": "int",
          "title": "Database port",
          "required": false,
          "default": 5432,
          "description": "Database port"
        },
        {
          "name": "database_name",
          "type": "str",
          "title": "Database name",
          "required": false,
          "description": "Database name"
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database user",
          "required": false,
          "description": "Database user"
        },
        {
          "name": "database_password",
          "type": "str",
          "title": "Database password",
          "required": false,
          "description": "Database password",
          "sensitive": true
        }
      ]
    },
    {
      "key": "dashboard",
      "title": "Dashboard IngressRoute",
      "variables": [
        {
          "name": "dashboard_host",
          "type": "str",
          "title": "FQDN for the Traefik dashboard",
          "required": false,
          "description": "FQDN for the Traefik dashboard"
        },
        {
          "name": "dashboard_ingressroute_enabled",
          "type": "bool",
          "title": "Create IngressRoute for Traefik dashboard",
          "required": false,
          "default": false,
          "description": "Create IngressRoute for Traefik dashboard"
        },
        {
          "name": "dashboard_middleware",
          "type": "str",
          "title": "Authentication middleware name for dashboard protection",
          "required": false,
          "default": "traefik-dashboard-auth",
          "description": "Authentication middleware name for dashboard protection"
        },
        {
          "name": "dashboard_tls_secret",
          "type": "str",
          "title": "TLS secret name for dashboard",
          "required": false,
          "default": "traefik-dashboard-tls",
          "description": "TLS secret name for dashboard"
        },
        {
          "name": "release_name",
          "type": "str",
          "title": "Release Name",
          "required": false,
          "default": "traefik"
        }
      ]
    },
    {
      "key": "http-redirect",
      "title": "HTTP to HTTPS Redirect",
      "variables": [
        {
          "name": "http_redirect_enabled",
          "type": "bool",
          "title": "Automatically redirect HTTP traffic to HTTPS",
          "required": false,
          "default": true,
          "description": "Automatically redirect HTTP traffic to HTTPS"
        },
        {
          "name": "http_redirect_permanent",
          "type": "bool",
          "title": "Use permanent redirect (301) instead of temporary (302)",
          "required": false,
          "default": true,
          "description": "Use permanent redirect (301) instead of temporary (302)"
        }
      ]
    },
    {
      "key": "traefik-config",
      "title": "Traefik Settings",
      "variables": [
        {
          "name": "accesslog_enabled",
          "type": "bool",
          "title": "Enable Traefik access log",
          "required": false,
          "default": false,
          "description": "Enable Traefik access log"
        },
        {
          "name": "dashboard_enabled",
          "type": "bool",
          "title": "Enable Traefik dashboard",
          "required": false,
          "default": false,
          "description": "Enable Traefik dashboard"
        },
        {
          "name": "prometheus_enabled",
          "type": "bool",
          "title": "Enable Prometheus metrics",
          "required": false,
          "default": false,
          "description": "Enable Prometheus metrics"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
