{
  "version": "1",
  "slug": "longhorn",
  "kind": "helm",
  "metadata": {
    "name": "Longhorn",
    "description": "Helm values template for Longhorn, a distributed block storage system for Kubernetes.\nProvides persistent storage with built-in backup and disaster recovery.\n\nChart Repository: https://charts.longhorn.io\nChart Name: longhorn\nChart Version: Compatible with Longhorn v1.9.1\n\nProject: https://longhorn.io/\nDocumentation: https://longhorn.io/docs/",
    "tags": [],
    "author": "Christian Lempa",
    "template_version": "1.9.1",
    "date": "2025-01-11",
    "icon": {
      "provider": "mdi",
      "id": "database-cog-outline"
    },
    "draft": true,
    "next_steps": ""
  },
  "entrypoint": {
    "path": "values.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "release_name",
          "type": "str",
          "title": "Helm release name",
          "required": false,
          "default": "longhorn",
          "description": "Helm release name"
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Kubernetes namespace",
          "required": false,
          "default": "longhorn-system",
          "description": "Kubernetes namespace"
        }
      ]
    },
    {
      "key": "networking",
      "title": "Networking Configuration",
      "variables": [
        {
          "name": "network_mode",
          "type": "str",
          "title": "Network mode for service",
          "required": false,
          "default": "ClusterIP",
          "description": "Network mode for service"
        }
      ]
    },
    {
      "key": "database",
      "title": "Database Configuration",
      "variables": [
        {
          "name": "database_enabled",
          "type": "bool",
          "title": "Enable database",
          "required": false,
          "default": false,
          "description": "Enable database"
        },
        {
          "name": "database_type",
          "type": "str",
          "title": "Database type",
          "required": false,
          "default": "postgres",
          "description": "Database type",
          "options": [
            "postgres",
            "mysql"
          ]
        },
        {
          "name": "database_host",
          "type": "str",
          "title": "Database host",
          "required": false,
          "description": "Database host"
        },
        {
          "name": "database_port",
          "type": "int",
          "title": "Database port",
          "required": false,
          "default": 5432,
          "description": "Database port"
        },
        {
          "name": "database_name",
          "type": "str",
          "title": "Database name",
          "required": false,
          "description": "Database name"
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database user",
          "required": false,
          "description": "Database user"
        },
        {
          "name": "database_password",
          "type": "str",
          "title": "Database password",
          "required": false,
          "description": "Database password",
          "sensitive": true
        }
      ]
    },
    {
      "key": "backup",
      "title": "Backup Configuration",
      "variables": [
        {
          "name": "backup_enabled",
          "type": "bool",
          "title": "Enable backup target configuration",
          "required": false,
          "default": false,
          "description": "Enable backup target configuration"
        },
        {
          "name": "backup_target",
          "type": "str",
          "title": "Backup target URL (e.g., s3://bucket or nfs://server/path)",
          "required": false,
          "description": "Backup target URL (e.g., s3://bucket or nfs://server/path)"
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Namespace",
          "required": false,
          "default": "longhorn-system"
        },
        {
          "name": "release_name",
          "type": "str",
          "title": "Release Name",
          "required": false,
          "default": "longhorn"
        }
      ]
    },
    {
      "key": "ui",
      "title": "Longhorn UI",
      "variables": [
        {
          "name": "ui_replicas",
          "type": "int",
          "title": "Number of Longhorn UI replicas",
          "required": false,
          "default": 1,
          "description": "Number of Longhorn UI replicas"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
