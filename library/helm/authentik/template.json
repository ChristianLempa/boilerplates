{
  "version": "1",
  "slug": "authentik",
  "kind": "helm",
  "metadata": {
    "name": "Authentik",
    "description": "Helm values template for Authentik, an open-source Identity Provider focused on flexibility and versatility with support for various protocols (OAuth2, SAML, LDAP).\n\nChart Repository: https://charts.goauthentik.io\nChart Name: authentik\nChart Version: Compatible with Authentik 2025.6.3\n\nProject: https://goauthentik.io/\nDocumentation: https://docs.goauthentik.io/\n",
    "author": "Christian Lempa",
    "template_version": "2025.6.3",
    "icon": {
      "provider": "simple-icons",
      "id": "authentik"
    },
    "date": "2025-01-11",
    "draft": true
  },
  "entrypoint": {
    "path": "values.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "release_name",
          "type": "str",
          "title": "Release Name",
          "required": false,
          "default": "authentik"
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Kubernetes namespace",
          "required": false,
          "default": "authentik",
          "description": "Kubernetes namespace"
        }
      ]
    },
    {
      "key": "networking",
      "title": "Networking",
      "variables": [
        {
          "name": "network_mode",
          "type": "str",
          "title": "Network mode for service",
          "required": false,
          "default": "ClusterIP",
          "description": "Network mode for service"
        }
      ]
    },
    {
      "key": "authentik",
      "title": "Authentik Configuration",
      "variables": [
        {
          "name": "authentik_secret_key",
          "type": "str",
          "title": "Secret Key",
          "required": false,
          "description": "Secret Key",
          "sensitive": true,
          "autogenerated": true
        },
        {
          "name": "authentik_log_level",
          "type": "str",
          "title": "Authentik log level",
          "required": false,
          "default": "error",
          "description": "Authentik log level",
          "options": [
            "trace",
            "debug",
            "info",
            "warning",
            "error"
          ]
        },
        {
          "name": "authentik_error_reporting",
          "type": "bool",
          "title": "Enable error reporting to Authentik developers",
          "required": false,
          "default": false,
          "description": "Enable error reporting to Authentik developers"
        }
      ]
    },
    {
      "key": "database",
      "title": "Database Configuration",
      "variables": [
        {
          "name": "database_enabled",
          "type": "bool",
          "title": "Enable database",
          "required": false,
          "default": true,
          "description": "Enable database"
        },
        {
          "name": "database_type",
          "type": "str",
          "title": "Database type",
          "required": false,
          "default": "postgres",
          "description": "Database type",
          "options": [
            "postgres",
            "mysql"
          ]
        },
        {
          "name": "database_host",
          "type": "str",
          "title": "Database host",
          "required": false,
          "default": "authentik-postgresql",
          "description": "Database host"
        },
        {
          "name": "database_port",
          "type": "int",
          "title": "Database port",
          "required": false,
          "default": 5432,
          "description": "Database port"
        },
        {
          "name": "database_name",
          "type": "str",
          "title": "Database name",
          "required": false,
          "default": "authentik",
          "description": "Database name"
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database user",
          "required": false,
          "default": "authentik",
          "description": "Database user"
        },
        {
          "name": "database_password",
          "type": "str",
          "title": "PostgreSQL database password",
          "required": false,
          "description": "PostgreSQL database password",
          "sensitive": true,
          "autogenerated": true
        }
      ]
    },
    {
      "key": "email",
      "title": "Email Configuration",
      "variables": [
        {
          "name": "email_enabled",
          "type": "bool",
          "title": "Enable email notifications",
          "required": false,
          "default": false,
          "description": "Enable email notifications"
        },
        {
          "name": "email_host",
          "type": "str",
          "title": "SMTP server hostname",
          "required": false,
          "default": "smtp.example.com",
          "description": "SMTP server hostname"
        },
        {
          "name": "email_port",
          "type": "int",
          "title": "SMTP server port",
          "required": false,
          "default": 587,
          "description": "SMTP server port"
        },
        {
          "name": "email_username",
          "type": "str",
          "title": "SMTP username",
          "required": false,
          "default": "",
          "description": "SMTP username"
        },
        {
          "name": "email_password",
          "type": "str",
          "title": "SMTP password",
          "required": false,
          "default": "",
          "description": "SMTP password",
          "sensitive": true
        },
        {
          "name": "email_from",
          "type": "str",
          "title": "From email address",
          "required": false,
          "default": "authentik@example.com",
          "description": "From email address"
        },
        {
          "name": "email_use_tls",
          "type": "bool",
          "title": "Use TLS/STARTTLS for SMTP connection",
          "required": false,
          "default": true,
          "description": "Use TLS/STARTTLS for SMTP connection"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik Configuration",
      "variables": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik ingress",
          "required": false,
          "default": false,
          "description": "Enable Traefik ingress"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik hostname",
          "required": false,
          "default": "authentik.home.arpa",
          "description": "Traefik hostname"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable TLS for Traefik ingress",
          "required": false,
          "default": false,
          "description": "Enable TLS for Traefik ingress"
        },
        {
          "name": "traefik_tls_secret",
          "type": "str",
          "title": "TLS secret name for Traefik ingress",
          "required": false,
          "default": "authentik-tls",
          "description": "TLS secret name for Traefik ingress"
        },
        {
          "name": "traefik_tls_certmanager",
          "type": "bool",
          "title": "Use cert-manager for TLS certificate",
          "required": false,
          "default": false,
          "description": "Use cert-manager for TLS certificate"
        },
        {
          "name": "certmanager_issuer",
          "type": "str",
          "title": "Cert-manager issuer name",
          "required": false,
          "default": "letsencrypt-prod",
          "description": "Cert-manager issuer name",
          "needs": [
            "traefik_tls_certmanager=true"
          ]
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
