{
  "version": "1",
  "slug": "authentik",
  "kind": "helm",
  "metadata": {
    "name": "Authentik",
    "description": "Helm values template for Authentik, an open-source Identity Provider focused on flexibility and versatility with support for various protocols (OAuth2, SAML, LDAP).\n\nChart Repository: https://charts.goauthentik.io\nChart Name: authentik\nChart Version: Compatible with Authentik 2025.6.3\n\nProject: https://goauthentik.io/\nDocumentation: https://docs.goauthentik.io/\n",
    "author": "Christian Lempa",
    "template_version": "2025.6.3",
    "icon": {
      "provider": "selfh",
      "id": "authentik"
    },
    "date": "2025-01-11",
    "draft": true
  },
  "entrypoint": {
    "path": "values.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "release_name",
      "type": "string",
      "label": "Release Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "authentik"
    },
    {
      "key": "namespace",
      "type": "string",
      "label": "Kubernetes namespace",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "authentik",
      "description": "Kubernetes namespace"
    },
    {
      "key": "network_mode",
      "type": "string",
      "label": "Network mode for service",
      "required": false,
      "section": {
        "key": "networking"
      },
      "source_type": "str",
      "default": "ClusterIP",
      "description": "Network mode for service"
    },
    {
      "key": "authentik_secret_key",
      "type": "string",
      "label": "Secret Key",
      "required": false,
      "section": {
        "key": "authentik",
        "title": "Authentik Configuration",
        "required": true,
        "description": "Configure Authentik application settings"
      },
      "source_type": "str",
      "description": "Secret Key",
      "extra": "Used for cookie signing and unique user IDs",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "authentik_log_level",
      "type": "string",
      "label": "Authentik log level",
      "required": false,
      "section": {
        "key": "authentik",
        "title": "Authentik Configuration",
        "required": true,
        "description": "Configure Authentik application settings"
      },
      "source_type": "enum",
      "default": "error",
      "description": "Authentik log level",
      "options": [
        "trace",
        "debug",
        "info",
        "warning",
        "error"
      ]
    },
    {
      "key": "authentik_error_reporting",
      "type": "boolean",
      "label": "Enable error reporting to Authentik developers",
      "required": false,
      "section": {
        "key": "authentik",
        "title": "Authentik Configuration",
        "required": true,
        "description": "Configure Authentik application settings"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable error reporting to Authentik developers"
    },
    {
      "key": "database_enabled",
      "type": "boolean",
      "label": "Enable database",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "bool",
      "default": true,
      "description": "Enable database"
    },
    {
      "key": "database_type",
      "type": "string",
      "label": "Database type",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "enum",
      "default": "postgres",
      "description": "Database type",
      "options": [
        "postgres",
        "mysql"
      ]
    },
    {
      "key": "database_host",
      "type": "string",
      "label": "Database host",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "hostname",
      "default": "authentik-postgresql",
      "description": "Database host"
    },
    {
      "key": "database_port",
      "type": "number",
      "label": "Database port",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "int",
      "default": 5432,
      "description": "Database port"
    },
    {
      "key": "database_name",
      "type": "string",
      "label": "Database name",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "str",
      "default": "authentik",
      "description": "Database name"
    },
    {
      "key": "database_user",
      "type": "string",
      "label": "Database user",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "str",
      "default": "authentik",
      "description": "Database user"
    },
    {
      "key": "database_password",
      "type": "string",
      "label": "PostgreSQL database password",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "str",
      "description": "PostgreSQL database password",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "email_enabled",
      "type": "boolean",
      "label": "Enable email notifications",
      "required": false,
      "section": {
        "key": "email",
        "title": "Email Configuration",
        "toggle": "email_enabled"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable email notifications"
    },
    {
      "key": "email_host",
      "type": "string",
      "label": "SMTP server hostname",
      "required": false,
      "section": {
        "key": "email",
        "title": "Email Configuration",
        "toggle": "email_enabled"
      },
      "source_type": "hostname",
      "default": "smtp.example.com",
      "description": "SMTP server hostname"
    },
    {
      "key": "email_port",
      "type": "number",
      "label": "SMTP server port",
      "required": false,
      "section": {
        "key": "email",
        "title": "Email Configuration",
        "toggle": "email_enabled"
      },
      "source_type": "int",
      "default": 587,
      "description": "SMTP server port"
    },
    {
      "key": "email_username",
      "type": "string",
      "label": "SMTP username",
      "required": false,
      "section": {
        "key": "email",
        "title": "Email Configuration",
        "toggle": "email_enabled"
      },
      "source_type": "str",
      "default": "",
      "description": "SMTP username"
    },
    {
      "key": "email_password",
      "type": "string",
      "label": "SMTP password",
      "required": false,
      "section": {
        "key": "email",
        "title": "Email Configuration",
        "toggle": "email_enabled"
      },
      "source_type": "str",
      "default": "",
      "description": "SMTP password",
      "sensitive": true
    },
    {
      "key": "email_from",
      "type": "string",
      "label": "From email address",
      "required": false,
      "section": {
        "key": "email",
        "title": "Email Configuration",
        "toggle": "email_enabled"
      },
      "source_type": "email",
      "default": "authentik@example.com",
      "description": "From email address"
    },
    {
      "key": "email_use_tls",
      "type": "boolean",
      "label": "Use TLS/STARTTLS for SMTP connection",
      "required": false,
      "section": {
        "key": "email",
        "title": "Email Configuration",
        "toggle": "email_enabled"
      },
      "source_type": "bool",
      "default": true,
      "description": "Use TLS/STARTTLS for SMTP connection"
    },
    {
      "key": "traefik_enabled",
      "type": "boolean",
      "label": "Enable Traefik ingress",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Configuration",
        "toggle": "traefik_enabled"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik ingress"
    },
    {
      "key": "traefik_host",
      "type": "string",
      "label": "Traefik hostname",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Configuration",
        "toggle": "traefik_enabled"
      },
      "source_type": "hostname",
      "default": "authentik.home.arpa",
      "description": "Traefik hostname"
    },
    {
      "key": "traefik_tls_enabled",
      "type": "boolean",
      "label": "Enable TLS for Traefik ingress",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Configuration",
        "toggle": "traefik_enabled"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable TLS for Traefik ingress"
    },
    {
      "key": "traefik_tls_secret",
      "type": "string",
      "label": "TLS secret name for Traefik ingress",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Configuration",
        "toggle": "traefik_enabled"
      },
      "source_type": "str",
      "default": "authentik-tls",
      "description": "TLS secret name for Traefik ingress"
    },
    {
      "key": "traefik_tls_certmanager",
      "type": "boolean",
      "label": "Use cert-manager for TLS certificate",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Configuration",
        "toggle": "traefik_enabled"
      },
      "source_type": "bool",
      "default": false,
      "description": "Use cert-manager for TLS certificate"
    },
    {
      "key": "certmanager_issuer",
      "type": "string",
      "label": "Cert-manager issuer name",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Configuration",
        "toggle": "traefik_enabled"
      },
      "source_type": "str",
      "default": "letsencrypt-prod",
      "description": "Cert-manager issuer name",
      "needs": "traefik_tls_certmanager=true"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
