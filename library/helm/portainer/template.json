{
  "version": "1",
  "slug": "portainer",
  "kind": "helm",
  "metadata": {
    "name": "Portainer CE",
    "description": "Helm values template for Portainer Community Edition, a container management platform that simplifies Docker and Kubernetes management.\n\nChart Repository: https://portainer.github.io/k8s/\nChart Name: portainer\nChart Version: Compatible with Portainer CE 2.34.0\n\nProject: https://www.portainer.io/\nDocumentation: https://docs.portainer.io/\n",
    "author": "Christian Lempa",
    "template_version": "2.34.0",
    "icon": {
      "provider": "simple-icons",
      "id": "portainer"
    },
    "date": "2025-01-11",
    "draft": true
  },
  "entrypoint": {
    "path": "values.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "release_name",
          "type": "str",
          "title": "Helm release name",
          "required": false,
          "default": "portainer",
          "description": "Helm release name"
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Kubernetes namespace",
          "required": false,
          "default": "portainer",
          "description": "Kubernetes namespace"
        }
      ]
    },
    {
      "key": "networking",
      "title": "Networking",
      "variables": [
        {
          "name": "network_mode",
          "type": "str",
          "title": "Network mode for service",
          "required": false,
          "default": "ClusterIP",
          "description": "Network mode for service"
        }
      ]
    },
    {
      "key": "database",
      "title": "Database Configuration",
      "variables": [
        {
          "name": "database_enabled",
          "type": "bool",
          "title": "Enable database",
          "required": false,
          "default": false,
          "description": "Enable database"
        },
        {
          "name": "database_type",
          "type": "str",
          "title": "Database type",
          "required": false,
          "default": "postgres",
          "description": "Database type",
          "options": [
            "postgres",
            "mysql"
          ]
        },
        {
          "name": "database_host",
          "type": "str",
          "title": "Database host",
          "required": false,
          "description": "Database host"
        },
        {
          "name": "database_port",
          "type": "int",
          "title": "Database port",
          "required": false,
          "default": 5432,
          "description": "Database port"
        },
        {
          "name": "database_name",
          "type": "str",
          "title": "Database name",
          "required": false,
          "description": "Database name"
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database user",
          "required": false,
          "description": "Database user"
        },
        {
          "name": "database_password",
          "type": "str",
          "title": "Database password",
          "required": false,
          "description": "Database password",
          "sensitive": true
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik Configuration",
      "variables": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik ingress",
          "required": false,
          "default": false,
          "description": "Enable Traefik ingress"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik hostname",
          "required": false,
          "default": "portainer.home.arpa",
          "description": "Traefik hostname"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable TLS for Traefik ingress",
          "required": false,
          "default": false,
          "description": "Enable TLS for Traefik ingress"
        },
        {
          "name": "traefik_tls_secret",
          "type": "str",
          "title": "TLS secret name for Traefik ingress",
          "required": false,
          "default": "portainer-tls",
          "description": "TLS secret name for Traefik ingress"
        }
      ]
    },
    {
      "key": "volumes",
      "title": "Volume Configuration",
      "variables": [
        {
          "name": "volumes_mode",
          "type": "str",
          "title": "Volume storage mode",
          "required": false,
          "default": "pvc",
          "description": "Volume storage mode",
          "options": [
            "pvc",
            "hostPath"
          ]
        },
        {
          "name": "volumes_pvc_name",
          "type": "str",
          "title": "PVC name for volumes",
          "required": false,
          "default": "portainer",
          "description": "PVC name for volumes"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
