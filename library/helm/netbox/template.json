{
  "version": "1",
  "slug": "netbox",
  "kind": "helm",
  "metadata": {
    "name": "NetBox",
    "description": "Helm values template for NetBox, an open-source network infrastructure management (IPAM/DCIM)\nsolution and network automation source of truth.\n## Chart Information\n* **Chart Repository:** https://charts.bootsource.github.io/charts\n* **Chart Name:** netbox\n* **Chart Version:** Compatible with NetBox 4.2.3\n## References\n* **Project:** https://netbox.dev/\n* **Documentation:** https://docs.netbox.dev/\n* **GitHub:** https://github.com/netbox-community/netbox\n",
    "author": "Christian Lempa",
    "template_version": "4.2.3",
    "icon": {
      "provider": "simple-icons",
      "id": "netbox"
    },
    "date": "2025-01-13",
    "draft": true
  },
  "entrypoint": {
    "path": "values.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "release_name",
          "type": "str",
          "title": "Release Name",
          "required": false,
          "default": "netbox"
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Namespace",
          "required": false,
          "default": "netbox"
        }
      ]
    },
    {
      "key": "database",
      "title": "Database Configuration",
      "variables": [
        {
          "name": "database_enabled",
          "type": "bool",
          "title": "Enable database",
          "required": false,
          "default": true,
          "description": "Enable database"
        },
        {
          "name": "database_type",
          "type": "str",
          "title": "Database type",
          "required": false,
          "default": "postgres",
          "description": "Database type",
          "options": [
            "postgres",
            "mysql"
          ]
        },
        {
          "name": "database_host",
          "type": "str",
          "title": "Database host",
          "required": false,
          "default": "netbox-postgresql",
          "description": "Database host"
        },
        {
          "name": "database_port",
          "type": "int",
          "title": "Database port",
          "required": false,
          "default": 5432,
          "description": "Database port"
        },
        {
          "name": "database_name",
          "type": "str",
          "title": "Database name",
          "required": false,
          "default": "netbox",
          "description": "Database name"
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database user",
          "required": false,
          "default": "netbox",
          "description": "Database user"
        },
        {
          "name": "database_password",
          "type": "str",
          "title": "Database password",
          "required": false,
          "description": "Database password",
          "sensitive": true,
          "autogenerated": true
        }
      ]
    },
    {
      "key": "networking",
      "title": "Networking Configuration",
      "variables": [
        {
          "name": "network_mode",
          "type": "str",
          "title": "Network mode for service",
          "required": false,
          "default": "ClusterIP",
          "description": "Network mode for service"
        }
      ]
    },
    {
      "key": "redis",
      "title": "Redis Configuration",
      "variables": [
        {
          "name": "redis_enabled",
          "type": "bool",
          "title": "Enable Redis deployment",
          "required": false,
          "default": true,
          "description": "Enable Redis deployment"
        },
        {
          "name": "redis_host",
          "type": "str",
          "title": "Redis host for tasks",
          "required": false,
          "default": "netbox-redis-master",
          "description": "Redis host for tasks"
        },
        {
          "name": "redis_cache_host",
          "type": "str",
          "title": "Redis host for caching",
          "required": false,
          "default": "netbox-redis-master",
          "description": "Redis host for caching"
        },
        {
          "name": "redis_password",
          "type": "str",
          "title": "Redis password",
          "required": false,
          "description": "Redis password",
          "sensitive": true,
          "autogenerated": true
        }
      ]
    },
    {
      "key": "email",
      "title": "Email Configuration",
      "variables": [
        {
          "name": "email_enabled",
          "type": "bool",
          "title": "Enable email notifications",
          "required": false,
          "default": false,
          "description": "Enable email notifications"
        },
        {
          "name": "email_host",
          "type": "str",
          "title": "SMTP server hostname",
          "required": false,
          "default": "smtp.example.com",
          "description": "SMTP server hostname"
        },
        {
          "name": "email_port",
          "type": "int",
          "title": "SMTP server port",
          "required": false,
          "default": 587,
          "description": "SMTP server port"
        },
        {
          "name": "email_username",
          "type": "str",
          "title": "SMTP username",
          "required": false,
          "default": "",
          "description": "SMTP username"
        },
        {
          "name": "email_from",
          "type": "str",
          "title": "From email address",
          "required": false,
          "default": "netbox@example.com",
          "description": "From email address"
        },
        {
          "name": "email_use_tls",
          "type": "bool",
          "title": "Use TLS/STARTTLS for SMTP connection",
          "required": false,
          "default": true,
          "description": "Use TLS/STARTTLS for SMTP connection"
        },
        {
          "name": "email_use_ssl",
          "type": "bool",
          "title": "Use SSL for SMTP connection",
          "required": false,
          "default": false,
          "description": "Use SSL for SMTP connection"
        }
      ]
    },
    {
      "key": "traefik",
      "title": "Traefik Configuration",
      "variables": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Enable Traefik ingress",
          "required": false,
          "default": false,
          "description": "Enable Traefik ingress"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik hostname",
          "required": false,
          "default": "netbox.home.arpa",
          "description": "Traefik hostname"
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "Enable TLS for Traefik ingress",
          "required": false,
          "default": false,
          "description": "Enable TLS for Traefik ingress"
        },
        {
          "name": "traefik_tls_secret",
          "type": "str",
          "title": "TLS secret name for Traefik ingress",
          "required": false,
          "default": "netbox-tls",
          "description": "TLS secret name for Traefik ingress"
        },
        {
          "name": "traefik_tls_certmanager",
          "type": "bool",
          "title": "Use cert-manager for TLS certificate",
          "required": false,
          "default": false,
          "description": "Use cert-manager for TLS certificate"
        },
        {
          "name": "certmanager_issuer",
          "type": "str",
          "title": "Cert-manager issuer name",
          "required": false,
          "default": "letsencrypt-prod",
          "description": "Cert-manager issuer name",
          "needs": "traefik_tls_certmanager=true"
        }
      ]
    },
    {
      "key": "volumes",
      "title": "Volume Configuration",
      "variables": [
        {
          "name": "volumes_mode",
          "type": "str",
          "title": "Volume storage mode",
          "required": false,
          "default": "pvc",
          "description": "Volume storage mode",
          "options": [
            "pvc",
            "hostPath"
          ]
        },
        {
          "name": "volumes_pvc_name",
          "type": "str",
          "title": "PVC name for volumes",
          "required": false,
          "default": "netbox-data",
          "description": "PVC name for volumes"
        }
      ]
    },
    {
      "key": "netbox",
      "title": "NetBox Configuration",
      "variables": [
        {
          "name": "netbox_secret_key",
          "type": "str",
          "title": "Secret Key",
          "required": false,
          "description": "Secret Key",
          "sensitive": true,
          "autogenerated": true
        },
        {
          "name": "netbox_superuser_name",
          "type": "str",
          "title": "Initial superuser username",
          "required": false,
          "default": "admin",
          "description": "Initial superuser username"
        },
        {
          "name": "netbox_superuser_email",
          "type": "str",
          "title": "Initial superuser email",
          "required": false,
          "default": "admin@example.com",
          "description": "Initial superuser email"
        },
        {
          "name": "netbox_superuser_password",
          "type": "str",
          "title": "Initial superuser password",
          "required": false,
          "description": "Initial superuser password",
          "sensitive": true,
          "autogenerated": true
        },
        {
          "name": "netbox_superuser_api_token",
          "type": "str",
          "title": "Initial superuser API token",
          "required": false,
          "description": "Initial superuser API token",
          "sensitive": true,
          "autogenerated": true
        },
        {
          "name": "netbox_allowed_hosts",
          "type": "str",
          "title": "Allowed hosts (comma-separated)",
          "required": false,
          "default": "*",
          "description": "Allowed hosts (comma-separated)"
        },
        {
          "name": "netbox_metrics_enabled",
          "type": "bool",
          "title": "Enable Prometheus metrics endpoint",
          "required": false,
          "default": false,
          "description": "Enable Prometheus metrics endpoint"
        },
        {
          "name": "netbox_cors_enabled",
          "type": "bool",
          "title": "Enable CORS (Cross-Origin Resource Sharing)",
          "required": false,
          "default": false,
          "description": "Enable CORS (Cross-Origin Resource Sharing)"
        },
        {
          "name": "netbox_cors_origins",
          "type": "str",
          "title": "Allowed CORS origins",
          "required": false,
          "default": "https://example.com",
          "description": "Allowed CORS origins",
          "needs": "netbox_cors_enabled=true"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
