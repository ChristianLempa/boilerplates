{
  "version": "1",
  "slug": "netbox",
  "kind": "helm",
  "metadata": {
    "name": "NetBox",
    "description": "Helm values template for NetBox, an open-source network infrastructure management (IPAM/DCIM)\nsolution and network automation source of truth.\n## Chart Information\n* **Chart Repository:** https://charts.bootsource.github.io/charts\n* **Chart Name:** netbox\n* **Chart Version:** Compatible with NetBox 4.2.3\n## References\n* **Project:** https://netbox.dev/\n* **Documentation:** https://docs.netbox.dev/\n* **GitHub:** https://github.com/netbox-community/netbox\n",
    "author": "Christian Lempa",
    "template_version": "4.2.3",
    "icon": {
      "provider": "selfh",
      "id": "netbox"
    },
    "date": "2025-01-13",
    "draft": true
  },
  "entrypoint": {
    "path": "values.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "release_name",
      "type": "string",
      "label": "Release Name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "netbox"
    },
    {
      "key": "namespace",
      "type": "string",
      "label": "Namespace",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "netbox"
    },
    {
      "key": "database_enabled",
      "type": "boolean",
      "label": "Enable database",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "bool",
      "default": true,
      "description": "Enable database"
    },
    {
      "key": "database_type",
      "type": "string",
      "label": "Database type",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "enum",
      "default": "postgres",
      "description": "Database type",
      "options": [
        "postgres",
        "mysql"
      ]
    },
    {
      "key": "database_host",
      "type": "string",
      "label": "Database host",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "hostname",
      "default": "netbox-postgresql",
      "description": "Database host"
    },
    {
      "key": "database_port",
      "type": "number",
      "label": "Database port",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "int",
      "default": 5432,
      "description": "Database port"
    },
    {
      "key": "database_name",
      "type": "string",
      "label": "Database name",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "str",
      "default": "netbox",
      "description": "Database name"
    },
    {
      "key": "database_user",
      "type": "string",
      "label": "Database user",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "str",
      "default": "netbox",
      "description": "Database user"
    },
    {
      "key": "database_password",
      "type": "string",
      "label": "Database password",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "str",
      "description": "Database password",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "network_mode",
      "type": "string",
      "label": "Network mode for service",
      "required": false,
      "section": {
        "key": "networking",
        "title": "Networking Configuration"
      },
      "source_type": "str",
      "default": "ClusterIP",
      "description": "Network mode for service"
    },
    {
      "key": "redis_enabled",
      "type": "boolean",
      "label": "Enable Redis deployment",
      "required": false,
      "section": {
        "key": "redis",
        "title": "Redis Configuration",
        "required": true,
        "description": "Configure Redis for caching and task queuing"
      },
      "source_type": "bool",
      "default": true,
      "description": "Enable Redis deployment"
    },
    {
      "key": "redis_host",
      "type": "string",
      "label": "Redis host for tasks",
      "required": false,
      "section": {
        "key": "redis",
        "title": "Redis Configuration",
        "required": true,
        "description": "Configure Redis for caching and task queuing"
      },
      "source_type": "hostname",
      "default": "netbox-redis-master",
      "description": "Redis host for tasks"
    },
    {
      "key": "redis_cache_host",
      "type": "string",
      "label": "Redis host for caching",
      "required": false,
      "section": {
        "key": "redis",
        "title": "Redis Configuration",
        "required": true,
        "description": "Configure Redis for caching and task queuing"
      },
      "source_type": "hostname",
      "default": "netbox-redis-master",
      "description": "Redis host for caching"
    },
    {
      "key": "redis_password",
      "type": "string",
      "label": "Redis password",
      "required": false,
      "section": {
        "key": "redis",
        "title": "Redis Configuration",
        "required": true,
        "description": "Configure Redis for caching and task queuing"
      },
      "source_type": "str",
      "description": "Redis password",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "email_enabled",
      "type": "boolean",
      "label": "Enable email notifications",
      "required": false,
      "section": {
        "key": "email",
        "title": "Email Configuration",
        "toggle": "email_enabled"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable email notifications"
    },
    {
      "key": "email_host",
      "type": "string",
      "label": "SMTP server hostname",
      "required": false,
      "section": {
        "key": "email",
        "title": "Email Configuration",
        "toggle": "email_enabled"
      },
      "source_type": "hostname",
      "default": "smtp.example.com",
      "description": "SMTP server hostname"
    },
    {
      "key": "email_port",
      "type": "number",
      "label": "SMTP server port",
      "required": false,
      "section": {
        "key": "email",
        "title": "Email Configuration",
        "toggle": "email_enabled"
      },
      "source_type": "int",
      "default": 587,
      "description": "SMTP server port"
    },
    {
      "key": "email_username",
      "type": "string",
      "label": "SMTP username",
      "required": false,
      "section": {
        "key": "email",
        "title": "Email Configuration",
        "toggle": "email_enabled"
      },
      "source_type": "str",
      "default": "",
      "description": "SMTP username"
    },
    {
      "key": "email_from",
      "type": "string",
      "label": "From email address",
      "required": false,
      "section": {
        "key": "email",
        "title": "Email Configuration",
        "toggle": "email_enabled"
      },
      "source_type": "email",
      "default": "netbox@example.com",
      "description": "From email address"
    },
    {
      "key": "email_use_tls",
      "type": "boolean",
      "label": "Use TLS/STARTTLS for SMTP connection",
      "required": false,
      "section": {
        "key": "email",
        "title": "Email Configuration",
        "toggle": "email_enabled"
      },
      "source_type": "bool",
      "default": true,
      "description": "Use TLS/STARTTLS for SMTP connection"
    },
    {
      "key": "email_use_ssl",
      "type": "boolean",
      "label": "Use SSL for SMTP connection",
      "required": false,
      "section": {
        "key": "email",
        "title": "Email Configuration",
        "toggle": "email_enabled"
      },
      "source_type": "bool",
      "default": false,
      "description": "Use SSL for SMTP connection"
    },
    {
      "key": "traefik_enabled",
      "type": "boolean",
      "label": "Enable Traefik ingress",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Configuration",
        "toggle": "traefik_enabled"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik ingress"
    },
    {
      "key": "traefik_host",
      "type": "string",
      "label": "Traefik hostname",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Configuration",
        "toggle": "traefik_enabled"
      },
      "source_type": "hostname",
      "default": "netbox.home.arpa",
      "description": "Traefik hostname"
    },
    {
      "key": "traefik_tls_enabled",
      "type": "boolean",
      "label": "Enable TLS for Traefik ingress",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Configuration",
        "toggle": "traefik_enabled"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable TLS for Traefik ingress"
    },
    {
      "key": "traefik_tls_secret",
      "type": "string",
      "label": "TLS secret name for Traefik ingress",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Configuration",
        "toggle": "traefik_enabled"
      },
      "source_type": "str",
      "default": "netbox-tls",
      "description": "TLS secret name for Traefik ingress"
    },
    {
      "key": "traefik_tls_certmanager",
      "type": "boolean",
      "label": "Use cert-manager for TLS certificate",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Configuration",
        "toggle": "traefik_enabled"
      },
      "source_type": "bool",
      "default": false,
      "description": "Use cert-manager for TLS certificate"
    },
    {
      "key": "certmanager_issuer",
      "type": "string",
      "label": "Cert-manager issuer name",
      "required": false,
      "section": {
        "key": "traefik",
        "title": "Traefik Configuration",
        "toggle": "traefik_enabled"
      },
      "source_type": "str",
      "default": "letsencrypt-prod",
      "description": "Cert-manager issuer name",
      "needs": "traefik_tls_certmanager=true"
    },
    {
      "key": "volumes_mode",
      "type": "string",
      "label": "Volume storage mode",
      "required": false,
      "section": {
        "key": "volumes",
        "title": "Volume Configuration"
      },
      "source_type": "enum",
      "default": "pvc",
      "description": "Volume storage mode",
      "options": [
        "pvc",
        "hostPath"
      ]
    },
    {
      "key": "volumes_pvc_name",
      "type": "string",
      "label": "PVC name for volumes",
      "required": false,
      "section": {
        "key": "volumes",
        "title": "Volume Configuration"
      },
      "source_type": "str",
      "default": "netbox-data",
      "description": "PVC name for volumes"
    },
    {
      "key": "netbox_secret_key",
      "type": "string",
      "label": "Secret Key",
      "required": false,
      "section": {
        "key": "netbox",
        "title": "NetBox Configuration",
        "required": true,
        "description": "Configure NetBox application settings"
      },
      "source_type": "str",
      "description": "Secret Key",
      "extra": "Used for cryptographic signing and session management",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "netbox_superuser_name",
      "type": "string",
      "label": "Initial superuser username",
      "required": false,
      "section": {
        "key": "netbox",
        "title": "NetBox Configuration",
        "required": true,
        "description": "Configure NetBox application settings"
      },
      "source_type": "str",
      "default": "admin",
      "description": "Initial superuser username"
    },
    {
      "key": "netbox_superuser_email",
      "type": "string",
      "label": "Initial superuser email",
      "required": false,
      "section": {
        "key": "netbox",
        "title": "NetBox Configuration",
        "required": true,
        "description": "Configure NetBox application settings"
      },
      "source_type": "email",
      "default": "admin@example.com",
      "description": "Initial superuser email"
    },
    {
      "key": "netbox_superuser_password",
      "type": "string",
      "label": "Initial superuser password",
      "required": false,
      "section": {
        "key": "netbox",
        "title": "NetBox Configuration",
        "required": true,
        "description": "Configure NetBox application settings"
      },
      "source_type": "str",
      "description": "Initial superuser password",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "netbox_superuser_api_token",
      "type": "string",
      "label": "Initial superuser API token",
      "required": false,
      "section": {
        "key": "netbox",
        "title": "NetBox Configuration",
        "required": true,
        "description": "Configure NetBox application settings"
      },
      "source_type": "str",
      "description": "Initial superuser API token",
      "sensitive": true,
      "autogenerated": true
    },
    {
      "key": "netbox_allowed_hosts",
      "type": "string",
      "label": "Allowed hosts (comma-separated)",
      "required": false,
      "section": {
        "key": "netbox",
        "title": "NetBox Configuration",
        "required": true,
        "description": "Configure NetBox application settings"
      },
      "source_type": "str",
      "default": "*",
      "description": "Allowed hosts (comma-separated)",
      "extra": "Add your domain names or IP addresses"
    },
    {
      "key": "netbox_metrics_enabled",
      "type": "boolean",
      "label": "Enable Prometheus metrics endpoint",
      "required": false,
      "section": {
        "key": "netbox",
        "title": "NetBox Configuration",
        "required": true,
        "description": "Configure NetBox application settings"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Prometheus metrics endpoint"
    },
    {
      "key": "netbox_cors_enabled",
      "type": "boolean",
      "label": "Enable CORS (Cross-Origin Resource Sharing)",
      "required": false,
      "section": {
        "key": "netbox",
        "title": "NetBox Configuration",
        "required": true,
        "description": "Configure NetBox application settings"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable CORS (Cross-Origin Resource Sharing)"
    },
    {
      "key": "netbox_cors_origins",
      "type": "string",
      "label": "Allowed CORS origins",
      "required": false,
      "section": {
        "key": "netbox",
        "title": "NetBox Configuration",
        "required": true,
        "description": "Configure NetBox application settings"
      },
      "source_type": "str",
      "default": "https://example.com",
      "description": "Allowed CORS origins",
      "needs": "netbox_cors_enabled=true"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
