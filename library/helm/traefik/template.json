{
  "version": "1",
  "slug": "traefik",
  "kind": "helm",
  "metadata": {
    "name": "Traefik Ingress Controller",
    "description": "Helm values template for Traefik v3, a modern HTTP reverse proxy and load balancer designed for microservices.\n\nChart Repository: https://traefik.github.io/charts\nChart Name: traefik\nChart Version: Compatible with Traefik v3.5.3\n\nProject: https://traefik.io/\nDocumentation: https://doc.traefik.io/traefik/",
    "tags": [],
    "author": "Christian Lempa",
    "template_version": "3.5.3",
    "date": "2025-01-11",
    "icon": {
      "provider": "simpleicons",
      "id": "traefikproxy"
    },
    "draft": true,
    "next_steps": ""
  },
  "entrypoint": {
    "path": "values.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "release_name",
      "type": "string",
      "label": "Helm release name",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "traefik",
      "description": "Helm release name"
    },
    {
      "key": "namespace",
      "type": "string",
      "label": "Kubernetes namespace",
      "required": false,
      "section": {
        "key": "general"
      },
      "source_type": "str",
      "default": "traefik",
      "description": "Kubernetes namespace"
    },
    {
      "key": "network_mode",
      "type": "string",
      "label": "Network mode for service",
      "required": false,
      "section": {
        "key": "networking",
        "title": "Networking Configuration"
      },
      "source_type": "str",
      "default": "LoadBalancer",
      "description": "Network mode for service"
    },
    {
      "key": "database_enabled",
      "type": "boolean",
      "label": "Enable database",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable database"
    },
    {
      "key": "database_type",
      "type": "string",
      "label": "Database type",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "enum",
      "default": "postgres",
      "description": "Database type",
      "options": [
        "postgres",
        "mysql"
      ]
    },
    {
      "key": "database_host",
      "type": "string",
      "label": "Database host",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "hostname",
      "description": "Database host"
    },
    {
      "key": "database_port",
      "type": "number",
      "label": "Database port",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "int",
      "default": 5432,
      "description": "Database port"
    },
    {
      "key": "database_name",
      "type": "string",
      "label": "Database name",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "str",
      "description": "Database name"
    },
    {
      "key": "database_user",
      "type": "string",
      "label": "Database user",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "str",
      "description": "Database user"
    },
    {
      "key": "database_password",
      "type": "string",
      "label": "Database password",
      "required": false,
      "section": {
        "key": "database",
        "title": "Database Configuration",
        "toggle": "database_enabled"
      },
      "source_type": "str",
      "description": "Database password",
      "sensitive": true
    },
    {
      "key": "dashboard_host",
      "type": "string",
      "label": "FQDN for the Traefik dashboard",
      "required": false,
      "section": {
        "key": "dashboard",
        "title": "Dashboard IngressRoute",
        "toggle": "dashboard_ingressroute_enabled"
      },
      "source_type": "hostname",
      "description": "FQDN for the Traefik dashboard"
    },
    {
      "key": "dashboard_ingressroute_enabled",
      "type": "boolean",
      "label": "Create IngressRoute for Traefik dashboard",
      "required": false,
      "section": {
        "key": "dashboard",
        "title": "Dashboard IngressRoute",
        "toggle": "dashboard_ingressroute_enabled"
      },
      "source_type": "bool",
      "default": false,
      "description": "Create IngressRoute for Traefik dashboard"
    },
    {
      "key": "dashboard_middleware",
      "type": "string",
      "label": "Authentication middleware name for dashboard protection",
      "required": false,
      "section": {
        "key": "dashboard",
        "title": "Dashboard IngressRoute",
        "toggle": "dashboard_ingressroute_enabled"
      },
      "source_type": "str",
      "default": "traefik-dashboard-auth",
      "description": "Authentication middleware name for dashboard protection"
    },
    {
      "key": "dashboard_tls_secret",
      "type": "string",
      "label": "TLS secret name for dashboard",
      "required": false,
      "section": {
        "key": "dashboard",
        "title": "Dashboard IngressRoute",
        "toggle": "dashboard_ingressroute_enabled"
      },
      "source_type": "str",
      "default": "traefik-dashboard-tls",
      "description": "TLS secret name for dashboard"
    },
    {
      "key": "release_name",
      "type": "string",
      "label": "Release Name",
      "required": false,
      "section": {
        "key": "dashboard",
        "title": "Dashboard IngressRoute",
        "toggle": "dashboard_ingressroute_enabled"
      },
      "source_type": "str",
      "default": "traefik"
    },
    {
      "key": "http_redirect_enabled",
      "type": "boolean",
      "label": "Automatically redirect HTTP traffic to HTTPS",
      "required": false,
      "section": {
        "key": "http_redirect",
        "title": "HTTP to HTTPS Redirect",
        "toggle": "http_redirect_enabled"
      },
      "source_type": "bool",
      "default": true,
      "description": "Automatically redirect HTTP traffic to HTTPS"
    },
    {
      "key": "http_redirect_permanent",
      "type": "boolean",
      "label": "Use permanent redirect (301) instead of temporary (302)",
      "required": false,
      "section": {
        "key": "http_redirect",
        "title": "HTTP to HTTPS Redirect",
        "toggle": "http_redirect_enabled"
      },
      "source_type": "bool",
      "default": true,
      "description": "Use permanent redirect (301) instead of temporary (302)"
    },
    {
      "key": "accesslog_enabled",
      "type": "boolean",
      "label": "Enable Traefik access log",
      "required": false,
      "section": {
        "key": "traefik_config",
        "title": "Traefik Settings"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik access log"
    },
    {
      "key": "dashboard_enabled",
      "type": "boolean",
      "label": "Enable Traefik dashboard",
      "required": false,
      "section": {
        "key": "traefik_config",
        "title": "Traefik Settings"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Traefik dashboard",
      "extra": "WARNING: Don't use in production!"
    },
    {
      "key": "prometheus_enabled",
      "type": "boolean",
      "label": "Enable Prometheus metrics",
      "required": false,
      "section": {
        "key": "traefik_config",
        "title": "Traefik Settings"
      },
      "source_type": "bool",
      "default": false,
      "description": "Enable Prometheus metrics"
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
