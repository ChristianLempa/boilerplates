{
  "version": "1",
  "slug": "certmanager",
  "kind": "helm",
  "metadata": {
    "name": "Cert-Manager",
    "description": "Helm values template for cert-manager, a Kubernetes add-on to automate the management and issuance of TLS certificates from various sources.\n\nChart Repository: https://charts.jetstack.io\nChart Name: cert-manager\nChart Version: Compatible with cert-manager v1.18.2\n\nProject: https://cert-manager.io/\nDocumentation: https://cert-manager.io/docs/",
    "tags": [],
    "author": "Christian Lempa",
    "template_version": "1.18.2",
    "date": "2025-01-11",
    "icon": {
      "provider": "simple-icons",
      "id": "letsencrypt"
    },
    "draft": true,
    "next_steps": ""
  },
  "entrypoint": {
    "path": "values.yaml",
    "type": "file"
  },
  "variables": [
    {
      "key": "general",
      "title": "General",
      "variables": [
        {
          "name": "release_name",
          "type": "str",
          "title": "Helm release name",
          "required": false,
          "default": "cert-manager",
          "description": "Helm release name"
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Kubernetes namespace",
          "required": false,
          "default": "cert-manager",
          "description": "Kubernetes namespace"
        }
      ]
    },
    {
      "key": "networking",
      "title": "Networking Configuration",
      "variables": [
        {
          "name": "network_mode",
          "type": "str",
          "title": "Network mode for service",
          "required": false,
          "default": "ClusterIP",
          "description": "Network mode for service"
        }
      ]
    },
    {
      "key": "database",
      "title": "Database Configuration",
      "variables": [
        {
          "name": "database_enabled",
          "type": "bool",
          "title": "Enable database",
          "required": false,
          "default": false,
          "description": "Enable database"
        },
        {
          "name": "database_type",
          "type": "str",
          "title": "Database type",
          "required": false,
          "default": "postgres",
          "description": "Database type",
          "options": [
            "postgres",
            "mysql"
          ]
        },
        {
          "name": "database_host",
          "type": "str",
          "title": "Database host",
          "required": false,
          "description": "Database host"
        },
        {
          "name": "database_port",
          "type": "int",
          "title": "Database port",
          "required": false,
          "default": 5432,
          "description": "Database port"
        },
        {
          "name": "database_name",
          "type": "str",
          "title": "Database name",
          "required": false,
          "description": "Database name"
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database user",
          "required": false,
          "description": "Database user"
        },
        {
          "name": "database_password",
          "type": "str",
          "title": "Database password",
          "required": false,
          "description": "Database password",
          "sensitive": true
        }
      ]
    },
    {
      "key": "dns",
      "title": "DNS Configuration",
      "variables": [
        {
          "name": "dns_nameserver_1",
          "type": "str",
          "title": "Primary DNS nameserver for DNS01 challenges",
          "required": false,
          "default": "1.1.1.1:53",
          "description": "Primary DNS nameserver for DNS01 challenges"
        },
        {
          "name": "dns_nameserver_2",
          "type": "str",
          "title": "Secondary DNS nameserver for DNS01 challenges",
          "required": false,
          "default": "1.0.0.1:53",
          "description": "Secondary DNS nameserver for DNS01 challenges"
        },
        {
          "name": "dns_recursive_nameservers_only",
          "type": "bool",
          "title": "Use only recursive nameservers for DNS01 challenges",
          "required": false,
          "default": true,
          "description": "Use only recursive nameservers for DNS01 challenges"
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Namespace",
          "required": false,
          "default": "cert-manager"
        },
        {
          "name": "release_name",
          "type": "str",
          "title": "Release Name",
          "required": false,
          "default": "cert-manager"
        }
      ]
    }
  ],
  "legacy": {
    "schema": "1.2"
  }
}
